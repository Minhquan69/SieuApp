<Window x:Class="V3SClient.window.ClientProfileEditWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local="clr-namespace:V3SClient.window" xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks" mc:Ignorable="d" Title="{Binding WindowTitle}" Height="550" Width="600" WindowStartupLocation="CenterScreen" WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True" Background="Transparent" FontFamily="Arial">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../styles/customize_button.xaml" />
                <ResourceDictionary Source="../styles/customize_textbox.xaml" />
            <ResourceDictionary Source="/styles/client_profile_edit_window_styles.xaml" /></ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="#111318" CornerRadius="8" BorderBrush="#252830" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="45" />
                <RowDefinition Height="*" />
                <RowDefinition Height="60" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#161920" CornerRadius="8,8,0,0">
                <Grid>
                    <TextBlock Text="{Binding WindowTitle}" Foreground="#E8ECF1" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" Margin="15,0,0,0" />
                    <Button Click="BtnClose_Click" Style="{StaticResource gridRemoveButton}" Background="Transparent" BorderThickness="0" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Width="30" Height="30">
                        <Icon:PackIconMaterial Kind="Close" Width="14" Height="14" Foreground="#8B95A5" />
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <TabControl Grid.Row="1" Margin="10" Background="Transparent" BorderThickness="0">
                <TabControl.Resources><ResourceDictionary Source="/styles/client_profile_edit_window_scope01_styles.xaml" /></TabControl.Resources>

                <!-- Tab 1: General Info -->
                <TabItem Header="Thông tin chung">
                    <Grid Margin="10,20,10,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Tên client *" Grid.Row="0" Grid.Column="0" Margin="5" Foreground="#E8ECF1" VerticalAlignment="Center" FontWeight="SemiBold" />
                        <TextBox x:Name="TxtName" Grid.Row="0" Grid.Column="1" Margin="5" Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Style="{StaticResource CustomTextBoxStyle}" Height="30" Tag="Nhập tên client" />

                        <TextBlock Text="Mã Client *" Grid.Row="1" Grid.Column="0" Margin="5" Foreground="#E8ECF1" VerticalAlignment="Center" FontWeight="SemiBold" />
                        <TextBox x:Name="TxtCode" Grid.Row="1" Grid.Column="1" Margin="5" Text="{Binding ProfileCode, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Style="{StaticResource CustomTextBoxStyle}" Height="30" Tag="Nhập mã client (ví dụ: CLI_001)" />

                        <TextBlock Text="Mô tả" Grid.Row="2" Grid.Column="0" Margin="5" Foreground="#E8ECF1" VerticalAlignment="Center" FontWeight="SemiBold" />
                        <TextBox x:Name="TxtDescription" Grid.Row="2" Grid.Column="1" Margin="5" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Text="{Binding ProfileDescription, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Style="{StaticResource CustomTextBoxStyle}" VerticalContentAlignment="Top" Padding="5" Tag="Nhập thông tin mô tả" />
                    </Grid>
                </TabItem>

                <!-- Tab 2: Users -->
                <TabItem Header="Người dùng">
                    <Grid Margin="5,10,5,5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBox x:Name="TxtSearchUser" Margin="0,0,0,10" Style="{StaticResource CustomTextBoxStyle}" Height="28" Tag="Nhập tìm kiếm người dùng..." TextChanged="TxtSearchUser_TextChanged" />
                        <ListBox Grid.Row="1" ItemsSource="{Binding UserList}" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ItemContainerStyle="{StaticResource ClientProfileEditWindowListBoxItem01Style}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsChecked}" Margin="5,5,5,5" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding UserName}" Foreground="#E8ECF1" FontWeight="Bold" />
                                            <TextBlock Text="{Binding FullName}" Foreground="#8B95A5" Margin="10,0,0,0" />
                                        </StackPanel>
                                    </CheckBox>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            
                        </ListBox>
                    </Grid>
                </TabItem>
 
                <!-- Tab 3: Cameras -->
                <TabItem Header="Camera">
                    <Grid Margin="5,10,5,5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBox x:Name="TxtSearchCamera" Margin="0,0,0,10" Style="{StaticResource CustomTextBoxStyle}" Height="28" Tag="Nhập  tìm camera..." TextChanged="TxtSearchCamera_TextChanged" />
                        <ListBox Grid.Row="1" ItemsSource="{Binding CameraList}" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ItemContainerStyle="{StaticResource ClientProfileEditWindowListBoxItem02Style}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsChecked}" Margin="5,5,5,5" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding CameraCode}" Foreground="#E8ECF1" FontWeight="Bold" />
                                            <TextBlock Text="{Binding DisplayName}" Foreground="#8B95A5" Margin="10,0,0,0" />
                                        </StackPanel>
                                    </CheckBox>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            
                        </ListBox>
                    </Grid>
                </TabItem>
            </TabControl>
 
            <!-- Footer (Buttons) -->
            <Border Grid.Row="2" Background="#161920" CornerRadius="0,0,8,8">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,15,0">
                    <Button Content="Hủy" Click="BtnCancel_Click" Width="80" Height="32" Margin="0,0,10,0" Style="{StaticResource gridRemoveButton}" Background="Transparent" Foreground="#E8ECF1" BorderBrush="#252830" BorderThickness="1" />
                    <Button Content="Lưu" Command="{Binding SaveCommand}" Width="80" Height="32" Background="#4A9EFF" Foreground="#0D0F12" FontWeight="Bold" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>




















