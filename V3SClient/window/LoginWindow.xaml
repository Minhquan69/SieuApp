<Window x:Class="V3SClient.window.LoginWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local="clr-namespace:V3SClient.window" mc:Ignorable="d" Title="Đăng nhập" Height="250" Width="360" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" AllowsTransparency="True" WindowStyle="None" Background="Transparent" Loaded="Window_Loaded">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../styles/login_window_styles.xaml" />
                <ResourceDictionary Source="../styles/customize_combobox.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border BorderThickness="1" CornerRadius="10" BorderBrush="#252830" Background="#0D0F12" Padding="10">
        <Grid Margin="2">
        
            <Button x:Name="SettingsButton" Content="⚙" ToolTip="Cấu hình" Width="30" Height="30" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,35,0" Background="Transparent" BorderBrush="{x:Null}" Foreground="#8B95A5" FontSize="12" Click="SettingsButton_Click" Cursor="Hand" />

            <Button Content="X" ToolTip="Thoát" Width="30" Height="30" HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderBrush="{x:Null}" Foreground="#8B95A5" FontWeight="Bold" Click="CancelButton_Click" Cursor="Hand" />

            <StackPanel Margin="0,30,0,0" HorizontalAlignment="Center">

                <!-- Tiêu đề -->
                <TextBlock Text="ĐĂNG NHẬP" FontSize="18" FontWeight="Bold" Foreground="#4A9EFF" HorizontalAlignment="Center" Margin="0,0,0,15" />

                <!-- Username -->
                <StackPanel Orientation="Horizontal" Margin="0 5">
                    <Image Source="/images/login/login_user.png" Width="24" Height="24" Margin="0,0,10,0" />
                    <Grid>
                        <TextBox x:Name="UsernameBox" Width="250" Height="30" Style="{StaticResource LoginInputTextBoxStyle}" TextChanged="UsernameBox_TextChanged" VerticalContentAlignment="Center" />
                        <TextBlock x:Name="UsernamePlaceholder" Text="Tên đăng nhập" Foreground="#8B95A5" Margin="8,0,0,0" IsHitTestVisible="False" VerticalAlignment="Center" Visibility="Visible" />
                    </Grid>
                </StackPanel>

                <!-- Password -->
                <StackPanel Orientation="Horizontal" Margin="0 5">
                    <Image Source="/images/login/login_password.png" Width="24" Height="24" Margin="0,0,10,0" />
                    <Grid>
                        <PasswordBox x:Name="PasswordBox" Width="250" Height="30" Style="{StaticResource LoginInputPasswordBoxStyle}" PasswordChanged="PasswordBox_PasswordChanged" VerticalContentAlignment="Center" />
                        <!-- TextBox to show password -->
                        <TextBox x:Name="PasswordTextBox" Width="250" Height="30" Style="{StaticResource LoginInputTextBoxStyle}" TextChanged="PasswordTextBox_TextChanged" VerticalContentAlignment="Center" Visibility="Collapsed" />
                        <TextBlock x:Name="PasswordPlaceholder" Text="Mật khẩu" Foreground="#8B95A5" Margin="8,0,0,0" IsHitTestVisible="False" VerticalAlignment="Center" Visibility="Visible" />

                        <Button x:Name="TogglePasswordButton" ToolTip="Ẩn/Hiện mật khẩu" Click="TogglePasswordVisibility_Click" Content="👁" FontSize="12" Width="30" Height="30" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Foreground="#8B95A5" Cursor="Hand" />
                    </Grid>
                </StackPanel>

                <!-- Client ComboBox -->
                <StackPanel x:Name="ClientPanel" Visibility="Collapsed" Margin="30,10,0,0" HorizontalAlignment="Center">
                    <TextBlock Text="Chọn client để bắt đầu" Foreground="#E8ECF1" FontWeight="Bold" Margin="0,0,0,5" HorizontalAlignment="Left" Width="250" />
                    <ComboBox x:Name="ClientComboBox" Height="28" Width="250" Style="{StaticResource CustomComboBoxStyle}" ItemContainerStyle="{StaticResource CustomComboBoxItemStyle}" HorizontalAlignment="Left">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayText}" Foreground="#E8ECF1" FontFamily="Segoe UI" FontSize="12" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <CheckBox x:Name="RememberMeCheckBox" Content="Nhớ mật khẩu" Margin="33,10,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" Foreground="#8B95A5" />
                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                    <Button x:Name="LoginButton" Content="Đăng nhập" Width="70" Margin="0,0,10,0" Click="LoginButton_Click" Style="{StaticResource LoginWindowRoundedButtonStyle}" IsDefault="True" />
                    <Button x:Name="ConfirmButton" Content="Xác nhận" Width="70" Margin="0,0,10,0" Visibility="Collapsed" Click="ConfirmButton_Click" Style="{StaticResource LoginWindowRoundedButtonStyle}" />
                    <Button Content="Hủy" Width="70" Click="CancelButton_Click" Background="#252830" Foreground="#E8ECF1" Style="{StaticResource LoginWindowRoundedButtonStyle}" />
                </StackPanel>

            </StackPanel>
        </Grid>
    </Border>
</Window>
