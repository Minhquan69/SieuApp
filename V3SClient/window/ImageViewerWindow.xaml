<Window x:Class="V3SClient.window.ImageViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:V3SClient.window"
        mc:Ignorable="d"
        Title="Image viewer" Height="600" Width="800"
        Background="Black" ResizeMode="CanResize">
    <Grid>
        <!-- Main image inside a scroll viewer for zooming -->
        <ScrollViewer x:Name="ScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
            <Image x:Name="LargeImage"
                   RenderTransformOrigin="0.0,0.0"
                   Stretch="None">
                <Image.RenderTransform>
                    <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1"/>
                </Image.RenderTransform>
            </Image>
        </ScrollViewer>

        <!-- Buttons at bottom right -->
        <Border HorizontalAlignment="Right"
        VerticalAlignment="Bottom"
        Margin="20"
        Background="#88000000"
        CornerRadius="6"
        Padding="6">
            <StackPanel Orientation="Horizontal">
                <Button Click="ZoomIn_Click" Margin="2" ToolTip="Zoom In">
                    <Image Width="20" Height="20" Source="/images/imageViewer/zoom_in.png"/>
                </Button>
                <Button Click="ZoomOut_Click" Margin="2" ToolTip="Zoom Out">
                    <Image Width="20" Height="20" Source="/images/imageViewer/zoom_out.png"/>
                </Button>
                <Button Click="FitImage_Click" Margin="2" ToolTip="Fit to Window">
                    <Image Width="20" Height="20" Source="/images/imageViewer/fit_to_page.png"/>
                </Button>
                <Button Click="PanToggle_Click" Margin="2" ToolTip="Pan Mode">
                    <Image Width="20" Height="20" Source="/images/imageViewer/pan.png"/>
                </Button>
            </StackPanel>
        </Border>
        
        
    </Grid>
</Window>



















