<Window x:Class="V3SClient.window.ClientSwitchWindow_v3" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" WindowStyle="None" AllowsTransparency="True" Background="Transparent" Width="700" Height="650" MinWidth="560" MinHeight="520" WindowStartupLocation="CenterScreen" FontFamily="Segoe UI" ShowInTaskbar="True">
    <Window.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries><ResourceDictionary Source="/styles/V3Migration/ClientSwitchWindow_v3.xaml"/></ResourceDictionary.MergedDictionaries></ResourceDictionary></Window.Resources>
    <Border Background="{StaticResource VmsBackgroundBrush_v3}" BorderBrush="{StaticResource VmsBorderBrush_v3}" BorderThickness="1" CornerRadius="16" Padding="30">
        <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Chọn Client" Foreground="{StaticResource VmsTextPrimaryBrush_v3}" FontSize="26" FontWeight="SemiBold"/><TextBlock Text="Chọn client trước khi vào hệ thống." Foreground="{StaticResource VmsTextSecondaryBrush_v3}" FontSize="13" Margin="0,5,0,0"/></StackPanel><Button Grid.Column="1" Content="—" Click="Minimize_Click" Style="{StaticResource ClientSwitchButton_v3}" Padding="12,4" Margin="0,0,8,0"/><Button Grid.Column="2" Content="×" Click="Close_Click" Style="{StaticResource ClientSwitchButton_v3}" Padding="12,4"/></Grid>
            <Grid Grid.Row="1" Margin="0,30,0,20"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><Grid><TextBlock Text="Danh sách Client" Foreground="{StaticResource VmsTextPrimaryBrush_v3}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/><Button Content="Tải lại" Command="{Binding ReloadCommand}" HorizontalAlignment="Right" Style="{StaticResource ClientSwitchButton_v3}" Padding="13,6"/></Grid><ListBox Grid.Row="1" ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile, Mode=TwoWay}" ItemContainerStyle="{StaticResource ClientSwitchListBoxItem_v3}" Background="Transparent" BorderThickness="0" Margin="0,16,0,0" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled"><ListBox.Resources><Style TargetType="ScrollBar" BasedOn="{StaticResource ClientSwitchScrollBar_v3}"/></ListBox.Resources><ListBox.ItemTemplate><DataTemplate><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="30"/><ColumnDefinition/></Grid.ColumnDefinitions><TextBlock Text="▣" Foreground="{StaticResource VmsPrimaryBrush_v3}" FontSize="19" VerticalAlignment="Top"/><StackPanel Grid.Column="1"><TextBlock Text="{Binding Name}" Foreground="{StaticResource VmsTextPrimaryBrush_v3}" FontSize="16" FontWeight="SemiBold"/><TextBlock Text="{Binding Code}" Foreground="{StaticResource VmsTextSecondaryBrush_v3}" FontSize="12" Margin="0,5,0,0"/><TextBlock Text="{Binding Description}" Foreground="{StaticResource VmsTextSecondaryBrush_v3}" FontSize="12" TextWrapping="Wrap" Margin="0,3,0,0"/></StackPanel></Grid></DataTemplate></ListBox.ItemTemplate></ListBox></Grid>
            <Border Grid.Row="2" BorderBrush="{StaticResource VmsBorderBrush_v3}" BorderThickness="0,1,0,0" Padding="0,18,0,0"><Grid><TextBlock Text="Đang chọn: " Foreground="{StaticResource VmsTextSecondaryBrush_v3}" FontSize="13" VerticalAlignment="Center"><Run Text="{Binding SelectedProfileName, Mode=OneWay}" Foreground="{StaticResource VmsTextPrimaryBrush_v3}"/></TextBlock><Button Content="✓  Vào hệ thống" Command="{Binding ConfirmCommand}" HorizontalAlignment="Right" Style="{StaticResource ClientSwitchPrimaryButton_v3}"/></Grid></Border>
        </Grid>
    </Border>
</Window>
