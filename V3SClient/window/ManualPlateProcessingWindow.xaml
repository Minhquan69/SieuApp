<Window x:Class="V3SClient.window.ManualPlateProcessingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Xử lý ảnh thủ công" Width="760" Height="520"
        MinWidth="680" MinHeight="460" WindowStartupLocation="CenterOwner"
        Background="#0D0F12" Foreground="#E8ECF1">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/styles/form_base.xaml" />
                <ResourceDictionary Source="/styles/customize_button_v2.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.35*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <Border Background="#111318" BorderBrush="#252830" BorderThickness="1" CornerRadius="8" Padding="8">
            <Image x:Name="PreviewImage" Stretch="Uniform" />
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="XỬ LÝ THỦ CÔNG" Foreground="#4A9EFF" FontSize="16" FontWeight="Bold" />
            <StackPanel Grid.Row="1" Margin="0,14,0,0">
                <TextBlock Text="Tên ảnh" Style="{StaticResource FieldLabelBase}" />
                <TextBlock x:Name="FileNameText" Foreground="#E8ECF1" TextWrapping="Wrap" Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel Grid.Row="2" Margin="0,14,0,0">
                <TextBlock Text="Lỗi xử lý gần nhất" Style="{StaticResource FieldLabelBase}" />
                <TextBlock x:Name="ErrorText" Foreground="#FF6B6B" TextWrapping="Wrap" Margin="0,4,0,0" MaxHeight="72" />
            </StackPanel>
            <StackPanel Grid.Row="3" Margin="0,16,0,0">
                <TextBlock Text="Biển số xe xác nhận" Style="{StaticResource FieldLabelBase}" />
                <TextBox x:Name="PlateTextBox" Style="{StaticResource FieldInputBase}" Height="34"
                         Margin="0,5,0,0" CharacterCasing="Upper" MaxLength="15" />
                <TextBlock Text="Ví dụ: 29A-123.45" Foreground="#8B95A5" FontSize="10" Margin="2,4,0,0" />
            </StackPanel>
            <CheckBox x:Name="ConfirmImageCheckBox" Grid.Row="4" VerticalAlignment="Top"
                      Margin="0,18,0,0" Foreground="#E8ECF1">
                <TextBlock Text="Tôi xác nhận ảnh đủ rõ và biển số nhập ở trên là chính xác"
                           TextWrapping="Wrap" Foreground="#E8ECF1" />
            </CheckBox>

            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Hủy" Width="82" Height="34" Margin="0,0,8,0"
                        Style="{StaticResource toolbarAddButton}" Click="Cancel_Click" />
                <Button Content="Đưa vào xử lý" Width="130" Height="34"
                        Style="{StaticResource toolbarAddButton}" Click="Confirm_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
