<UserControl x:Class="V3SClient.ucs.Settings.views.DynamicDataGridControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:V3SClient.ucs.Settings.views"
             mc:Ignorable="d" x:Name="RootControl"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:ei="http://schemas.microsoft.com/expression/2010/interactions"
             xmlns:converters="clr-namespace:V3SClient.UI.Converters"
             d:DesignHeight="450" d:DesignWidth="800" >
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../../styles/customize_button.xaml" />
                <ResourceDictionary Source="../../../styles/customize_image.xaml" />
                <ResourceDictionary Source="../../../styles/customize_textblock.xaml" />
                <ResourceDictionary Source="../../../styles/customize_datagrid.xaml"/>
                <ResourceDictionary Source="../../../styles/border_reseted.xaml" />
                <ResourceDictionary Source="../../../styles/customize_scrollviewer.xaml" />
                <ResourceDictionary Source="../../../styles/customize_combobox.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border BorderBrush="#252830" Background="#111318" BorderThickness="0.2" CornerRadius="5" Padding="10">
        <!--<Border.Effect>
            <DropShadowEffect Color="LightGray" Direction="270" ShadowDepth="5" Opacity="0.4" BlurRadius="8"/>
        </Border.Effect>-->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="20" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding WindowTitle}" Style="{StaticResource label_TextBlock }" Margin="0,3,0,0" FontSize="24"/>
            <Separator Grid.Row="1" Margin="5,1,5,1" Background="#252830" DockPanel.Dock="Top" Height="0.8"/>

            <DataGrid x:Name="DynamicGrid"
                      Grid.Row="2"
                      ItemsSource="{Binding PagedItems}"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      CanUserAddRows="False"
                      IsReadOnly="False"
                      RowHeaderWidth="0"
                      SelectionMode="Single"
                      Margin="10"
                      AlternatingRowBackground="#161920"
                      RowBackground="#111318"
                      Foreground="#E8ECF1"
                      ColumnHeaderHeight="45">
                <DataGrid.Resources>
                    <ResourceDictionary Source="/styles/settings_base.xaml" />
                </DataGrid.Resources>
            </DataGrid>


            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Pagination Left Aligned -->
                <StackPanel Orientation="Horizontal" Height="28" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,0,0,0">
                    <Button Style="{StaticResource No_HandOver_Button}" Command="{Binding PreviousPageCommand}" Background="Transparent" Padding="0" BorderThickness="0" Width="16" Height="16">
                        <Image Source="/images/arrow_square_left.png" Style="{StaticResource ImageFull}" />
                    </Button>
                    <TextBox Width="24" Text="{Binding PageInput, UpdateSourceTrigger=PropertyChanged}" Background="#161920" Foreground="#E8ECF1" BorderBrush="#252830" BorderThickness="1" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Margin="5">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="LostFocus">
                                <i:InvokeCommandAction Command="{Binding PageInputLostFocusCommand}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </TextBox>
                    <TextBlock VerticalAlignment="Center" Margin="5" FontWeight="Bold" Foreground="#E8ECF1">
                        <Run Text="/ "/><Run Text="{Binding TotalPages}" />
                    </TextBlock>
                    <Button Style="{StaticResource No_HandOver_Button}" Command="{Binding NextPageCommand}" Background="Transparent" Padding="0" BorderThickness="0" Width="16" Height="16">
                        <Image Source="/images/arrows/arrow-square-right.png" Style="{StaticResource ImageFull}" />
                    </Button>
                </StackPanel>

                <!-- Buttons Right Aligned -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <!-- Save Button -->
                    <Button Visibility="{Binding ShowSaveButton, Converter={StaticResource BoolToVisibilityConverter}}" Width="100" Height="35" Margin="5" Background="#4A9EFF" Foreground="#0D0F12" FontWeight="Bold" Cursor="Hand" Command="{Binding SaveCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" BorderBrush="Transparent" BorderThickness="1">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#6BB2FF"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#358BE0"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="border" Property="Background" Value="#252830"/>
                                        <Setter Property="Foreground" Value="#8B95A5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="💾" FontSize="14" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Lưu" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Close Button -->
                    <Button Visibility="{Binding ShowCancelButton, Converter={StaticResource BoolToVisibilityConverter}}" Width="100" Height="35" Margin="5" Background="#252830" Foreground="#E8ECF1" FontWeight="Bold" Cursor="Hand" Command="{Binding CancelCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" BorderBrush="#252830" BorderThickness="1">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#30343F"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#1C1E24"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="border" Property="Background" Value="#161920"/>
                                        <Setter Property="Foreground" Value="#8B95A5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="❌" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Đóng" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        
        </Grid>
    </Border>
</UserControl>




















