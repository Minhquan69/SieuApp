<UserControl x:Class="V3SClient.ucs.Settings.views.AIConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:V3SClient.ucs.Settings.views"
             xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:converters="clr-namespace:V3SClient.UI.Converters"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../../styles/customize_button.xaml" />
                <ResourceDictionary Source="../../../styles/customize_button_v2.xaml" />
                <ResourceDictionary Source="../../../styles/customize_image.xaml" />
                <ResourceDictionary Source="../../../styles/customize_textblock.xaml" />
                <ResourceDictionary Source="../../../styles/customize_datagrid.xaml"/>
                <ResourceDictionary Source="../../../styles/border_reseted.xaml" />
                <ResourceDictionary Source="../../../styles/customize_combobox.xaml" />
                <ResourceDictionary Source="../../../styles/customize_textbox.xaml" />
                <ResourceDictionary Source="../../../styles/customize_checkbox_v2.xaml" />
                <ResourceDictionary Source="../../../styles/customize_scrollviewer.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis" />
            <converters:TypeToImageConverter x:Key="TypeToImageConverter"/>
            <converters:IndexPlusOneConverter  x:Key="IndexPlusOneConverter"/>
            <converters:TrimConverter  x:Key="TrimConverter"/>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <Border CornerRadius="15,2,2,2" Background="#111318" Margin="12,0,10,0">
        <DockPanel Margin="10" LastChildFill="True">

            <!-- Title Row -->
            <StackPanel DockPanel.Dock="Top">
                <DockPanel Margin="0,5,0,10">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <Icon:PackIconMaterial Kind="Brain" Width="20" Height="20" Foreground="#4A9EFF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Cấu hình AI Node Camera" FontWeight="Bold" FontSize="20" Foreground="#E8ECF1" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                        <Button Command="{Binding RefreshCommand}" ToolTip="Làm mới" Style="{StaticResource toolbarRefreshButton}">
                            <StackPanel Orientation="Horizontal">
                                <Icon:PackIconMaterial Kind="Refresh" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="Làm mới" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </DockPanel>

                <!-- Search and Filter Row -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource CustomTextBoxStyle}"
                             Width="250" Height="28" Margin="0,0,10,0"
                             Tag="Nhập tìm kiếm camera..."/>

                    <ComboBox SelectedValue="{Binding FilterType}" SelectedValuePath="Tag" 
                              Style="{StaticResource CustomComboBoxStyle}"
                              Width="140" Height="28" Margin="0,0,10,0" FontSize="12">
                        <ComboBoxItem Content="Tất cả" Tag="{x:Null}" Style="{StaticResource CustomComboBoxItemStyle}"/>
                        <ComboBoxItem Content="IP Camera" Tag="ip_cam" Style="{StaticResource CustomComboBoxItemStyle}"/>
                        <ComboBoxItem Content="Body Camera" Tag="body_cam" Style="{StaticResource CustomComboBoxItemStyle}"/>
                    </ComboBox>


                </StackPanel>
            </StackPanel>

            <!-- Bottom pagination bar -->
            <Grid DockPanel.Dock="Bottom">
                <Grid.RowDefinitions>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Height="0.8" Background="#252830" Margin="1">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="0" Opacity="0.3"/>
                    </Border.Effect>
                </Border>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Height="28" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="2">
                    <Button Style="{StaticResource No_HandOver_Button}" Command="{Binding PreviousPageCommand}" Background="Transparent" Padding="0" BorderThickness="0" Width="16" Height="16">
                        <Image Source="../../../images/arrow_square_left.png" Style="{StaticResource ImageFull}" />
                    </Button>
                    <TextBox Width="24" Text="{Binding PageInput, UpdateSourceTrigger=PropertyChanged}" Background="#161920" Foreground="#E8ECF1" BorderBrush="#252830" BorderThickness="1" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Margin="5">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="LostFocus">
                                <i:InvokeCommandAction Command="{Binding PageInputLostFocusCommand}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </TextBox>
                    <TextBlock VerticalAlignment="Center" Margin="5" FontWeight="Bold" Foreground="#E8ECF1"> <Run Text="/ "/> <Run Text="{Binding TotalPages}" />
                    </TextBlock>
                    <Button Style="{StaticResource No_HandOver_Button}" Command="{Binding NextPageCommand}" Background="Transparent" Padding="0" BorderThickness="0" Width="16" Height="16">
                        <Image Source="../../../images/arrows/arrow-square-right.png" Style="{StaticResource ImageFull}" />
                    </Button>
                    <TextBlock VerticalAlignment="Center" Margin="15,0,0,0" Foreground="#999" FontSize="12">
                        <Run Text="Tổng: "/>
                        <Run Text="{Binding TotalItems, Mode=OneWay}"/>
                        <Run Text=" camera"/>
                    </TextBlock>
                </StackPanel>
            </Grid>

            <!-- DataGrid -->
            <DataGrid ItemsSource="{Binding PagedItems}"
                  SelectedItem="{Binding SelectedItem}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  IsReadOnly="True"
                  ColumnWidth="auto">
                <DataGrid.Resources>
                    <ResourceDictionary Source="/styles/settings_base.xaml" />
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="30" />
                    <DataGridTextColumn Header="Tên Camera" Binding="{Binding DisplayName1}" Width="*" />
                    <DataGridTextColumn Header="Mã định danh" Binding="{Binding CameraCode}" Width="120" />
                    <DataGridTextColumn Header="AI Node Name" Binding="{Binding AiNodeName}" Width="150" />
                    <DataGridTextColumn Header="Chế độ" Binding="{Binding OperationModeDisplay}" Width="100" />

                    <!-- Actions -->
                    <DataGridTemplateColumn Header="Gán AI Node" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Margin="0"
                                            Style="{StaticResource gridEditButton}" Height="28" Width="90"
                                            Command="{Binding DataContext.AIConfigCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Gán AI Node">
                                        <StackPanel Orientation="Horizontal">
                                            <Icon:PackIconMaterial Kind="Brain" Width="14" Height="14" Style="{StaticResource gridButtonIcon}" Margin="0,0,5,0" />
                                            <TextBlock Text="Cấu hình"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Border>
</UserControl>




















