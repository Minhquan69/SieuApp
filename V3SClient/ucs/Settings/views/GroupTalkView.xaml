<UserControl x:Class="V3SClient.ucs.Settings.views.GroupTalkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:V3SClient.ucs.Settings.views"
             xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
            xmlns:converters="clr-namespace:V3SClient.UI.Converters"
            xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../../styles/customize_button.xaml" />
                <ResourceDictionary Source="../../../styles/customize_button_v2.xaml" />
                <ResourceDictionary Source="../../../styles/customize_image.xaml" />
                <ResourceDictionary Source="../../../styles/customize_textblock.xaml" />
                <ResourceDictionary Source="../../../styles/customize_datagrid.xaml"/>
                <ResourceDictionary Source="../../../styles/border_reseted.xaml" />
                <ResourceDictionary Source="../../../styles/customize_combobox.xaml" />
                <ResourceDictionary Source="../../../styles/customize_textbox.xaml" />
                <ResourceDictionary Source="../../../styles/customize_checkbox_v2.xaml" />
                <ResourceDictionary Source="../../../styles/customize_scrollviewer.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis" />
            <converters:TypeToImageConverter x:Key="TypeToImageConverter"/>
            <converters:IndexPlusOneConverter  x:Key="IndexPlusOneConverter"/>
            <converters:TrimConverter  x:Key="TrimConverter"/>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:PermissionVisibilityConverter x:Key="PermissionVisConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>
    <Border CornerRadius="15,2,2,2" Background="#111318" Margin="12,0,10,0">
        <DockPanel Margin="10" LastChildFill="True">

            <!-- Top header / Title / Toolbar -->
            <StackPanel DockPanel.Dock="Top">
                <DockPanel Margin="0,5,0,10">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <Icon:PackIconMaterial Kind="FolderAccount" Width="20" Height="20" Foreground="#4A9EFF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding WindowTitle}" FontWeight="Bold" FontSize="20" Foreground="#E8ECF1" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                        <!-- Refresh Button -->
                        <Button Command="{Binding RefreshCommand}" ToolTip="Làm mới" Margin="0,0,8,0"
                                Background="#2196F3" Foreground="White" Padding="8,4" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="3" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <StackPanel Orientation="Horizontal">
                                            <Icon:PackIconMaterial Kind="Refresh" Width="14" Height="14" Foreground="White" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBlock Text="Làm mới" Foreground="White" VerticalAlignment="Center" FontSize="12"/>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- Add Button -->
                        <Button Visibility="{Binding Converter={StaticResource PermissionVisConverter}, ConverterParameter='camera_group:create'}" 
                                Command="{Binding AddCommand}" ToolTip="Thêm mới nhóm đàm thoại"
                                Background="#4CAF50" Foreground="White" Padding="8,4" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="3" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <StackPanel Orientation="Horizontal">
                                            <Icon:PackIconMaterial Kind="Plus" Width="14" Height="14" Foreground="White" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBlock Text="Thêm mới" Foreground="White" VerticalAlignment="Center" FontSize="12"/>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </DockPanel>

                <!-- Search Box Row -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource CustomTextBoxStyle}"
                             Width="250" Margin="0,0,10,0"
                             Tag="🔍 tìm kiếm nhóm đàm thoại..."/>
                </StackPanel>
            </StackPanel>

            <!-- Bottom pagination bar -->
            <Grid DockPanel.Dock="Bottom">
                <Grid.RowDefinitions>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Height="0.8" Background="#252830" Margin="1">
                    <Border.Effect>
                        <DropShadowEffect Color="Black"
                      BlurRadius="4"
                      ShadowDepth="0"
                      Opacity="0.3"/>
                    </Border.Effect>
                </Border>
                <!--<Separator Margin="1" Background="#A49F94"  Height="0.8"/>-->
                <StackPanel Grid.Row="1"  Orientation="Horizontal" Height="28" VerticalAlignment="Center" HorizontalAlignment="Left"  Margin="2">

                    <!-- Previous Page Button -->
                    <Button Style="{StaticResource No_HandOver_Button}"  Command="{Binding PreviousPageCommand}" Background="Transparent"  Padding="0"  BorderThickness="0"  Width="16" Height="16">
                        <Image Source="/images/arrow_square_left.png" Style="{StaticResource ImageFull}" />
                    </Button>

                    <!-- Page Input -->
                    <!--<TextBox Width="18" Text="{Binding PageInput, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center"  HorizontalContentAlignment="Center"  Margin="5"  LostFocus="OnPageInputLostFocus" />-->
                    <TextBox Width="24"  Text="{Binding PageInput, UpdateSourceTrigger=PropertyChanged}" Background="#161920" Foreground="#E8ECF1" BorderBrush="#252830" BorderThickness="1" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Margin="5">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="LostFocus">
                                <i:InvokeCommandAction Command="{Binding PageInputLostFocusCommand}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </TextBox>
                    <!-- Total Pages -->
                    <TextBlock VerticalAlignment="Center" Margin="5" FontWeight="Bold" Foreground="#E8ECF1"> <Run Text="/ "/> <Run Text="{Binding TotalPages}" />
                    </TextBlock>

                    <!-- Next Page -->
                    <Button Style="{StaticResource No_HandOver_Button}" Command="{Binding NextPageCommand}" Background="Transparent" Padding="0" BorderThickness="0" Width="16" Height="16">
                        <Image Source="/images/arrows/arrow-square-right.png" Style="{StaticResource ImageFull}" />
                    </Button>
                    <!-- Total count -->
                    <TextBlock VerticalAlignment="Center" Margin="15,0,0,0" Foreground="#999" FontSize="12">
                        <Run Text="Tổng: "/>
                        <Run Text="{Binding TotalItems, Mode=OneWay}"/>
                        <Run Text=" nhóm"/>
                    </TextBlock>
                </StackPanel>
            </Grid>


            <!-- DataGrid will expand to fill remaining space -->
            <DataGrid ItemsSource="{Binding PagedItems}"
              SelectedItem="{Binding SelectedItem}"
              AutoGenerateColumns="False"
              CanUserAddRows="False"
                 
              SelectionMode="Single"
              IsReadOnly="True"
              ColumnWidth="auto">
                <DataGrid.Resources>
                    <ResourceDictionary Source="/styles/settings_base.xaml" />
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="30" />

                    <DataGridTextColumn Header="ID nhóm" Width="100">
                        <DataGridTextColumn.Binding>
                            <Binding Path="TalkId" Converter="{StaticResource TrimConverter}" />
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Tên nhóm" Binding="{Binding CameraGroup_Name}" Width="*" />
                    <DataGridTextColumn Header="Mô tả" Binding="{Binding Description}" Width="*" />
                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding Active}" Width="100" />
                    <DataGridTemplateColumn Header="Thao tác" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource gridEditButton}"
                                    Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Visibility="{Binding Converter={StaticResource PermissionVisConverter}, ConverterParameter='camera_group:edit'}">
                                        <Icon:PackIconMaterial Kind="PencilOutline" Style="{StaticResource gridButtonIcon}" />
                                    </Button>
                                    <Button Margin="5 0 0 0"
                                    Style="{StaticResource gridRemoveButton}"
                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Visibility="{Binding Converter={StaticResource PermissionVisConverter}, ConverterParameter='camera_group:delete'}">
                                        <Icon:PackIconMaterial Kind="DeleteOutline" Style="{StaticResource gridButtonIcon}" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Border>
</UserControl>
