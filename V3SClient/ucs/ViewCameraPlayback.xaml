<UserControl x:Class="V3SClient.ucs.ViewCameraPlayback"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
             xmlns:local="clr-namespace:V3SClient.ucs"
             xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
             d:DataContext="{d:DesignInstance Type=local:ViewCameraPlayback}"
             mc:Ignorable="d"
             d:DesignHeight="350"
             d:DesignWidth="511">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../styles/StyleCameraView.xaml" />
                <ResourceDictionary Source="../styles/border_reseted.xaml" />
                <ResourceDictionary Source="../styles/windowformhost.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <Border x:Name="DragOverlay" Style="{StaticResource Border_Reseted}"
            BorderThickness="{Binding Path=CameraWarning}"
            Background="Transparent"
            Margin="0"
            BorderBrush="OrangeRed"
            MouseEnter="Tile_MouseEnter"
            MouseLeave="Tile_MouseLeave"
            MouseLeftButtonDown="Tile_MouseLeftButtonDown" >
        <Grid Margin="0.3">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <!-- Video Panel-->
                <Border Style="{StaticResource Border_Reseted}"
                        IsHitTestVisible="False"
                        Background="#0D0F12">
                    <WindowsFormsHost x:Name="videoWindow"
                                      Panel.ZIndex="1"
                                      Background="{Binding ViewCamBackground}"
                                      Margin="0"
                                      IsHitTestVisible="False">
                        <wf:Panel x:Name="VideoPanel"
                                  Dock="Fill"
                                  AutoSizeMode="GrowAndShrink" />
                    </WindowsFormsHost>
                </Border>

                <!-- Playback has no HLS segments in the selected interval.  This is
                     a tile state, not a pipeline error, so no player is created. -->
                <Grid x:Name="NoPlaybackDataOverlay" Panel.ZIndex="8" Background="#FF0B1A2A" Visibility="Collapsed" IsHitTestVisible="False">
                    <!-- Do not give this state a fixed width: a narrow tile must not
                         be stretched or crop the message, and it must not influence
                         the video host's measured size. -->
                    <Border Width="560" MaxWidth="560" Margin="20" Padding="24,18" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Background="#FF0B1A2A" BorderBrush="#243E5B" BorderThickness="1" CornerRadius="6">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" Foreground="#FFF59E0B" FontSize="30" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="NoPlaybackDataText" Text="Không tìm thấy dữ liệu trong khoảng thời gian này" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,12,0,0" TextAlignment="Center" TextWrapping="NoWrap"/>
                            <TextBlock x:Name="NoPlaybackDataTimeText" Visibility="Collapsed" Foreground="#FF9DB4C8" FontSize="12" Margin="0,6,0,0" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- The playlist is being generated/validated. Keep this separate
                     from the no-data state so a transient HLS delay is never shown
                     to users as a permanent playback error. -->
                <Grid x:Name="PreparingPlaybackOverlay" Panel.ZIndex="9" Background="#FF0B1A2A" Visibility="Collapsed" IsHitTestVisible="False">
                    <Border Width="390" MaxWidth="390" Margin="20" Padding="24,18" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Background="#FF0B1A2A" BorderBrush="#243E5B" BorderThickness="1" CornerRadius="6">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="PreparingPlaybackIcon" Text="&#xE9F5;" FontFamily="Segoe MDL2 Assets" Foreground="#FF2F80FF" FontSize="27" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="PreparingPlaybackText" Text="Đang chuẩn bị dữ liệu..." Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,10,0,0" TextAlignment="Center" TextWrapping="NoWrap"/>
                            <TextBlock x:Name="PreparingPlaybackHint" Text="Vui lòng chờ đồng bộ dữ liệu phát lại" Foreground="#FF9DB4C8" FontSize="11" Margin="0,6,0,0" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Height="34" VerticalAlignment="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Left Top Overlay: Camera Name -->
                    <wfi:WindowsFormsHost x:Name="LeftOnTopWindow"
                                          Grid.Column="0"
                                           Panel.ZIndex="3"
                                           Style="{StaticResource ViewCameraOverlay_Transparent}"
                                          Margin="7,5,0,0" Height="28" HorizontalAlignment="Left">
                        <wfi:ElementHost>
                            <Border MouseDown="btnLive_MouseDown" Padding="7,4" Background="#FF10293D" BorderBrush="#FF294D6B" BorderThickness="1" CornerRadius="3">
                                <Button Foreground="White"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Margin="0"
                                        Click="btnPlayCamera_Click"
                                        x:Name="btnPlayTitle">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <Ellipse x:Name="CameraStatusDot" Width="7" Height="7" Fill="#22C55E" Margin="0,0,6,0" VerticalAlignment="Center" />
                                        <TextBlock x:Name="txtCameraName" Foreground="White" FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </Border>
                        </wfi:ElementHost>
                    </wfi:WindowsFormsHost>

                    <!-- Native host is required because the GStreamer video HWND paints
                         above ordinary WPF elements. Width/Height are enabled only for
                         the no-playback state after the host has loaded. -->
                    <wfi:WindowsFormsHost x:Name="NoPlaybackDataHost" Panel.ZIndex="20"
                                          Width="0" Height="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Style="{StaticResource ViewCameraOverlay_Transparent}">
                        <!-- Per-tile native overlay removed: the page owns playback actions. -->
                        <!--
                        <wfi:ElementHost>
                            <Border Width="360" Height="90" Padding="22,14" Background="#FF0B1A2A" BorderBrush="#243E5B" BorderThickness="1" CornerRadius="6">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="&#xEA39;" FontFamily="Segoe MDL2 Assets" Foreground="#FFEF4444" FontSize="28" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Không tìm thấy dữ liệu trong khoảng thời gian này" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,8,0,0" TextAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </wfi:ElementHost>
                        -->
                    </wfi:WindowsFormsHost>

                    <WindowsFormsHost Panel.ZIndex="4"
                                      Grid.Column="1"
                                      x:Name="RighOnTopWindow"
                                      Style="{StaticResource ViewCameraOverlay}"
                                      Margin="0,2,2,0" HorizontalAlignment="Right" Width="0" Height="0"
                                      IsHitTestVisible="False">
                        <!--
                        <wfi:ElementHost AutoSize="True" Dock="Fill">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" x:Name="btn_Speaker" Style="{StaticResource UCamera_Button}" Click="btn_Speaker_Click" ToolTip="Bật/tắt âm thanh" Padding="0">
                                    <Image x:Name="img_speaker" Source="/images/speaker_off.png" Stretch="UniformToFill" VerticalAlignment="Center" Margin="0" />
                                </Button>
                                <Button Grid.Column="1" x:Name="btn_Zoom" Style="{StaticResource UCamera_Button}" Click="btn_Zoom_Click" ToolTip="Phóng to/thu nhỏ" Padding="0">
                                    <Image x:Name="img_zoom" Source="/images/zoom_out.png" Stretch="UniformToFill" Margin="0" VerticalAlignment="Center" />
                                </Button>
                                <Button Grid.Column="2" x:Name="btn_Close" Style="{StaticResource UCamera_Button}" Click="btn_Exit_Click" ToolTip="Đóng camera" Padding="0">
                                    <Image x:Name="img_close" Source="/images/close.png" Stretch="UniformToFill" Margin="0" Width="18" Height="18" VerticalAlignment="Center" />
                                </Button>
                            </Grid>
                        </wfi:ElementHost>
                        -->
                    </WindowsFormsHost>
                </Grid>
                
                <wfi:WindowsFormsHost x:Name="NoPlaybackDataNativeHost" Panel.ZIndex="20"
                                      Width="0" Height="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Style="{StaticResource ViewCameraOverlay_Transparent}">
                    <!--
                    <wfi:ElementHost>
                        <Border Width="360" Height="90" Padding="22,14" Background="#FF0B1A2A" BorderBrush="#243E5B" BorderThickness="1" CornerRadius="6">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xEA39;" FontFamily="Segoe MDL2 Assets" Foreground="#FFEF4444" FontSize="28" HorizontalAlignment="Center"/>
                                <TextBlock Text="Không tìm thấy dữ liệu trong khoảng thời gian này" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,8,0,0" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </wfi:ElementHost>
                    -->
                </wfi:WindowsFormsHost>

                <!-- Hosted above the native GStreamer surface so the buttons are not
                     obscured by WindowsFormsHost airspace. -->
                <WindowsFormsHost x:Name="HoverActionsHost" Panel.ZIndex="10"
                                  VerticalAlignment="Bottom" HorizontalAlignment="Center"
                                  Visibility="Collapsed"
                                  Style="{StaticResource ViewCameraOverlay}"
                                  Margin="0,0,0,8" Width="275" Height="30">
                    <!-- The tile no longer hosts controls: VPlaybackHLS supplies one global toolbar. -->
                    <!--
                    <wfi:ElementHost AutoSize="True" Dock="Fill">
                        <Grid Background="#88000000">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="25" />
                                <ColumnDefinition Width="35" />
                                <ColumnDefinition Width="25" />
                                <ColumnDefinition Width="25" />
                                <ColumnDefinition Width="25" />
                                <ColumnDefinition Width="25" />
                                <ColumnDefinition Width="25" />
                                <ColumnDefinition Width="25" />
                                <ColumnDefinition Width="25" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" x:Name="btn_Slower" Style="{StaticResource UCamera_Button}" Click="btn_Slower_Click" ToolTip="Tua chậm" Padding="0">
                                <TextBlock Text="&#xEB9E;" FontFamily="Segoe MDL2 Assets" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Button>
                            <Button Grid.Column="1" x:Name="btn_PlayPause" Style="{StaticResource UCamera_Button}" Click="btn_PlayPause_Click" ToolTip="Phát/Tạm dừng" Padding="0">
                                <TextBlock x:Name="txtPlayPauseIcon" Text="&#xE768;" FontFamily="Segoe MDL2 Assets" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Button>
                            <Button Grid.Column="2" x:Name="btn_Faster" Style="{StaticResource UCamera_Button}" Click="btn_Faster_Click" ToolTip="Tua nhanh" Padding="0">
                                <TextBlock Text="&#xEB9D;" FontFamily="Segoe MDL2 Assets" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Button>
                            <TextBlock Grid.Column="3" x:Name="txtSpeed" Text="1x" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="10" Margin="2,0,5,0"/>
                            <Button Grid.Column="4" Style="{StaticResource UCamera_Button}" Click="btn_AiOverlay_Click" ToolTip="Bật/tắt AI" Padding="0">
                                <TextBlock Text="AI" Foreground="#4EA1FF" FontWeight="Bold" FontSize="9" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Button>
                            <Button Grid.Column="5" Style="{StaticResource UCamera_Button}" Click="btn_SnapshotCurrent_Click" ToolTip="Chụp ảnh camera này" Padding="0">
                                <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Button>
                            <Button Grid.Column="6" Style="{StaticResource UCamera_Button}" Click="btn_SnapshotAll_Click" ToolTip="Chụp ảnh tất cả camera" Padding="0">
                                <TextBlock Text="&#xE7F6;" FontFamily="Segoe MDL2 Assets" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Button>
                            <Button Grid.Column="7" Style="{StaticResource UCamera_Button}" Click="btn_DownloadCurrent_Click" ToolTip="Tải video camera này" Padding="0">
                                <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Button>
                            <Button Grid.Column="8" Style="{StaticResource UCamera_Button}" Click="btn_Zoom_Click" ToolTip="Phóng to/thu nhỏ" Padding="0">
                                <TextBlock Text="&#xE740;" FontFamily="Segoe MDL2 Assets" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Button>
                        </Grid>
                    </wfi:ElementHost>
                    -->
                </WindowsFormsHost>
                
            </Grid>
            
            <Grid Grid.Row="1" Height="{Binding TimelineHeight}" x:Name="TimelineArea" Margin="0,0,0,0"
                  Visibility="Visible"
                  Background="#111318">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="15" />
                </Grid.RowDefinitions>
                
                <!-- Interaction Canvas -->
                <Canvas Grid.Row="0" x:Name="canvasMiniTimeline" Background="Transparent" ClipToBounds="True"
                        MouseDown="canvasMiniTimeline_MouseDown"
                        MouseMove="canvasMiniTimeline_MouseMove"
                        MouseUp="canvasMiniTimeline_MouseUp"
                        SizeChanged="canvasMiniTimeline_SizeChanged">
                    <!-- Segments will be rendered here -->
                </Canvas>

                <!-- Selection Overlay Canvas -->
                <Canvas Grid.Row="0" IsHitTestVisible="False">
                    <!-- Playhead -->
                    <Rectangle x:Name="miniPlayhead" Width="2" Fill="#00D2FF" VerticalAlignment="Stretch" Height="{Binding TimelineHeight}">
                        <Rectangle.Effect>
                            <DropShadowEffect Color="#00D2FF" BlurRadius="4" ShadowDepth="0" />
                        </Rectangle.Effect>
                    </Rectangle>
                    <!-- Current time tooltip at playhead (overlay) -->
                    <Border x:Name="currentTimeBorder" Canvas.Top="8" Background="#CC000000" CornerRadius="2" Padding="10,1" Visibility="Collapsed">
                        <TextBlock x:Name="txtCurrentTime" Foreground="White" FontSize="10" />
                    </Border>
                </Canvas>

                <!-- Time Labels -->
                <Grid Grid.Row="1" Margin="2,0,2,0">
                    <TextBlock x:Name="txtTimeStart" Foreground="#AAAAAA" FontSize="10" HorizontalAlignment="Left" VerticalAlignment="Center" />
                    <TextBlock x:Name="txtTimeMiddle" Foreground="#AAAAAA" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <TextBlock x:Name="txtTimeEnd" Foreground="#AAAAAA" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center" />
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
