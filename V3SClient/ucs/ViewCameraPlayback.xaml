<UserControl x:Class="V3SClient.ucs.ViewCameraPlayback"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
             xmlns:local="clr-namespace:V3SClient.ucs"
             xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
             d:DataContext="{d:DesignInstance Type=local:ViewCameraPlayback}"
             mc:Ignorable="d"
             d:DesignHeight="350"
             d:DesignWidth="511">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../styles/StyleCameraView.xaml" />
                <ResourceDictionary Source="../styles/border_reseted.xaml" />
                <ResourceDictionary Source="../styles/windowformhost.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <Border x:Name="DragOverlay" Style="{StaticResource Border_Reseted}"
            BorderThickness="{Binding Path=CameraWarning}"
            Background="Transparent"
            Margin="0"
            BorderBrush="OrangeRed" >
        <Grid Margin="0.3">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <!-- Video Panel-->
                <Border Style="{StaticResource Border_Reseted}"
                        IsHitTestVisible="False"
                        Background="#0D0F12">
                    <WindowsFormsHost x:Name="videoWindow"
                                      Panel.ZIndex="1"
                                      Background="{Binding ViewCamBackground}"
                                      Margin="0"
                                      IsHitTestVisible="False">
                        <wf:Panel x:Name="VideoPanel"
                                  Dock="Fill"
                                  AutoSizeMode="GrowAndShrink" />
                    </WindowsFormsHost>
                </Border>

                <!-- Connect Button -->
                <wfi:WindowsFormsHost Panel.ZIndex="2"
                                      Background="Gray"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"
                                      Height="30"
                                      Width="70"
                                      x:Name="btnLive"
                                      Visibility="{Binding ShowConnectButton}">
                    <wfi:ElementHost AutoSize="True" Dock="Fill">
                        <Border Style="{StaticResource LiveButton}" CornerRadius="5" MouseDown="btnLive_MouseDown">
                            <TextBlock Text="Kết nối" x:Name="centerButton" Foreground="White" Style="{StaticResource General_TextBlock}" FontSize="12" />
                        </Border>
                    </wfi:ElementHost>
                </wfi:WindowsFormsHost>

                <Grid Height="25" VerticalAlignment="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Left Top Overlay: Camera Name -->
                    <wfi:WindowsFormsHost x:Name="LeftOnTopWindow"
                                          Grid.Column="0"
                                          Panel.ZIndex="3"
                                          Style="{StaticResource ViewCameraOverlay}"
                                          Margin="2,2,0,0" HorizontalAlignment="Left">
                        <wfi:ElementHost>
                            <Border MouseDown="btnLive_MouseDown" Padding="0">
                                <Button Foreground="White"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Margin="0"
                                        Click="btnPlayCamera_Click"
                                        x:Name="btnPlayTitle">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <TextBlock Text="&#xE768; " FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Left" FontSize="10" VerticalAlignment="Center" />
                                        <TextBlock x:Name="txtCameraName" Style="{StaticResource General_TextBlock}" />
                                    </StackPanel>
                                </Button>
                            </Border>
                        </wfi:ElementHost>
                    </wfi:WindowsFormsHost>

                    <WindowsFormsHost Panel.ZIndex="4"
                                      Grid.Column="1"
                                      x:Name="RighOnTopWindow"
                                      Style="{StaticResource ViewCameraOverlay}"
                                      Margin="0,2,2,0" HorizontalAlignment="Right" Width="90" Height="25">
                        <wfi:ElementHost AutoSize="True" Dock="Fill">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" x:Name="btn_Speaker" Style="{StaticResource UCamera_Button}" Click="btn_Speaker_Click" ToolTip="Bật/tắt âm thanh" Padding="0">
                                    <Image x:Name="img_speaker" Source="/images/speaker_off.png" Stretch="UniformToFill" VerticalAlignment="Center" Margin="0" />
                                </Button>
                                <Button Grid.Column="1" x:Name="btn_Zoom" Style="{StaticResource UCamera_Button}" Click="btn_Zoom_Click" ToolTip="Phóng to/thu nhỏ" Padding="0">
                                    <Image x:Name="img_zoom" Source="/images/zoom_out.png" Stretch="UniformToFill" Margin="0" VerticalAlignment="Center" />
                                </Button>
                                <Button Grid.Column="2" x:Name="btn_Close" Style="{StaticResource UCamera_Button}" Click="btn_Exit_Click" ToolTip="Đóng camera" Padding="0">
                                    <Image x:Name="img_close" Source="/images/close.png" Stretch="UniformToFill" Margin="0" Width="18" Height="18" VerticalAlignment="Center" />
                                </Button>
                            </Grid>
                        </wfi:ElementHost>
                    </WindowsFormsHost>
                </Grid>
                
                <!-- Playback Speed Controls Overlay (Bottom Right of Video) -->
                <WindowsFormsHost Panel.ZIndex="4"
                                  VerticalAlignment="Bottom" HorizontalAlignment="Right"
                                  Style="{StaticResource ViewCameraOverlay}"
                                  Margin="0,0,2,2" Width="120" Height="25">
                    <wfi:ElementHost AutoSize="True" Dock="Fill">
                        <Grid Background="#88000000">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="25" />
                                <ColumnDefinition Width="35" />
                                <ColumnDefinition Width="25" />
                                <ColumnDefinition Width="25" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" x:Name="btn_Slower" Style="{StaticResource UCamera_Button}" Click="btn_Slower_Click" ToolTip="Tua chậm" Padding="0">
                                <TextBlock Text="&#xEB9E;" FontFamily="Segoe MDL2 Assets" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Button>
                            <Button Grid.Column="1" x:Name="btn_PlayPause" Style="{StaticResource UCamera_Button}" Click="btn_PlayPause_Click" ToolTip="Phát/Tạm dừng" Padding="0">
                                <TextBlock x:Name="txtPlayPauseIcon" Text="&#xE768;" FontFamily="Segoe MDL2 Assets" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Button>
                            <Button Grid.Column="2" x:Name="btn_Faster" Style="{StaticResource UCamera_Button}" Click="btn_Faster_Click" ToolTip="Tua nhanh" Padding="0">
                                <TextBlock Text="&#xEB9D;" FontFamily="Segoe MDL2 Assets" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Button>
                            <TextBlock Grid.Column="3" x:Name="txtSpeed" Text="1x" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="10" Margin="2,0,5,0"/>
                        </Grid>
                    </wfi:ElementHost>
                </WindowsFormsHost>
                
            </Grid>
            
            <Grid Grid.Row="1" Height="{Binding TimelineHeight}" x:Name="TimelineArea" Margin="0,0,0,0"
                  Visibility="Visible"
                  Background="#111318">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="15" />
                </Grid.RowDefinitions>
                
                <!-- Interaction Canvas -->
                <Canvas Grid.Row="0" x:Name="canvasMiniTimeline" Background="Transparent" ClipToBounds="True"
                        MouseDown="canvasMiniTimeline_MouseDown"
                        MouseMove="canvasMiniTimeline_MouseMove"
                        MouseUp="canvasMiniTimeline_MouseUp"
                        SizeChanged="canvasMiniTimeline_SizeChanged">
                    <!-- Segments will be rendered here -->
                </Canvas>

                <!-- Selection Overlay Canvas -->
                <Canvas Grid.Row="0" IsHitTestVisible="False">
                    <!-- Playhead -->
                    <Rectangle x:Name="miniPlayhead" Width="2" Fill="#00D2FF" VerticalAlignment="Stretch" Height="{Binding TimelineHeight}">
                        <Rectangle.Effect>
                            <DropShadowEffect Color="#00D2FF" BlurRadius="4" ShadowDepth="0" />
                        </Rectangle.Effect>
                    </Rectangle>
                    <!-- Current time tooltip at playhead (overlay) -->
                    <Border x:Name="currentTimeBorder" Canvas.Top="8" Background="#CC000000" CornerRadius="2" Padding="10,1" Visibility="Collapsed">
                        <TextBlock x:Name="txtCurrentTime" Foreground="White" FontSize="10" />
                    </Border>
                </Canvas>

                <!-- Time Labels -->
                <Grid Grid.Row="1" Margin="2,0,2,0">
                    <TextBlock x:Name="txtTimeStart" Foreground="#AAAAAA" FontSize="10" HorizontalAlignment="Left" VerticalAlignment="Center" />
                    <TextBlock x:Name="txtTimeMiddle" Foreground="#AAAAAA" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <TextBlock x:Name="txtTimeEnd" Foreground="#AAAAAA" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center" />
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
