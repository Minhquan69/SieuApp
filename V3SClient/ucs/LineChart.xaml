<UserControl x:Class="V3SClient.ucs.LineChart" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:V3SClient.ucs" xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf" mc:Ignorable="d">
    <UserControl.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries><ResourceDictionary Source="/styles/line_chart_styles.xaml" /></ResourceDictionary.MergedDictionaries>
        
    </ResourceDictionary></UserControl.Resources>

    <Grid>
        <lvc:CartesianChart Grid.Row="1" Margin="10" LegendLocation="None">
            <lvc:CartesianChart.DataTooltip>
                <lvc:DefaultTooltip Background="Transparent" Foreground="Transparent" BulletSize="10" Opacity="0.7" ShowSeries="False" ShowTitle="False" />
            </lvc:CartesianChart.DataTooltip>
            <lvc:CartesianChart.Series>
                <lvc:LineSeries Values="{Binding ChartValues}" />
            </lvc:CartesianChart.Series>

            <lvc:CartesianChart.AxisX>
                <lvc:Axis Foreground="#464a63" ShowLabels="False" LabelFormatter="{Binding DateTimeFormatter}" MaxValue="{Binding AxisXMax}" MinValue="{Binding AxisXMin}" Unit="{Binding AxisXUnit}">
                    <lvc:Axis.Separator>
                        <lvc:Separator StrokeThickness="0" Stroke="#2c3a54" Step="{Binding AxisXStep}" />
                    </lvc:Axis.Separator>
                </lvc:Axis>
            </lvc:CartesianChart.AxisX>

            <lvc:CartesianChart.AxisY>
                <lvc:Axis Foreground="WhiteSmoke" ShowLabels="True" MinValue="{Binding AxisYMin}" MaxValue="{Binding AxisYMax}" FontSize="8" FontFamily="Kanit">
                    <lvc:Axis.Separator>
                        <lvc:Separator StrokeThickness="0" Stroke="#2c3a54" />
                    </lvc:Axis.Separator>
                </lvc:Axis>
            </lvc:CartesianChart.AxisY>
        </lvc:CartesianChart>
    </Grid>
</UserControl>



















