<UserControl x:Class="V3SClient.ucs.VehicleCaptureResultControl" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:V3SClient.ucs" xmlns:models="clr-namespace:V3SClient.models" xmlns:converters="clr-namespace:V3SClient.UI.Converters" mc:Ignorable="d" d:DesignHeight="180" d:DesignWidth="620" Background="#0D0F12">
             
    <UserControl.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries><ResourceDictionary Source="/styles/vehicle_capture_result_control_styles.xaml" /></ResourceDictionary.MergedDictionaries>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
        
    </ResourceDictionary></UserControl.Resources>
    
    <Grid>
        <!-- Carousel ảnh ngang: Biển số -> Trước -> Sau -> các ảnh bổ sung -->
        <Grid Margin="4,3">
            <ScrollViewer x:Name="ImageScrollViewer" Margin="8,0" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" CanContentScroll="False" PanningMode="HorizontalOnly" ScrollChanged="ImageScrollViewer_ScrollChanged" PreviewMouseWheel="ImageScrollViewer_PreviewMouseWheel">
                <ItemsControl ItemsSource="{Binding Images}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <local:VehicleCaptureSlotControl Width="118" Height="105" Margin="3" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Button x:Name="PreviousButton" Content="❮" Style="{StaticResource VehicleCaptureResultControlCarouselArrowButtonStyle}" HorizontalAlignment="Left" VerticalAlignment="Center" ToolTip="Xem ảnh phía trước" Click="PreviousImages_Click" />

            <Button x:Name="NextButton" Content="❯" Style="{StaticResource VehicleCaptureResultControlCarouselArrowButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" ToolTip="Xem ảnh tiếp theo" Click="NextImages_Click" />
        </Grid>
    </Grid>
</UserControl>
