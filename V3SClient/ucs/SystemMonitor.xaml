<UserControl x:Class="V3SClient.ucs.SystemMonitor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:V3SClient.ucs"
             xmlns:linechart="clr-namespace:V3SClient.ucs"
             mc:Ignorable="d"
             d:DesignHeight="340"
             d:DesignWidth="300">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../styles/customize_system_monitor.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid MouseRightButtonUp="Grid_RightClick"
          Background="#202020"
          > 
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <!--CPU & Ram-->
        <Border Style="{StaticResource mainBorder}"
                Grid.Row="0"
                Grid.Column="0"
                Margin="2 5 2 0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="9*" />
                    <RowDefinition Height="2*" />
                </Grid.RowDefinitions>
                <!--CPU -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="20" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="CPU"
                               Style="{StaticResource titleText}"
                               />
                    <ProgressBar x:Name="cpuProgressBar"
                                 Grid.Column="1"
                                 Grid.ColumnSpan="2"
                                 Style="{DynamicResource ProgressBarStyle}"
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Center"
                                 Width="60"
                                 Height="6"
                                 Minimum="0"
                                 Maximum="100" />
                    <Grid Grid.Column="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Label Name="cpuLabel"
                               Grid.Column="0"
                               Foreground="#fcfafa"
                               FontSize="8"
                               FontWeight="SemiBold"
                               VerticalContentAlignment="Center"
                               Padding="0"
                               ContentStringFormat="{}{0:F1}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               HorizontalContentAlignment="Right" />
                        <TextBlock Text="%"
                                   Grid.Column="1"
                                   Style="{StaticResource titleText}"
                                   FontSize="8"
                                   HorizontalAlignment="Right" />
                    </Grid>
                    <Separator Grid.Row="0"
                               Grid.ColumnSpan="4"
                               VerticalAlignment="Bottom"
                               Margin="5 0 5 0"
                               BorderBrush="YellowGreen"
                               BorderThickness="0.8" />
                    
                    <linechart:LineChart x:Name="cpuChart"
                                         Grid.Row="1"
                                         Grid.ColumnSpan="4"
                                         Margin="5" 
                                         Foreground="WhiteSmoke"
                                         FontSize="6"
                                         
                                         />
                    
                    <Separator Grid.Row="1"
                               Grid.ColumnSpan="4"
                               VerticalAlignment="Bottom"
                               Margin="5 0 5 0"
                               BorderBrush="#464a63"
                               BorderThickness="0.8" />
                </Grid>

                <!--RAM -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="RAM"
                               Style="{StaticResource titleText}"
                             />
                    <ProgressBar x:Name="ramProgressBar"
                                 Grid.Column="1"
                                 Grid.ColumnSpan="2"
                                 Style="{DynamicResource ProgressBarStyle}"
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Center"
                                 Width="60"
                                 Height="6"
                                 Minimum="0"
                                 Maximum="100" />
                    <Grid Grid.Column="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Label Name="ramLabel"
                               Grid.Column="0"
                               Foreground="#fcfafa"
                               FontSize="8"
                               FontWeight="SemiBold"
                               VerticalContentAlignment="Center"
                               Padding="0"
                               ContentStringFormat="{}{0:F1}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               HorizontalContentAlignment="Right" />
                        <TextBlock Text="%"
                                   Grid.Column="1"
                                   Style="{StaticResource titleText}"
                                   FontSize="8"
                                   HorizontalAlignment="Right" />
                    </Grid>
                </Grid>
            </Grid>


        </Border>

        <!--GPU & VRam-->
        <Border Style="{StaticResource mainBorder}"
                Grid.Row="0"
                Grid.Column="1"
                Margin="2 5 2 0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="9*" />
                    <RowDefinition Height="2*" />
                </Grid.RowDefinitions>
                <!--CPU -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="20" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="GPU"
                               Style="{StaticResource titleText}"                               
                              />
                    <ProgressBar x:Name="gpuProgressBar"
                                 Grid.Column="1"
                                 Grid.ColumnSpan="2"
                                 Style="{DynamicResource ProgressBarStyle}"
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Center"
                                 Width="60"
                                 Height="6"
                                 Minimum="0"
                                 Maximum="100" />
                    <Grid Grid.Column="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Label Name="gpuLabel"
                               Grid.Column="0"
                               Foreground="#fcfafa"
                               FontSize="8"
                               FontWeight="SemiBold"
                               VerticalContentAlignment="Center"
                               Padding="0"
                               ContentStringFormat="{}{0:F1}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               HorizontalContentAlignment="Right" />
                        <TextBlock Text="%"
                                   Grid.Column="1"
                                   Style="{StaticResource titleText}"
                                   FontSize="8"
                                   HorizontalAlignment="Right" />
                    </Grid>
                    <Separator Grid.Row="0"
                               Grid.ColumnSpan="4"
                               VerticalAlignment="Bottom"
                               Margin="5 0 5 0"
                               BorderBrush="YellowGreen"
                               BorderThickness="0.8" />
                    <linechart:LineChart x:Name="gpuChart"
                                         Grid.Row="1"
                                         Grid.ColumnSpan="4"
                                         Margin="5 5 5 5" />
                    <Separator Grid.Row="1"
                               Grid.ColumnSpan="4"
                               VerticalAlignment="Bottom"
                               Margin="5 0 5 0"
                               BorderBrush="#464a63"
                               BorderThickness="0.8" />
                </Grid>

                <!--VRAM -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="VRAM  "
                               Style="{StaticResource titleText}"
                              
                                />
                    <ProgressBar x:Name="vramProgressBar"
                                 Grid.Column="1"
                                 Grid.ColumnSpan="2"
                                 Style="{DynamicResource ProgressBarStyle}"
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Center"
                                 Width="60"
                                 Height="6"
                                 Minimum="0"
                                 Maximum="100" />
                    <Grid Grid.Column="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Label Name="vramLabel"
                               Grid.Column="0"
                               Foreground="#fcfafa"
                               FontSize="8"
                               FontWeight="SemiBold"
                               VerticalContentAlignment="Center"
                               Padding="0"
                               ContentStringFormat="{}{0:F1}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               HorizontalContentAlignment="Right" />

                        <TextBlock Text="%"
                                   Grid.Column="1"
                                  Style="{StaticResource titleText}"
                                   FontSize="8"
                                   HorizontalAlignment="Right" />
                    </Grid>
                </Grid>
            </Grid>
        </Border>
        <!--Network-->
        <Border Style="{StaticResource mainBorder}"
                Grid.Row="1"
                Grid.Column="0"
                Margin="2 5 2 0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="15" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="NETWORK"
                           Style="{StaticResource titleText}"
                           HorizontalAlignment="Left"
                            />
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0"
                          Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Sent"
                                   Grid.Row="0"
                                   Style="{StaticResource titleText}"      
                                   HorizontalAlignment="Left"
                                   FontSize="8" />
                        <Label x:Name="networkSentBytesLabel"
                               Grid.Row="1"
                               VerticalContentAlignment="Center"
                                Foreground="WhiteSmoke"
                               Padding="0"
                               ContentStringFormat="{}{0:F1}"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               HorizontalContentAlignment="Left"
                               Margin="10 0 0 0" />
                        <TextBlock Text="Mb/s"
                                   Grid.Row="2"
                                   Foreground="#fcfafa"
                                   FontSize="8"
                                   Margin="20 1 1 10"
                                   VerticalAlignment="Center"
                                 
                                   HorizontalAlignment="Center" />
                    </Grid>
                    <linechart:LineChart x:Name="networkSentChart"
                                         Grid.Row="0"
                                         Grid.Column="1"
                                         Margin="5" 
                                        
                                         />
                    <Separator Grid.Row="0"
                               Grid.ColumnSpan="2"
                               VerticalAlignment="Bottom"
                               Margin="5 0 5 0"
                               BorderBrush="#464a63"
                               BorderThickness="0.8" />
                    <Grid Grid.Row="1"
                          Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Received"
                                   Grid.Row="0"
                                  Style="{StaticResource titleText}"
                                   FontSize="8"
                                   Margin="1 10 1 1"
                                   VerticalAlignment="Center"                                 
                                   HorizontalAlignment="Left" />
                        <Label x:Name="networkReceivedBytesLabel"
                               Grid.Row="1"
                               Foreground="WhiteSmoke"
                               FontSize="12"
                              
                               VerticalContentAlignment="Center"
                               Padding="0"
                               ContentStringFormat="{}{0:F1}"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               HorizontalContentAlignment="Left"
                               Margin="10 0 0 0" />
                        <TextBlock Text="Mb/s"
                                   Grid.Row="2"
                                   Style="{StaticResource titleText}"                                  
                                   FontSize="8"
                                   Margin="20 1 1 16"
                                   VerticalAlignment="Center"                                  
                                   HorizontalAlignment="Center" />
                    </Grid>
                    <linechart:LineChart x:Name="networkReceivedChart"
                                         Grid.Row="1"
                                         Grid.Column="1"
                                         Margin="0,5,5,5"
                                         FontFamily="Microsoft YaHei Light"
                                         FontSize="11" />

                </Grid>
            </Grid>

        </Border>
        <!--DISK-->
        <Border Style="{StaticResource mainBorder}"
                Grid.Row="1"
                Grid.Column="1"
                Margin="2 5 2 0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="15" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="DISK"
                           Style="{StaticResource titleText}"
                          
                           HorizontalAlignment="Left" />
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*" />
                        <RowDefinition Height="1*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Total"
                                   Grid.ColumnSpan="2"
                                   Style="{StaticResource titleText}"
                                   Margin="5 0 0 0"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left"
                                   FontSize="8" />
                        <Grid Grid.Row="0" Grid.ColumnSpan="2"
                              Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Used"
                                       Grid.Column="0"
                                       Style="{StaticResource titleText}"
                                       FontSize="8"
                                       
                                       />
                            <Label x:Name="totalDiskUsedLabel"
                                   Grid.Column="1"
                                   Content="12"
                                   Foreground="WhiteSmoke"
                                   FontFamily="Kanit"
                                   FontSize="10"
                                   VerticalContentAlignment="Center"
                                   Padding="0"
                                   ContentStringFormat="{}{0:F1}"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   HorizontalContentAlignment="Left"
                                   Margin="3 0 0 0" />
                            <TextBlock Text="GB"
                                       Grid.Column="2"
                                      Style="{StaticResource titleText}"
                                       FontSize="6"
                                       Margin="1"
                                       VerticalAlignment="Center"                                       
                                       HorizontalAlignment="Center" />
                        </Grid>
                        <Grid Grid.Row="1" Grid.ColumnSpan="2"
                              Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Free"
                                       Grid.Column="0"
                                       Style="{StaticResource titleText}"                                      
                                       Margin="1"
                                       FontSize="8"
                                      
                                       />
                            <Label x:Name="totalDiskFreeLabel"
                                   Grid.Column="1"
                                   Content="12"
                                   Foreground="WhiteSmoke"
                                   FontFamily="Kanit"
                                   FontSize="10"                                   
                                   VerticalContentAlignment="Center"
                                   Padding="0"
                                   ContentStringFormat="{}{0:F1}"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   HorizontalContentAlignment="Left"
                                   Margin="3 0 0 0" />
                            <TextBlock Text="GB"
                                       Grid.Column="2"
                                      Style="{StaticResource titleText}"
                                       FontSize="6"
                                       Margin="1"
                                        />

                        </Grid>
                    </Grid>
                    <Separator Grid.Row="0"
                               Grid.ColumnSpan="2"
                               VerticalAlignment="Bottom"
                               Margin="5 0 5 0"
                               BorderBrush="#464a63"
                               BorderThickness="0.8" />
                    <!--<StackPanel x:Name="StackPanelContainer" Grid.Row="1" MinHeight="50" MinWidth="50" Orientation="Horizontal" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"/>-->
                    <ContentControl  x:Name="GaugeContainer"
                                     Grid.Row="1"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch" />
                </Grid>

            </Grid>
        </Border>
    </Grid>
</UserControl>




















