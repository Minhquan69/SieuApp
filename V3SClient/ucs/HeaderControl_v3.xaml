<UserControl x:Class="V3SClient.ucs.HeaderControl_v3"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Height="48">
    <Grid Background="{StaticResource VmsHeaderBrush_v3}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
            <Border Width="30" Height="30" Background="{StaticResource VmsPrimarySofterBrush_v3}"
                    BorderBrush="{StaticResource VmsPrimaryBorderBrush_v3}" BorderThickness="1" CornerRadius="7" Margin="0,0,10,0">
                <Icon:PackIconMaterial Kind="{Binding SelectedNavigationItem.IconKind}" Width="16" Height="16"
                                       Foreground="{StaticResource VmsFocusBrush_v3}" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="{Binding PageTitle}" Foreground="{StaticResource VmsTextPrimaryBrush_v3}"
                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
        </StackPanel>

        <Grid x:Name="AccountPopupAnchor" Grid.Column="1" Margin="0,0,10,0" HorizontalAlignment="Right">
            <Button x:Name="AccountButton" Click="AccountButton_Click" Background="Transparent" BorderThickness="0"
                    Cursor="Hand" Padding="4,0" HorizontalAlignment="Right" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <Border Width="28" Height="28" CornerRadius="14" Background="{StaticResource VmsPrimarySofterBrush_v3}">
                        <TextBlock Text="{Binding UserInitials}" Foreground="{StaticResource VmsFocusBrush_v3}" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="8,0,0,0">
                        <TextBlock Text="{Binding Username}" Foreground="{StaticResource VmsTextPrimaryBrush_v3}" FontSize="12" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SelectedProfileName}" Foreground="{StaticResource VmsTextSecondaryBrush_v3}" FontSize="10" />
                    </StackPanel>
                </StackPanel>
            </Button>
        </Grid>

        <Border Grid.ColumnSpan="2" VerticalAlignment="Bottom" Height="1" Background="{StaticResource VmsBorderBrush_v3}" />
        <Popup x:Name="AccountPopup" Placement="Bottom" PlacementTarget="{Binding ElementName=AccountPopupAnchor}"
               VerticalOffset="1" StaysOpen="False" AllowsTransparency="True">
            <Border Width="208" Background="{StaticResource VmsElevatedBrush_v3}" BorderBrush="{StaticResource VmsBorderBrush_v3}"
                    BorderThickness="1" CornerRadius="8" Padding="0,2">
                <StackPanel>
                    <Grid Height="36">
                        <TextBlock Text="Tài khoản" Padding="12,0" VerticalAlignment="Center"
                                   Foreground="{StaticResource VmsTextPrimaryBrush_v3}" FontWeight="SemiBold" />
                    </Grid>
                    <Border Height="1" Background="{StaticResource VmsBorderBrush_v3}" />
                    <Button Click="SwitchClient_Click" Style="{StaticResource VmsAccountMenuItem_v3}">
                        <StackPanel Orientation="Horizontal">
                            <Icon:PackIconMaterial Kind="AccessPoint" Width="16" Height="16" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="0,0,12,0" />
                            <TextBlock Text="Đổi client" VerticalAlignment="Center" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                        </StackPanel>
                    </Button>
                    <Button Click="Logout_Click" Style="{StaticResource VmsAccountMenuItem_v3}">
                        <StackPanel Orientation="Horizontal">
                            <Icon:PackIconMaterial Kind="Logout" Width="16" Height="16" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="0,0,12,0" />
                            <TextBlock Text="Đăng xuất" VerticalAlignment="Center" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
