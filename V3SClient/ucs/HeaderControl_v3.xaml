<UserControl x:Class="V3SClient.ucs.HeaderControl_v3" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
 <Border Background="{StaticResource VmsHeaderBrush_v3}" BorderBrush="{StaticResource VmsBorderBrush_v3}" BorderThickness="0,0,0,1" Padding="18,0"><Grid Height="48"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel Orientation="Horizontal" VerticalAlignment="Center"><TextBlock Text="{Binding PageTitle}" Foreground="{StaticResource VmsTextPrimaryBrush_v3}" FontSize="15" FontWeight="SemiBold"/><TextBlock Text=" · " Foreground="{StaticResource VmsTextTertiaryBrush_v3}"/><TextBlock Text="{Binding SelectedProfileName}" Foreground="{StaticResource VmsTextSecondaryBrush_v3}"/></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"><TextBlock Text="{Binding Username}" Foreground="{StaticResource VmsTextPrimaryBrush_v3}"/><TextBlock Text="  |  " Foreground="{StaticResource VmsTextTertiaryBrush_v3}"/><TextBlock Text="{Binding ServerTime, StringFormat={}{0:dd/MM/yyyy HH:mm:ss}}" Foreground="{StaticResource VmsTextSecondaryBrush_v3}"/></StackPanel></Grid></Border>
</UserControl>
