<UserControl x:Class="V3SClient.ucs.SidebarControl_v3" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
 <Border Background="{StaticResource VmsSidebarBrush_v3}" BorderBrush="{StaticResource VmsBorderBrush_v3}" BorderThickness="0,0,1,0">
  <Grid><Grid.Style><Style TargetType="{x:Type Grid}"><Setter Property="Width" Value="208"/><Style.Triggers><DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True"><Setter Property="Width" Value="64"/></DataTrigger></Style.Triggers></Style></Grid.Style><Grid.RowDefinitions><RowDefinition Height="68"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
   <StackPanel Grid.Row="0" Margin="16,14"><TextBlock Text="iVista" Foreground="{StaticResource VmsTextPrimaryBrush_v3}" FontSize="20" FontWeight="SemiBold"/><TextBlock Text="Enterprise VMS" Foreground="{StaticResource VmsPrimaryBrush_v3}" FontSize="10"/></StackPanel>
   <ListBox Grid.Row="1" ItemsSource="{Binding NavigationItems}" SelectedItem="{Binding SelectedNavigationItem}" BorderThickness="0" Background="Transparent" Margin="8"><ListBox.ItemTemplate><DataTemplate><Button Command="{Binding DataContext.SelectNavigationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch" Padding="8"><StackPanel Orientation="Horizontal"><TextBlock Text="{Binding Glyph}" Foreground="{StaticResource VmsPrimaryBrush_v3}" Width="24"/><TextBlock Text="{Binding Title}" Foreground="{StaticResource VmsTextPrimaryBrush_v3}"/></StackPanel></Button></DataTemplate></ListBox.ItemTemplate></ListBox>
   <Button Grid.Row="2" Content="Collapse" Command="{Binding ToggleSidebarCommand}" Style="{StaticResource SecondaryButtonStyle_v3}" Margin="10"/>
  </Grid>
 </Border>
</UserControl>
