<UserControl x:Class="V3SClient.ucs.SidebarControl_v3" x:Name="Root" Width="176" ClipToBounds="True"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks">
 <Border Background="{StaticResource VmsSidebarBrush_v3}" BorderBrush="{StaticResource VmsBorderBrush_v3}" BorderThickness="0,0,1,0">
  <Border.Resources>
   <SolidColorBrush x:Key="SidebarHoverBrush_v3" Color="#1A2563EB"/>
   <SolidColorBrush x:Key="SidebarSelectedBrush_v3" Color="#332563EB"/>
  </Border.Resources>
  <Grid>
   <Grid.RowDefinitions><RowDefinition Height="48"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
   <Border Grid.Row="0" BorderBrush="{StaticResource VmsBorderBrush_v3}" BorderThickness="0,0,0,1">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
     <Image x:Name="LogoImage" Source="/images/logo/ivista_logo.png" Width="112" Height="30" Stretch="Uniform" HorizontalAlignment="Center"/>
     <TextBlock x:Name="LogoSubtext" Text="Enterprise VMS" Foreground="{StaticResource VmsPrimaryBrush_v3}" FontSize="9" HorizontalAlignment="Center"/>
     <Border x:Name="CollapsedLogo" Width="28" Height="25" ClipToBounds="True" HorizontalAlignment="Center" Visibility="Collapsed">
      <Image Source="/images/logo/ivista_logo.png" Width="105" Height="34" Stretch="Fill" HorizontalAlignment="Left" VerticalAlignment="Center"/>
     </Border>
     <TextBlock x:Name="CollapsedLogoSubtext" Text="VMS" Foreground="{StaticResource VmsPrimaryBrush_v3}" FontSize="8" HorizontalAlignment="Center" Visibility="Collapsed"/>
    </StackPanel>
   </Border>
   <ListBox Grid.Row="1" ItemsSource="{Binding NavigationItems}" SelectedItem="{Binding SelectedNavigationItem, Mode=OneWay}" BorderThickness="0" Background="Transparent" Padding="8,12" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
    <ListBox.ItemContainerStyle>
     <Style TargetType="ListBoxItem"><Setter Property="Padding" Value="0"/><Setter Property="Margin" Value="0"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="ToolTip" Value="{Binding Title}"/><Setter Property="FocusVisualStyle" Value="{x:Null}"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ListBoxItem"><Border Background="Transparent" BorderBrush="Transparent" BorderThickness="0"><ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/></Border></ControlTemplate></Setter.Value></Setter></Style>
    </ListBox.ItemContainerStyle>
    <ListBox.ItemTemplate><DataTemplate>
     <Button Command="{Binding DataContext.SelectNavigationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" ToolTip="{Binding Title}" Cursor="Hand" FocusVisualStyle="{x:Null}" Height="42" Padding="0" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
      <Border x:Name="ItemBorder" CornerRadius="6" Padding="8,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"><Border.Style><Style TargetType="Border"><Setter Property="Background" Value="Transparent"/><Style.Triggers><DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True"><Setter Property="Background" Value="{StaticResource SidebarSelectedBrush_v3}"/></DataTrigger></Style.Triggers></Style></Border.Style>
       <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="2"/><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
        <Border x:Name="ActiveBar" Grid.Column="0" Width="3" Height="22" VerticalAlignment="Center" Background="{StaticResource VmsPrimaryBrush_v3}" CornerRadius="2"><Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed"/><Setter Property="Opacity" Value="0"/><Style.Triggers><DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True"><Setter Property="Visibility" Value="Visible"/><DataTrigger.EnterActions><BeginStoryboard><Storyboard><DoubleAnimation Duration="0:0:0.18" To="1" Storyboard.TargetProperty="Opacity"/></Storyboard></BeginStoryboard></DataTrigger.EnterActions><DataTrigger.ExitActions><BeginStoryboard><Storyboard><DoubleAnimation Duration="0:0:0.15" To="0" Storyboard.TargetProperty="Opacity"/></Storyboard></BeginStoryboard></DataTrigger.ExitActions></DataTrigger></Style.Triggers></Style></Border.Style></Border>
        <Icon:PackIconMaterial x:Name="ItemIcon" Grid.Column="1" Kind="{Binding IconKind}" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"><Icon:PackIconMaterial.Style><Style TargetType="Icon:PackIconMaterial"><Setter Property="Foreground" Value="{StaticResource VmsTextSecondaryBrush_v3}"/><Style.Triggers><DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=IsMouseOver}" Value="True"><Setter Property="Foreground" Value="#60A5FA"/></DataTrigger><DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True"><Setter Property="Foreground" Value="#3B82F6"/></DataTrigger></Style.Triggers></Style></Icon:PackIconMaterial.Style></Icon:PackIconMaterial>
        <TextBlock x:Name="ItemText" Grid.Column="2" Text="{Binding Title}" VerticalAlignment="Center" FontSize="12"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="{StaticResource VmsTextSecondaryBrush_v3}"/><Setter Property="FontWeight" Value="Normal"/><Style.Triggers><DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=IsMouseOver}" Value="True"><Setter Property="Foreground" Value="#60A5FA"/></DataTrigger><DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True"><Setter Property="Foreground" Value="#3B82F6"/><Setter Property="FontWeight" Value="SemiBold"/></DataTrigger><DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=IsCollapsed}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
        <Border x:Name="Badge" Grid.Column="3" Background="{StaticResource VmsErrorBrush_v3}" CornerRadius="8" Padding="5,1" Margin="4,0,0,0"><Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding HasBadge}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger><DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=IsCollapsed}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></Border.Style><TextBlock Text="{Binding BadgeText}" Foreground="White" FontSize="9"/></Border>
       </Grid>
      </Border>
      <Button.Style><Style TargetType="Button"><Setter Property="Background" Value="Transparent"/><Setter Property="BorderBrush" Value="Transparent"/><Setter Property="OverridesDefaultStyle" Value="True"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" BorderBrush="Transparent" BorderThickness="0" CornerRadius="6"><ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/></Border></ControlTemplate></Setter.Value></Setter><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{StaticResource SidebarHoverBrush_v3}"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter Property="Background" Value="{StaticResource SidebarSelectedBrush_v3}"/></Trigger></Style.Triggers></Style></Button.Style>
     </Button>
    </DataTemplate></ListBox.ItemTemplate>
   </ListBox>
   <Border Grid.Row="2" BorderBrush="{StaticResource VmsBorderBrush_v3}" BorderThickness="0,1,0,0" Padding="10,8,10,10">
    <StackPanel>
     <StackPanel x:Name="ExpandedFooter">
      <StackPanel Orientation="Horizontal"><Ellipse Width="8" Height="8" Fill="{StaticResource VmsSuccessBrush_v3}" Margin="0,0,7,0" VerticalAlignment="Center"/><TextBlock Text="Hoạt động bình thường" Foreground="{StaticResource VmsTextSecondaryBrush_v3}" FontSize="10"/></StackPanel>
      <StackPanel Orientation="Horizontal" Margin="0,8,0,0"><Icon:PackIconMaterial Kind="ClockOutline" Width="14" Height="14" Foreground="{StaticResource VmsTextTertiaryBrush_v3}" Margin="0,0,6,0"/><TextBlock Text="{Binding ServerTime, StringFormat={}{0:dd/MM/yyyy, HH:mm:ss}}" Foreground="{StaticResource VmsTextSecondaryBrush_v3}" FontSize="10"/></StackPanel>
      <TextBlock Text="Version — v2.5.0" Foreground="{StaticResource VmsTextTertiaryBrush_v3}" FontSize="9" Margin="0,7,0,8"/>
     </StackPanel>
     <StackPanel x:Name="CollapsedFooter" Visibility="Collapsed" HorizontalAlignment="Center" Width="34">
      <Ellipse Width="8" Height="8" Fill="{StaticResource VmsSuccessBrush_v3}" HorizontalAlignment="Center" Margin="0,1,0,9"/>
      <Icon:PackIconMaterial Kind="ClockOutline" Width="14" Height="14" Foreground="{StaticResource VmsTextTertiaryBrush_v3}" HorizontalAlignment="Center" Margin="0,0,0,7"/>
      <TextBlock Text="v2.4.1" Foreground="{StaticResource VmsTextTertiaryBrush_v3}" FontSize="8" HorizontalAlignment="Center"/>
     </StackPanel>
     <Button x:Name="ToggleButton" Click="ToggleButton_Click" Cursor="Hand" FocusVisualStyle="{x:Null}" Style="{StaticResource SecondaryButtonStyle_v3}" Height="30" Padding="0" MinWidth="0" HorizontalContentAlignment="Center"><StackPanel Orientation="Horizontal"><Icon:PackIconMaterial x:Name="ToggleIcon" Kind="ChevronLeft" Width="14" Height="14"/><TextBlock x:Name="ToggleText" Text="Thu gọn" Margin="6,0,0,0"/></StackPanel></Button>
    </StackPanel>
   </Border>
  </Grid>
 </Border>
</UserControl>
