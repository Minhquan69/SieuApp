<UserControl x:Class="V3SClient.ucs.VehicleCaptureSlotControl" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:models="clr-namespace:V3SClient.models" mc:Ignorable="d" d:DesignHeight="200" d:DesignWidth="300" Background="#0D0F12">
    <UserControl.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries><ResourceDictionary Source="/styles/vehicle_capture_slot_control_styles.xaml" /></ResourceDictionary.MergedDictionaries>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </ResourceDictionary></UserControl.Resources>
    
    <Border BorderBrush="#252830" BorderThickness="1" CornerRadius="4" Margin="2" Background="#161920">
        <Grid>
            <!-- Ảnh -->
            <Image Source="{Binding Thumbnail}" Stretch="Uniform" Margin="2" />
            
            <!-- Icon hiển thị không có ảnh -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource VehicleCaptureSlotControlStackPanel01Style}">
                
                <Image Source="/images/no_image.png" Width="32" Height="32" Opacity="0.5" />
                <TextBlock Text="Chưa có ảnh" Foreground="#777777" HorizontalAlignment="Center" Margin="0,3,0,0" />
            </StackPanel>
            
            <!-- Overlay báo lỗi -->
            <Border Background="#88FF0000" VerticalAlignment="Top" HorizontalAlignment="Stretch" Visibility="{Binding HasError, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="White" FontWeight="Bold" Padding="5" TextAlignment="Center" />
            </Border>
            
            <!-- Góc chụp (Role) -->
            <Border Background="#AA000000" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Padding="5">
                <Grid>
                    <TextBlock Text="{Binding DisplayRole}" Foreground="#E0E0E0" FontWeight="SemiBold" HorizontalAlignment="Left" />
                    <TextBlock Text="{Binding CaptureTime, StringFormat='{}{0:HH:mm:ss}'}" Foreground="#AAAAAA" HorizontalAlignment="Right" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
