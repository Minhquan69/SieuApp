<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="V3SClient.ucs.ViewCamGroupList" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:V3SClient.ucs" xmlns:libs="clr-namespace:V3SClient.libs" xmlns:models="clr-namespace:V3SClient.models" xmlns:viewModels="clr-namespace:V3SClient.viewModels" xmlns:cv="clr-namespace:V3SClient.UI.Converters" mc:Ignorable="d" d:DesignHeight="450" d:DesignWidth="800">
  <UserControl.Resources>
    <ResourceDictionary>
      <cv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="../styles/border_reseted.xaml" />
        <ResourceDictionary Source="../styles/TreeView.xaml" />
        <ResourceDictionary Source="../styles/customize_radio_button.xaml" />
        <ResourceDictionary Source="../styles/customize_checkbox.xaml" />
        <ResourceDictionary Source="/styles/view_cam_group_list_styles.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>
  <Grid Background="Transparent">
    <TreeView x:Name="MyTreeView" Background="Transparent" ItemsSource="{Binding CameraGroupList}" SelectedItemChanged="MyTreeView_SelectedItemChanged" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" BorderThickness="0" Opacity="0.9">
      <TreeView.Resources>
        <ResourceDictionary>
          <ResourceDictionary.MergedDictionaries>
            <ResourceDictionary Source="/styles/view_cam_group_list_scope01_styles.xaml" />
          </ResourceDictionary.MergedDictionaries>
          <DataTemplate DataType="{x:Type models:Camera}">
            <StackPanel Orientation="Horizontal" Margin="20 5 0 5" VerticalAlignment="Center" Background="Transparent">
              <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" Style="{StaticResource CustomCheckBoxStyle}" Visibility="{Binding Path=AllowSelecting}" Checked="Camera_CheckedChanged" Unchecked="Camera_CheckedChanged" />
              <Image Width="16" Height="16" Margin="2,0,10,0" Style="{StaticResource ViewCamGroupListImage01Style}" />
              <TextBlock FontSize="11" Text="{Binding Path=name}" Style="{StaticResource ViewCamGroupListTextBlock02Style}" />
              <TextBlock Text="{Binding long_Name, StringFormat=' -&gt; {0}'}" Margin="2,0,0,0" FontSize="12" Style="{StaticResource ViewCamGroupListTextBlock03Style}" />
              <Border CornerRadius="3" Padding="3,0" Margin="4,0,0,0" Visibility="{Binding IsPlaying, Converter={StaticResource BoolToVisibilityConverter}}" Style="{StaticResource ViewCamGroupListBorder04Style}">
                <TextBlock Text="{Binding ActiveStreamMode}" FontSize="9" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" />
              </Border>
              <StackPanel.ContextMenu>
                <ContextMenu>
                  <MenuItem Header="Đàm thoại Camera" Click="TalkToCamera_Click" />
                </ContextMenu>
              </StackPanel.ContextMenu>
            </StackPanel>
          </DataTemplate>
          <HierarchicalDataTemplate DataType="{x:Type viewModels:VMTalkGroup}" ItemsSource="{Binding Items}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,0,2">
              <Image Source="/images/cam_group.png" Width="16" Height="16" Margin="2,0,5,0" VerticalAlignment="Center" />
              <TextBlock Style="{StaticResource  General_TextBlock}" FontSize="12">
                <TextBlock.Text>
                  <MultiBinding StringFormat="{}{0} ({1})">
                    <Binding Path="name" />
                    <Binding Path="Cameras.Count" />
                  </MultiBinding>
                </TextBlock.Text>
              </TextBlock>
              <StackPanel.ContextMenu>
                <ContextMenu>
                  <MenuItem Header="Đàm thoại Nhóm" Click="TalkToGroup_Click" />
                </ContextMenu>
              </StackPanel.ContextMenu>
            </StackPanel>
          </HierarchicalDataTemplate>
        </ResourceDictionary>
      </TreeView.Resources>
    </TreeView>
  </Grid>
</UserControl>