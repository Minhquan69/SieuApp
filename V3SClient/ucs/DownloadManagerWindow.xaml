<Window x:Class="V3SClient.ucs.DownloadManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:V3SClient.UI.Converters"
        Title="Tải xuống video" Height="440" Width="560" MinHeight="280" MinWidth="460"
        WindowStartupLocation="CenterOwner" Background="#071827" Foreground="#E6F0FF">
    <Window.Resources>
        <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#DCEBFF" />
            <Setter Property="Background" Value="#0C2841" />
            <Setter Property="BorderBrush" Value="#1D4F78" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>
    <Border Background="#071827" BorderBrush="#16466D" BorderThickness="1" CornerRadius="8" Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,0,0,12" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE118;" Foreground="#2D6BFF" FontSize="17" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <StackPanel>
                        <TextBlock Text="Tải xuống video" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="Tiến trình tải được tiếp tục khi đóng cửa sổ này" Foreground="#8FA9C1" FontSize="11" />
                    </StackPanel>
                </StackPanel>
                <Button Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Right" VerticalAlignment="Top" Click="Close_Click" Padding="6,4" />
            </Grid>
            <Border Grid.Row="1" Background="#0A2034" BorderBrush="#123C60" BorderThickness="1" CornerRadius="6" Padding="10,7" Margin="0,0,0,10">
                <TextBlock Text="Video tải về được lưu trong thư mục Downloads mặc định của Windows." Foreground="#AFC5DB" FontSize="12" />
            </Border>
            <Grid Grid.Row="2">
                <ListBox x:Name="lstTasks" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#0A2136" BorderBrush="#16466D" BorderThickness="1" CornerRadius="6" Padding="11" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Row="0">
                                        <TextBlock Text="{Binding CameraNames}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Status}" Foreground="#8FB5D5" FontSize="11" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                        <Button Content="Hủy" Click="Cancel_Click" IsEnabled="{Binding CanCancel}" Margin="0,0,6,0" />
                                        <Button Content="Mở thư mục" Click="OpenFolder_Click" />
                                    </StackPanel>
                                    <ProgressBar Grid.Row="1" Grid.ColumnSpan="2" Height="6" Margin="0,10,0,6" Value="{Binding Progress}" Maximum="100" Foreground="#2D6BFF" Background="#061521" BorderThickness="0" />
                                    <Grid Grid.Row="2" Grid.ColumnSpan="2">
                                        <TextBlock Text="{Binding Progress, StringFormat={}{0:F0}%}" Foreground="#90ABC3" FontSize="11" />
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Speed}" Foreground="#90ABC3" FontSize="11" Margin="0,0,12,0" />
                                            <TextBlock Foreground="#90ABC3" FontSize="11">
                                                <Run Text="{Binding StartTime, StringFormat=HH:mm}" />
                                                <Run Text=" - " />
                                                <Run Text="{Binding EndTime, StringFormat=HH:mm}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding Items.Count, ElementName=lstTasks, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=Inverse}">
                    <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" Foreground="#4C7193" FontSize="28" HorizontalAlignment="Center" />
                    <TextBlock Text="Chưa có video đang tải" Foreground="#AFC5DB" FontSize="13" Margin="0,8,0,0" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
