<Window x:Class="V3SClient.ucs.DownloadManagerWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local="clr-namespace:V3SClient.ucs" xmlns:converters="clr-namespace:V3SClient.UI.Converters" mc:Ignorable="d" Title="Download Manager" Height="450" Width="600" WindowStyle="None" AllowsTransparency="True" Background="Transparent" WindowStartupLocation="CenterOwner">
    <Window.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries><ResourceDictionary Source="/styles/download_manager_window_styles.xaml" /></ResourceDictionary.MergedDictionaries>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
        
    </ResourceDictionary></Window.Resources>

    <Border Background="#0D0F12" CornerRadius="8" BorderThickness="1" BorderBrush="#252830">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Background="#111318" CornerRadius="8,8,0,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid Margin="15,0">
                    <TextBlock Text="QUẢN LÝ TẢI VIDEO" Foreground="#4A9EFF" FontWeight="Bold" VerticalAlignment="Center" />
                    <Button Content="✖" HorizontalAlignment="Right" Click="Close_Click" Style="{StaticResource DownloadManagerWindowHeaderButtonStyle}" />
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="10">
                <ListBox x:Name="lstTasks" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#161920" CornerRadius="4" Padding="10" Margin="0,0,0,10" BorderThickness="1" BorderBrush="#252830">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Info -->
                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <TextBlock Text="{Binding CameraNames}" Foreground="#E8ECF1" FontWeight="SemiBold" FontSize="14" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Status}" Foreground="#8B95A5" FontSize="12" Margin="0,2,0,0" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding Speed}" Foreground="#8B95A5" FontSize="11" HorizontalAlignment="Right" />
                                        <Button Content="Mở thư mục" Click="OpenFolder_Click" Padding="5,2" Margin="0,5,0,0" Background="#252830" Foreground="#E8ECF1" BorderThickness="0" FontSize="10" Cursor="Hand" />
                                    </StackPanel>

                                    <!-- Progress -->
                                    <ProgressBar Grid.Row="1" Grid.ColumnSpan="2" Height="6" Margin="0,10,0,5" Value="{Binding Progress}" Maximum="100" Foreground="#4A9EFF" Background="#0D0F12" BorderThickness="0" />

                                    <Grid Grid.Row="2" Grid.ColumnSpan="2">
                                        <TextBlock Text="{Binding Progress, StringFormat={}{0:F1}%}" Foreground="#8B95A5" FontSize="10" HorizontalAlignment="Left" />
                                        <TextBlock Foreground="#8B95A5" FontSize="10" HorizontalAlignment="Right">
                                            <Run Text="{Binding StartTime, StringFormat=HH:mm:ss}" />
                                            <Run Text=" - " />
                                            <Run Text="{Binding EndTime, StringFormat=HH:mm:ss}" />
                                        </TextBlock>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Empty State -->
                <TextBlock Text="Không có yêu cầu tải xuống nào đang diễn ra" Foreground="#8B95A5" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding Items.Count, ElementName=lstTasks, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=Inverse}" />
            </Grid>
        </Grid>
    </Border>
</Window>



















