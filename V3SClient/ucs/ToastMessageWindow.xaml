<Window x:Class="V3SClient.ucs.ToastMessageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:V3SClient.ucs"
       WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        Width="300"
        Height="80"
        ShowInTaskbar="False"
        Loaded="Window_Loaded">
    <Border CornerRadius="5" Background="{Binding BackgroundBrush}" Padding="10" Opacity="0.95">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Image Source="{Binding IconSource}" Width="28" Height="28" Margin="0,0,10,0"/>
            <TextBlock Grid.Column="1" Text="{Binding Message}" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" FontSize="12" Foreground="White" MaxWidth="240"/>
            <!--<Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                --><!--<TextBlock Grid.Row="0" Text="{Binding Title}" 
                           FontWeight="Bold" 
                           FontSize="16" 
                           Foreground="White"
                           VerticalAlignment="Center"/>--><!--
                <TextBlock Grid.Row="1" Text="{Binding Message}" TextWrapping="Wrap" FontSize="12" Foreground="White" MaxWidth="250"/>
            </Grid>-->
        </Grid>
        
    </Border>
</Window>



















