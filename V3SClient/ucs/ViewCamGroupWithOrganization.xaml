<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="V3SClient.ucs.ViewCamGroupWithOrganization" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:V3SClient.ucs" xmlns:libs="clr-namespace:V3SClient.libs" xmlns:cv="clr-namespace:V3SClient.UI.Converters" mc:Ignorable="d" d:DesignHeight="450" d:DesignWidth="800">
  <UserControl.Resources>
    <ResourceDictionary>
      <cv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="../styles/border_reseted.xaml" />
        <ResourceDictionary Source="../styles/TreeView.xaml" />
        <ResourceDictionary Source="../styles/customize_radio_button.xaml" />
        <ResourceDictionary Source="../styles/customize_checkbox.xaml" />
        <ResourceDictionary Source="/styles/view_cam_group_with_organization_styles.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>
  <Grid Background="Transparent">
    <TreeView x:Name="MyTreeView" ItemsSource="{Binding AreaTree}" Background="Transparent" BorderThickness="0" SelectedItemChanged="TreeView_SelectedItemChanged" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto">
      <TreeView.Resources>
        <ResourceDictionary>
          <ResourceDictionary.MergedDictionaries>
            <ResourceDictionary Source="/styles/view_cam_group_with_organization_scope01_styles.xaml" />
          </ResourceDictionary.MergedDictionaries>
          <HierarchicalDataTemplate DataType="{x:Type libs:AreaNode}" ItemsSource="{Binding Units}">
            <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
              <Image Source="/images/layer_3.png" Width="16" Height="16" Margin="2,0,5,0" VerticalAlignment="Center" />
              <TextBlock Style="{StaticResource  General_TextBlock}" FontSize="12">
                <TextBlock.Text>
                  <MultiBinding StringFormat="{}{0} ({1})">
                    <Binding Path="Name" />
                    <Binding Path="Units.Count" />
                  </MultiBinding>
                </TextBlock.Text>
              </TextBlock>
            </StackPanel>
          </HierarchicalDataTemplate>
          <HierarchicalDataTemplate DataType="{x:Type libs:UnitNode}" ItemsSource="{Binding Items}">
            <StackPanel Orientation="Horizontal">
              <Image Source="/images/layer_1.png" Width="14" Height="14" Margin="3" />
              <TextBlock Style="{StaticResource  General_TextBlock}" FontSize="12">
                <TextBlock.Text>
                  <MultiBinding StringFormat="{}{0} ({1})">
                    <Binding Path="Name" />
                    <Binding Path="Cams.Count" />
                  </MultiBinding>
                </TextBlock.Text>
              </TextBlock>
            </StackPanel>
          </HierarchicalDataTemplate>
          <DataTemplate DataType="{x:Type libs:CamInfoNode}">
            <StackPanel Orientation="Horizontal" Margin="10,2">
              <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" Visibility="{Binding AllowSelecting}" Checked="Camera_CheckedChanged" Unchecked="Camera_CheckedChanged" />
              <Image Width="16" Height="16" Margin="5,0" Style="{StaticResource ViewCamGroupWithOrganizationImage01Style}" />
              <TextBlock Text="{Binding Name}" FontSize="11" Margin="5,0" Style="{StaticResource ViewCamGroupWithOrganizationTextBlock02Style}" />
              <TextBlock Text="{Binding LongName, StringFormat='--&gt; {0}'}" FontSize="12" Margin="5,0" Style="{StaticResource ViewCamGroupWithOrganizationTextBlock03Style}" />
              <Border CornerRadius="3" Padding="3,0" Margin="4,0,0,0" Visibility="{Binding IsPlaying, Converter={StaticResource BoolToVisibilityConverter}}" Style="{StaticResource ViewCamGroupWithOrganizationBorder04Style}">
                <TextBlock Text="{Binding ActiveStreamMode}" FontSize="9" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" />
              </Border>
            </StackPanel>
          </DataTemplate>
        </ResourceDictionary>
      </TreeView.Resources>
    </TreeView>
  </Grid>
</UserControl>