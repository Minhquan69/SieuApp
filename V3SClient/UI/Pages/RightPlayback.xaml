<Page x:Class="V3SClient.UI.Pages.RightPlayback"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:V3SClient.UI.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="400"
      Title="RightPlayback"
      Loaded="Page_Loaded"
      >
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../styles/customize_button.xaml" />
                <ResourceDictionary Source="../../styles/customize_image.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="Transparent" Margin="5,0,0,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" 
                x:Name="gridContent"
                Width="200"
                Visibility="Collapsed"
                Background="Transparent"
                BorderThickness="0"
                >
            <Frame x:Name="frmAIResultLog"                 
                   NavigationUIVisibility="Hidden"
                    />

        </Border>
        
       

        <Border Grid.Column="1" Background="Transparent">
            <StackPanel Orientation="Vertical">
                <Button Grid.Column="0"
                        Click="ShowContent"
                        Width="16" Height="16"
                        Style="{StaticResource Transparent_Button}"  
                                             
                       >
                    <Image Source="/images/arrows/arrow-square-right.png"
                           Style="{StaticResource Transparent_Image}"
                           />

                </Button>
            </StackPanel>
        </Border>


        
    </Grid>
</Page>




















