<Page x:Class="V3SClient.UI.Pages.LeftMenu" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:V3SClient.UI.Pages" xmlns:ucs="clr-namespace:V3SClient.ucs" xmlns:converters="clr-namespace:V3SClient.UI.Converters" mc:Ignorable="d" d:DesignHeight="800" d:DesignWidth="340" x:Name="Root" Title="Left_Menu">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../styles/border_reseted.xaml" />
                <ResourceDictionary Source="../../styles/TreeView.xaml" />
                <ResourceDictionary Source="../../styles/customize_combobox_mini.xaml" />
                <ResourceDictionary Source="../../styles/customize_textblock.xaml" />
            <ResourceDictionary Source="/styles/left_menu_styles.xaml" /></ResourceDictionary.MergedDictionaries>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
        </ResourceDictionary>
        
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="15" />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>
        <Border x:Name="Hide_Left_Menu" Visibility="Visible" Grid.Column="0" Style="{StaticResource Border_Reseted}" Background="#0D0F12" BorderThickness="0,0,0,0" BorderBrush="Transparent">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Column="0" Style="{StaticResource Border_Reseted}" Margin="0,20,0,0">
                    
                    <Button x:Name="btn_show_left_menu" Style="{StaticResource No_HandOver_Button}" Click="btn_hide_left_menu_Click" Background="Transparent" Padding="0" BorderThickness="0" Width="16" Height="16">
                        <Image Source="/images/arrow_square_left.png" Style="{StaticResource ImageFull}" />
                    </Button>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="leftMenu" Grid.Column="1" Width="230" Style="{StaticResource Border_Reseted}" BorderThickness="0" BorderBrush="DarkGray">
            <Border.Background>
                <SolidColorBrush Color="#0D0F12" Opacity="0.9" />
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="{Binding Path=HeightZoneCameraList}" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Định nghĩa vùng Cam List-->
                <Border Grid.Row="0" Style="{StaticResource Border_Reseted}" Margin="0,5,20,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30" />
                            <RowDefinition Height="35" /> <!-- Search Box -->
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource Border_Reseted}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Text: dynamic title -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                    <TextBlock Text="{Binding CameraGroupList.Count, StringFormat='Talk G ({0})'}" Visibility="{Binding IsOrganizationView, Converter={StaticResource InverseBoolToVisibilityConverter}}" Style="{StaticResource General_TextBlock}" FontSize="12" FontWeight="SemiBold" Opacity="0.9" Margin="5,0,0,0" />

                                    <TextBlock Text="{Binding CameraGroupList.Count, StringFormat='Orgs ({0})'}" Visibility="{Binding IsOrganizationView, Converter={StaticResource BoolToVisibilityConverter}}" Style="{StaticResource General_TextBlock}" FontSize="12" Opacity="0.9" Margin="5,0,0,0" FontWeight="SemiBold" />
                                </StackPanel>

                                <!-- Toggle button -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,2">
                                    <ToggleButton x:Name="btnToggleAIMode" Click="btnToggleAIMode_Click" ToolTip="Bật/tắt chế độ AI" Cursor="Hand" Margin="0,0,5,0" Style="{StaticResource LeftMenuToggleButton01Style}">
                                        
                                    </ToggleButton>
                                    <Button x:Name="btnSwapView" Visibility="Hidden" BorderThickness="0" Click="btnToggleView_Click" Width="16" Height="16" Background="Transparent" ToolTip="Chuyển đổi chế độ hiển thị">
                                        <Image Source="/images/swap.png" Stretch="Uniform" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Margin="1,0,1,5" Background="#0F1117" BorderBrush="#303540" BorderThickness="1" CornerRadius="4" Height="28">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                
                                <!-- Hint Text -->
                                <TextBlock x:Name="txtSearchHint" Grid.Column="0" Text="Tìm kiếm..." Foreground="#888888" VerticalAlignment="Center" Margin="6,0,0,0" IsHitTestVisible="False" />

                                <!-- Search Input -->
                                <TextBox x:Name="txtSearchTree" Grid.Column="0" Foreground="White" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="5,0" CaretBrush="White" TextChanged="txtSearchTree_TextChanged" />

                                <!-- Search Icon -->
                                <Image Grid.Column="1" Source="/images/search.png" Width="14" Height="14" Margin="5,0,8,0" Opacity="0.7" VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource Border_Reseted}">
                            <Border.Background>
                                <SolidColorBrush Opacity="0.2" Color="#252830" />
                            </Border.Background>

                            <Grid>
                                <ucs:ViewCamGroupList x:Name="View_Cam_Group_List" Visibility="{Binding IsOrganizationView, ElementName=Root, Converter={StaticResource InverseBoolToVisibilityConverter}}" Opacity="0.9" BorderThickness="0" />

                                <ucs:ViewCamGroupWithOrganization x:Name="View_Cam_Group_Org" Visibility="{Binding IsOrganizationView, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}" Opacity="0.9" BorderThickness="0" />
                            </Grid>
                        </Border>



                    </Grid>

                </Border>
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Margin="5" Orientation="Horizontal" x:Name="panelcomboBoxContent" Visibility="Collapsed">
                        <TextBlock x:Name="lablel_Content" Text="Chỉ huy :" Style="{StaticResource label_TextBlock }" />
                        <ComboBox x:Name="combox_Content" ItemsSource="{Binding Commanders}" SelectedValue="{Binding ActiveCommanderID, Mode=TwoWay}" SelectedValuePath="CamInfo_CamId" DisplayMemberPath="CamInfo_Name" Style="{StaticResource CustomComboBoxStyle }" Background="Transparent" Height="26" Margin="0,1,15,1" VerticalAlignment="Center" ItemContainerStyle="{StaticResource CustomComboBoxItemStyle}" FontSize="12" />
                    </StackPanel>
                    <Border Grid.Row="1" Margin="0,5,20,0">
                        <Border.Background>
                            <SolidColorBrush Color="#252830" Opacity="0.1" />
                        </Border.Background>
                        <Frame Grid.Row="1" x:Name="frameBottom" Background="Transparent" />
                    </Border>


                </Grid>
               
                <!-- Map-->

            </Grid>


        </Border>

        <!-- Định nghĩa nút ẩn Left Menu-->
       

    </Grid>
</Page>
