<Page x:Class="V3SClient.UI.Pages.PObjectDetail"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:V3SClient.UI.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="600"
      Title="PObjectDetail">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../styles/border_reseted.xaml" />
                <ResourceDictionary Source="../../styles/customize_textblock.xaml" />
                <ResourceDictionary Source="../../styles/customize_scrollviewer.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Top Images -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <!-- Info Fields -->
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="150"/>
        </Grid.ColumnDefinitions>

        <!-- Main Image -->
        <!--<Grid Grid.Row="0" Grid.Column="0" Height="120">
            <Grid.RowDefinitions>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Hình ảnh chân dung" Style="{StaticResource label_TextBlock}"/>
            <Border  BorderThickness="1" BorderBrush="LightGray" Width="100" Height="100">
                <Image Grid.Row="1" Grid.Column="0" x:Name="MainImage" Width="100" Height="100"  />
            </Border>
            
        </Grid>-->

        <Image Grid.Row="0" Grid.Column="0" x:Name="MainImage" Width="150" Height="150"  />
       
        <!-- Sub Image -->
        <Image x:Name="SubImage" Visibility="Hidden" Width="50" Height="50" Grid.Row="0" Grid.Column="1" Margin="10,120,10,10"/>
        <Grid Grid.Row="0" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="20"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Image x:Name="DetectImage"
       Width="Auto" Height="Auto"
       HorizontalAlignment="Center"
       Margin="2"
       Grid.Row="0" Grid.ColumnSpan="2"
       MouseRightButtonUp="DetectImage_MouseRightButtonUp">
                <Image.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Xem hình ảnh gốc" Click="ViewOriginalImage_Click"/>
                    </ContextMenu>
                </Image.ContextMenu>
            </Image>
            <TextBlock x:Name="txt2" Visibility="Hidden" Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center" Foreground="DarkGray" Text="Hình ảnh phát hiện"
       FontSize="14" Style="{StaticResource General_TextBlock}" Padding="2"/>
        </Grid>
        <!--<Border Grid.Row="0" Grid.Column="2" BorderThickness="0" BorderBrush="LightGray" Width="150" Height="150">
            <Image x:Name="DetectImage" Width="120" Height="120"  HorizontalAlignment="Right" Margin="2"/>
        </Border>-->
        <!-- Detect Image -->
        <!--<Image x:Name="DetectImage" Width="100" Height="100" Grid.Row="0" Grid.Column="2" HorizontalAlignment="Right" Margin="10"/>-->
        <TextBlock x:Name="txt1" Visibility="Hidden" Grid.Row="1" Text="Thông tin chi tiết" FontSize="20" Foreground="Gray"  Grid.ColumnSpan="2" Style="{StaticResource General_TextBlock}" HorizontalAlignment="Left" Padding="2"/>
        <!-- Info Fields -->
        <ScrollViewer Grid.Row="2" Grid.ColumnSpan="3"  Style="{StaticResource CustomScrollViewerStyle}">
            <StackPanel Orientation="Vertical" Margin="10" x:Name="InfoStack">
                <!-- Labels and TextBlocks will be generated dynamically in code-behind -->
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
