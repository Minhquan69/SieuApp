<Page x:Class="V3SClient.UI.Pages.VAISearchPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:webview2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf" xmlns:ucs="clr-namespace:V3SClient.ucs" mc:Ignorable="d" d:DesignHeight="720" d:DesignWidth="1280" SnapsToDevicePixels="True" UseLayoutRounding="True" Loaded="Loaded_Handler" TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType" TextOptions.TextHintingMode="Fixed" Title="VAISearchPage">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../styles/customize_textblock.xaml" />
                <ResourceDictionary Source="../../styles/customize_combobox.xaml" />
                <ResourceDictionary Source="../../styles/customize_button.xaml" />
                <ResourceDictionary Source="../../styles/border_reseted.xaml" />
                <ResourceDictionary Source="../../styles/gradientBorder.xaml" />
                <ResourceDictionary Source="../../styles/customize_scrollviewer.xaml" />
            <ResourceDictionary Source="/styles/vaisearch_page_styles.xaml" /></ResourceDictionary.MergedDictionaries>

            <!-- Custom Template for Timeline ListBoxItem -->
            

            
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="#111318">
        <Grid.ColumnDefinitions>
            <!-- 1: Sidebar Left (Fixed Width) -->
            <ColumnDefinition Width="Auto" />
            <!-- 2: Map Area (Flexible) -->
            <ColumnDefinition Width="*" />
            <!-- 3: Sidebar Right (Fixed Width) -->
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar Left -->
        <Border Grid.Column="0" BorderBrush="#252830" BorderThickness="0,0,1,0">
            <Frame x:Name="frmLeftMenu" Width="230" />
        </Border>

        <!-- Main Map Area -->
        <Grid Grid.Column="1">
            <ucs:UCTrajectoryMap x:Name="TrajectoryMap" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
        </Grid>

        <!-- Right Side Info Panel -->
        <Border Grid.Column="2" Background="#0D0F12" BorderBrush="#252830" BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <!-- Header -->
                    <RowDefinition Height="Auto" />
                    <!-- Object Profile -->
                    <RowDefinition Height="Auto" />
                    <!-- Timeline Section Header -->
                    <RowDefinition Height="Auto" />
                    <!-- Timeline History -->
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header Title -->
                <TextBlock Grid.Row="0" Text="ĐỐI TƯỢNG TRUY VẾT" Style="{StaticResource label_TextBlock}" FontSize="18" FontWeight="Bold" Foreground="White" Margin="15,15,15,10" />

                <!-- Object Profile Card -->
                <Border Grid.Row="1" Margin="15,5,15,15" Background="#161920" CornerRadius="8" Padding="15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        
                        <!-- Avatar -->
                        <Border Grid.Column="0" Width="60" Height="60" CornerRadius="30" BorderBrush="#252830" BorderThickness="2" VerticalAlignment="Top" ClipToBounds="True" Cursor="Hand" MouseDown="ObjectAvatar_MouseDown">
                            <Grid>
                                <Ellipse Fill="#0F1117" />
                                <Image x:Name="ObjectAvatar" Source="/images/user.png" Stretch="UniformToFill" Margin="12" Opacity="0.5" />
                            </Grid>
                        </Border>

                        <!-- Details -->
                        <StackPanel Grid.Column="1" Margin="15,0,0,0">
                            <TextBlock x:Name="SummaryNameText" Text="Đang tìm kiếm..." Style="{StaticResource label_TextBlock}" FontSize="15" FontWeight="Bold" Foreground="White" />
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                <TextBlock Text="ID: " Style="{StaticResource label_TextBlock}" FontSize="12" Opacity="0.6" />
                                <TextBlock x:Name="SummaryIdText" Text="—" Style="{StaticResource label_TextBlock}" FontSize="12" Foreground="#C8C8C8" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="Biển số: " Style="{StaticResource label_TextBlock}" FontSize="12" Opacity="0.6" />
                                <TextBlock x:Name="SummaryPlateText" Text="—" Style="{StaticResource label_TextBlock}" FontSize="12" Foreground="#C8C8C8" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Timeline Header -->
                <Grid Grid.Row="2" Margin="15,10,15,5">
                    <TextBlock Text="Lịch sử xuất hiện" Style="{StaticResource label_TextBlock}" FontSize="14" FontWeight="SemiBold" Foreground="#AAAAAA" />
                    <Image Source="/images/Log.png" HorizontalAlignment="Right" Width="16" Height="16" Opacity="0.6" />
                </Grid>

                <!-- Timeline List -->
                <ListBox Grid.Row="3" x:Name="TimelineList" Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource VaiSearchPageTimelineItemStyle}" Padding="10,5,10,10" SelectionChanged="TimelineList_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.Resources><ResourceDictionary Source="/styles/vaisearch_page_scope01_styles.xaml" /></ListBox.Resources>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                
                                <!-- Vertical Line segment -->
                                <!-- We draw a line for all except the last if we want, but simpler to just draw it -->
                                <Rectangle Grid.Column="0" Width="2" Fill="#252830" />
                                
                                <!-- Dot/Point icon -->
                                <Grid Grid.Column="0">
                                    <Ellipse Width="10" Height="10" Fill="#0D0F12" Stroke="#303540" StrokeThickness="2" VerticalAlignment="Center" />
                                    <Ellipse Width="4" Height="4" Fill="#4A9EFF" VerticalAlignment="Center" />
                                </Grid>

                                <!-- Details -->
                                <Border Grid.Column="1" Padding="15,12,10,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}" Style="{StaticResource label_TextBlock}" FontSize="14" FontWeight="Bold" Foreground="White" />
                                            <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:dd/MM/yyyy}'}" Style="{StaticResource label_TextBlock}" FontSize="10" Opacity="0.5" Margin="0,2,0,0" />
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Camera}" Style="{StaticResource label_TextBlock}" FontSize="13" Foreground="#C0C8D4" TextWrapping="Wrap" />
                                            <TextBlock Text="Vị trí phát hiện" Style="{StaticResource label_TextBlock}" FontSize="10" Opacity="0.4" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Full-screen Image Expansion Overlay -->
        <Grid x:Name="ImageOverlay" Grid.Column="0" Grid.ColumnSpan="3" Background="#CC000000" Visibility="Collapsed" MouseDown="Overlay_MouseDown">
            <Border Background="#161920" BorderBrush="#252830" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="1000" MaxHeight="800" CornerRadius="8" Padding="10">
                <Grid>
                    <Image x:Name="LargeImage" Stretch="Uniform" />
                    <Button Content="âœ–" HorizontalAlignment="Right" VerticalAlignment="Top" Width="32" Height="32" Margin="-5,-5,-5,-5" Style="{StaticResource SearchButtonBase}" Click="CloseOverlay_Click" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
