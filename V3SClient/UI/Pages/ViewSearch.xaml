<Page x:Class="V3SClient.UI.Pages.ViewSearch"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
      xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
      xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
      Background="Transparent">
    <Page.Resources>
        <Style x:Key="PlaybackSearchLabel_v3" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource VmsTextTertiaryBrush_v3}"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
        <Style x:Key="PlaybackDateField_v3" TargetType="Border">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Width" Value="190"/>
            <Setter Property="Background" Value="{StaticResource VmsSurfaceBrush_v3}"/>
            <Setter Property="BorderBrush" Value="{StaticResource VmsBorderBrush_v3}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="PlaybackCalendarDay_v3" TargetType="CalendarDayButton">
            <Setter Property="Foreground" Value="{StaticResource VmsTextPrimaryBrush_v3}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value><ControlTemplate TargetType="CalendarDayButton"><Border x:Name="root" Background="Transparent" BorderBrush="Transparent" BorderThickness="1" CornerRadius="7" Margin="2"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsToday" Value="True"><Setter TargetName="root" Property="BorderBrush" Value="{StaticResource VmsPrimaryBorderBrush_v3}"/></Trigger><Trigger Property="IsSelected" Value="True"><Setter TargetName="root" Property="Background" Value="{StaticResource VmsPrimarySoftBrush_v3}"/><Setter TargetName="root" Property="BorderBrush" Value="{StaticResource VmsPrimaryBrush_v3}"/><Setter Property="Foreground" Value="{StaticResource VmsTextPrimaryBrush_v3}"/></Trigger><Trigger Property="IsInactive" Value="True"><Setter Property="Foreground" Value="{StaticResource VmsTextTertiaryBrush_v3}"/></Trigger><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="root" Property="Background" Value="{StaticResource VmsPrimarySoftBrush_v3}"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PlaybackCalendarButton_v3" TargetType="CalendarButton">
            <Setter Property="Foreground" Value="{StaticResource VmsTextPrimaryBrush_v3}"/>
            <Setter Property="Template">
                <Setter.Value><ControlTemplate TargetType="CalendarButton"><Border x:Name="root" Background="Transparent" CornerRadius="6" Margin="2"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="root" Property="Background" Value="{StaticResource VmsPrimarySoftBrush_v3}"/></Trigger><Trigger Property="IsInactive" Value="True"><Setter Property="Foreground" Value="{StaticResource VmsTextTertiaryBrush_v3}"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PlaybackCalendarItem_v3" TargetType="primitives:CalendarItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="primitives:CalendarItem">
                        <ControlTemplate.Resources>
                            <DataTemplate x:Key="{x:Static primitives:CalendarItem.DayTitleTemplateResourceKey}"><TextBlock Text="{Binding}" Foreground="{StaticResource VmsTextSecondaryBrush_v3}" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/></DataTemplate>
                        </ControlTemplate.Resources>
                        <Grid x:Name="PART_Root" Background="{StaticResource VmsSurfaceBrush_v3}">
                            <Grid.Resources><Style TargetType="CalendarDayButton" BasedOn="{StaticResource PlaybackCalendarDay_v3}"/><Style TargetType="CalendarButton" BasedOn="{StaticResource PlaybackCalendarButton_v3}"/></Grid.Resources>
                            <Grid.RowDefinitions><RowDefinition Height="36"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="32"/><ColumnDefinition Width="*"/><ColumnDefinition Width="32"/></Grid.ColumnDefinitions>
                            <Button x:Name="PART_PreviousButton" Grid.Row="0" Grid.Column="0" Content="‹" FontSize="23" Foreground="{StaticResource VmsTextPrimaryBrush_v3}" Background="Transparent" BorderThickness="0"/>
                            <Button x:Name="PART_HeaderButton" Grid.Row="0" Grid.Column="1" FontWeight="SemiBold" Foreground="{StaticResource VmsTextPrimaryBrush_v3}" Background="Transparent" BorderThickness="0"/>
                            <Button x:Name="PART_NextButton" Grid.Row="0" Grid.Column="2" Content="›" FontSize="23" Foreground="{StaticResource VmsTextPrimaryBrush_v3}" Background="Transparent" BorderThickness="0"/>
                            <Grid x:Name="PART_MonthView" Grid.Row="1" Grid.ColumnSpan="3" Margin="0,3,0,0"/>
                            <Grid x:Name="PART_YearView" Grid.Row="1" Grid.ColumnSpan="3" Visibility="Collapsed"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PlaybackQuickRangeButton_v3" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource VmsTextSecondaryBrush_v3}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="7,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="root" Property="Background" Value="{StaticResource VmsPrimarySoftBrush_v3}"/><Setter Property="Foreground" Value="{StaticResource VmsTextPrimaryBrush_v3}"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter TargetName="root" Property="Background" Value="{StaticResource VmsPrimaryBrush_v3}"/><Setter Property="Foreground" Value="White"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PlaybackCalendarDayButton_v3" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource VmsTextPrimaryBrush_v3}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="root" Property="Background" Value="{StaticResource VmsPrimarySoftBrush_v3}"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter TargetName="root" Property="Background" Value="{StaticResource VmsPrimaryBrush_v3}"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    <Grid VerticalAlignment="Center" PreviewMouseDown="Root_PreviewMouseDown">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <!-- Retained for ViewSearch logic; storage selection is intentionally
             not shown in the compact web toolbar. -->
        <ComboBox x:Name="combVideoStorage" Visibility="Collapsed" ItemsSource="{Binding Path=VideoStorageList}" DisplayMemberPath="Name" SelectedValuePath="Location" SelectedItem="{Binding SelectedVideoStorage, Mode=TwoWay}"/>
        <!-- The hidden Xceed controls retain the current playback search contract.
             The visible fields and popup are a web-style presentation layer. -->
        <xctk:DateTimePicker x:Name="datetimeFrom" Visibility="Collapsed"/>
        <xctk:DateTimePicker x:Name="datetimeTo" Visibility="Collapsed"/>
        <StackPanel Grid.Column="0" Margin="0,0,8,0">
            <TextBlock Text="BẮT ĐẦU" Style="{StaticResource PlaybackSearchLabel_v3}"/>
            <Border x:Name="fromDateField" Style="{StaticResource PlaybackDateField_v3}" MouseLeftButtonDown="DateField_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="11,0"><Icon:PackIconMaterial Kind="CalendarMonthOutline" Width="17" Height="17" Foreground="{StaticResource VmsTextSecondaryBrush_v3}"/><TextBlock x:Name="fromDateText" Foreground="{StaticResource VmsTextPrimaryBrush_v3}" FontWeight="SemiBold" FontSize="12" Margin="9,0,0,0" VerticalAlignment="Center"/></StackPanel>
            </Border>
        </StackPanel>
        <StackPanel Grid.Column="1" Margin="0,0,8,0">
            <TextBlock Text="KẾT THÚC" Style="{StaticResource PlaybackSearchLabel_v3}"/>
            <Border x:Name="toDateField" Style="{StaticResource PlaybackDateField_v3}" MouseLeftButtonDown="DateField_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="11,0"><Icon:PackIconMaterial Kind="CalendarMonthOutline" Width="17" Height="17" Foreground="{StaticResource VmsTextSecondaryBrush_v3}"/><TextBlock x:Name="toDateText" Foreground="{StaticResource VmsTextPrimaryBrush_v3}" FontWeight="SemiBold" FontSize="12" Margin="9,0,0,0" VerticalAlignment="Center"/></StackPanel>
            </Border>
        </StackPanel>
        <StackPanel Grid.Column="2" Margin="0,0,8,0">
            <TextBlock Text="CHỌN NHANH" Style="{StaticResource PlaybackSearchLabel_v3}"/>
            <Border Height="36" CornerRadius="7" Background="{StaticResource VmsSurfaceBrush_v3}" BorderBrush="{StaticResource VmsBorderBrush_v3}" BorderThickness="1" Padding="5,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="quickRange1h" Content="1h" Tag="1" Click="QuickRange_Click" Style="{StaticResource PlaybackQuickRangeButton_v3}"/>
                    <Button x:Name="quickRange6h" Content="6h" Tag="6" Click="QuickRange_Click" Style="{StaticResource PlaybackQuickRangeButton_v3}"/>
                    <Button x:Name="quickRange12h" Content="12h" Tag="12" Click="QuickRange_Click" Style="{StaticResource PlaybackQuickRangeButton_v3}"/>
                    <Button x:Name="quickRange24h" Content="24h" Tag="24" Click="QuickRange_Click" Style="{StaticResource PlaybackQuickRangeButton_v3}"/>
                </StackPanel>
            </Border>
        </StackPanel>
        <Grid Grid.Column="3" Width="136" Height="36" VerticalAlignment="Bottom" x:Name="ButtonGrid">
            <Grid.RowDefinitions><RowDefinition x:Name="btnSize" Height="36"/><RowDefinition Height="0"/></Grid.RowDefinitions>
            <Border Grid.Row="0" x:Name="btn_01" Tag="btn1" Height="36" MouseLeftButtonDown="btnSearch_MouseLeftButtonDown" Background="{StaticResource VmsPrimaryBrush_v3}" CornerRadius="7" Cursor="Hand" ToolTip="Tìm kiếm video theo khoảng thời gian đã chọn">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"><Icon:PackIconMaterial Kind="Magnify" Width="16" Height="16" Foreground="White"/><TextBlock x:Name="txtTitle_bnt1" Text="Tìm kiếm" Foreground="White" FontWeight="SemiBold" FontSize="12" Margin="6,0,0,0"/></StackPanel>
            </Border>
            <Border Grid.Row="1" x:Name="btn_02" Tag="btn2" MouseLeftButtonDown="btnSearch_MouseLeftButtonDown" Visibility="Collapsed"><TextBlock x:Name="txtTitle_bnt2"/></Border>
        </Grid>
        <!-- The result text remains available to the existing playback code;
             the web UI reports readiness inside the selected-camera panel. -->
        <TextBlock x:Name="txtResultSearch" Visibility="Collapsed"/>
        <Border x:Name="btnExportFiles" Visibility="Collapsed" MouseLeftButtonDown="btnExportFiles_MouseLeftButtonDown"/>
        <Popup x:Name="datePopup" Placement="Bottom" StaysOpen="True" AllowsTransparency="True" PopupAnimation="Fade">
            <Border Width="280" Background="{StaticResource VmsSurfaceBrush_v3}" BorderBrush="{StaticResource VmsBorderBrush_v3}" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,6,0,0">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <StackPanel>
                        <Grid><TextBlock Text="NGÀY" Style="{StaticResource PlaybackSearchLabel_v3}"/><Button HorizontalAlignment="Right" VerticalAlignment="Top" Click="CloseDatePopup_Click" Content="×" Width="24" Height="22" Padding="0" Foreground="{StaticResource VmsTextSecondaryBrush_v3}" Background="Transparent" BorderThickness="0" FontSize="18" ToolTip="Đóng"/></Grid>
                        <TextBox x:Name="popupDateInput" Height="34" Padding="9,0" VerticalContentAlignment="Center" Foreground="{StaticResource VmsTextPrimaryBrush_v3}" Background="{StaticResource VmsHeaderBrush_v3}" BorderBrush="{StaticResource VmsPrimaryBrush_v3}" BorderThickness="1" LostFocus="PopupDateInput_LostFocus"/>
                    </StackPanel>
                    <Grid Grid.Row="1" Margin="0,10,0,8">
                        <Grid.RowDefinitions><RowDefinition Height="34"/><RowDefinition Height="24"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/><ColumnDefinition Width="34"/></Grid.ColumnDefinitions>
                        <Button Grid.Row="0" Grid.Column="0" Content="‹" Click="PreviousMonth_Click" FontSize="23" Foreground="{StaticResource VmsTextPrimaryBrush_v3}" Background="Transparent" BorderThickness="0" ToolTip="Tháng trước"/>
                        <TextBlock x:Name="calendarMonthText" Grid.Row="0" Grid.Column="1" TextAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource VmsTextPrimaryBrush_v3}"/>
                        <Button Grid.Row="0" Grid.Column="2" Content="›" Click="NextMonth_Click" FontSize="23" Foreground="{StaticResource VmsTextPrimaryBrush_v3}" Background="Transparent" BorderThickness="0" ToolTip="Tháng sau"/>
                        <primitives:UniformGrid Grid.Row="1" Grid.ColumnSpan="3" Columns="7">
                            <TextBlock Text="Su" TextAlignment="Center" Foreground="{StaticResource VmsTextSecondaryBrush_v3}" FontSize="12"/><TextBlock Text="Mo" TextAlignment="Center" Foreground="{StaticResource VmsTextSecondaryBrush_v3}" FontSize="12"/><TextBlock Text="Tu" TextAlignment="Center" Foreground="{StaticResource VmsTextSecondaryBrush_v3}" FontSize="12"/><TextBlock Text="We" TextAlignment="Center" Foreground="{StaticResource VmsTextSecondaryBrush_v3}" FontSize="12"/><TextBlock Text="Th" TextAlignment="Center" Foreground="{StaticResource VmsTextSecondaryBrush_v3}" FontSize="12"/><TextBlock Text="Fr" TextAlignment="Center" Foreground="{StaticResource VmsTextSecondaryBrush_v3}" FontSize="12"/><TextBlock Text="Sa" TextAlignment="Center" Foreground="{StaticResource VmsTextSecondaryBrush_v3}" FontSize="12"/>
                        </primitives:UniformGrid>
                        <primitives:UniformGrid x:Name="calendarDaysPanel" Grid.Row="2" Grid.ColumnSpan="3" Columns="7"/>
                    </Grid>
                    <StackPanel Grid.Row="2">
                        <TextBlock Text="THỜI GIAN" Style="{StaticResource PlaybackSearchLabel_v3}"/>
                        <TextBox x:Name="popupTimeInput" Height="34" Padding="9,0" VerticalContentAlignment="Center" Foreground="{StaticResource VmsTextPrimaryBrush_v3}" Background="{StaticResource VmsHeaderBrush_v3}" BorderBrush="{StaticResource VmsBorderBrush_v3}" BorderThickness="1" LostFocus="PopupTimeInput_LostFocus"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</Page>
