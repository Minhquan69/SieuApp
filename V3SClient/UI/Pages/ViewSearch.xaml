<Page xmlns:ucs="clr-namespace:V3SClient.ucs" x:Class="V3SClient.UI.Pages.ViewSearch" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:V3SClient.UI.Pages" xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit" mc:Ignorable="d" d:DesignHeight="800" d:DesignWidth="600" Title="ViewSearch">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../styles/customize_textblock.xaml" />
                <ResourceDictionary Source="../../styles/customize_combobox.xaml" />
                <ResourceDictionary Source="../../styles/customize_datetimepicker.xaml" />
                <ResourceDictionary Source="../../styles/gradientBorder.xaml" />
                <ResourceDictionary Source="../../styles/windowformhost.xaml" />
            <ResourceDictionary Source="/styles/view_search_styles.xaml" /></ResourceDictionary.MergedDictionaries>
            
        </ResourceDictionary>
        
        
        
    
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="65" />
            <RowDefinition Height="65" />
            <RowDefinition Height="65" />
            <RowDefinition x:Name="btnSize" Height="50" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <!--where searching-->
        <StackPanel Orientation="Vertical">
            <TextBlock Text="Storage" Style="{StaticResource label_TextBlock }" />
            <ComboBox Style="{StaticResource CustomComboBoxStyle}" Background="Transparent" Height="40" VerticalAlignment="Center" ItemContainerStyle="{StaticResource CustomComboBoxItemStyle}" ItemsSource="{Binding Path=VideoStorageList}" DisplayMemberPath="Name" SelectedValuePath="Location" SelectedItem="{Binding SelectedVideoStorage, Mode=TwoWay}" x:Name="combVideoStorage" />
        </StackPanel>


        <StackPanel Grid.Row="1">
            <TextBlock Text="From" Style="{StaticResource label_TextBlock }" Margin="0,3,0,0" />
                <xctk:DateTimePicker x:Name="datetimeFrom" Style="{StaticResource CustomizeDateTimePicker}" Opacity="0.6" />
            </StackPanel>
        <StackPanel Grid.Row="2">
            <TextBlock Text="To" Style="{StaticResource label_TextBlock }" Margin="0,3,0,0" />
                <xctk:DateTimePicker x:Name="datetimeTo" Style="{StaticResource CustomizeDateTimePicker}" Opacity="0.6" />
            </StackPanel>
        <Grid Grid.Row="3" x:Name="ButtonGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <!-- Cho btn_01 -->
                <RowDefinition Height="*" />
                <!-- Cho btn_02 -->
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Margin="0,6,0,3" Style="{StaticResource GrayBorder}" CornerRadius="5" x:Name="btn_01" Tag="btn1" MouseLeftButtonDown="btnSearch_MouseLeftButtonDown" Opacity="0.95" VerticalAlignment="Stretch">
                <TextBlock x:Name="txtTitle_bnt1" Text="Button1" Style="{StaticResource label_TextBlock}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#DDDDDD" />
            </Border>

            <Border Grid.Row="1" Margin="0,6,0,3" Visibility="Collapsed" Style="{StaticResource GrayBorder}" CornerRadius="5" x:Name="btn_02" Tag="btn2" MouseLeftButtonDown="btnSearch_MouseLeftButtonDown" Opacity="0.95">
                <TextBlock x:Name="txtTitle_bnt2" Text="Button2" Style="{StaticResource label_TextBlock}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#DDDDDD" />
            </Border>
        </Grid>

        <Grid Grid.Row="4" Margin="0,5,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="25" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Text="Videos" Grid.Row="0" Style="{StaticResource label_TextBlock }" VerticalAlignment="Bottom" />
            <Border CornerRadius="3" Grid.Row="1" BorderBrush="#252830" BorderThickness="1" Margin="0,0,0,5" Padding="10" Opacity="0.8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="txtResultSearch" Style="{StaticResource label_TextBlock}" VerticalAlignment="Top" FontSize="12" />
                </ScrollViewer>
               
            </Border>
            <Border Grid.Row="1" Width="60" Height="30" Visibility="Hidden" HorizontalAlignment="Right" Style="{StaticResource GrayBorder}" Margin="0,0,5,10" CornerRadius="5" x:Name="btnExportFiles" MouseLeftButtonDown="btnExportFiles_MouseLeftButtonDown" VerticalAlignment="Bottom">
                <TextBlock Text="Export" Style="{StaticResource label_TextBlock}" VerticalAlignment="Center" HorizontalAlignment="Center" Background="Transparent" Foreground="White" />

            </Border>
            
        </Grid>

    </Grid>
</Page>
