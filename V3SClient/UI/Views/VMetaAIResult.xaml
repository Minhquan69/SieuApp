<Page x:Class="V3SClient.UI.Views.VMetaAIResult" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:V3SClient.UI.Views" xmlns:libs="clr-namespace:V3SClient.libs" mc:Ignorable="d" d:DesignHeight="450" d:DesignWidth="800" Title="VMetaAIResult">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/styles/customize_listview_ai_result.xaml" />
                <ResourceDictionary Source="/styles/customize_datagrid.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <libs:Base64ToBitmapConverter x:Key="Base64ToBitmapConverter" />
            <libs:DateTimeStringFormatConverter x:Key="DateTimeStringFormatConverter" />

        </ResourceDictionary>
    </Page.Resources>
    <Grid Background="#0D0F12">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="HeaderRow" Height="30" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" x:Name="txtAIResult" Visibility="Hidden" Text="AI Result" Style="{StaticResource customizeTextBlock}" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" FontSize="13" FontFamily="Kanit" Foreground="WhiteSmoke" />
        
        <!-- DataGrid: logData is ObservableCollection<LogItem> -->
        <DataGrid Grid.Row="1" x:Name="LogDataGrid" ItemsSource="{Binding logData}" AutoGenerateColumns="False" Margin="0,3,0,0" Background="Transparent" RowBackground="Transparent" AlternatingRowBackground="#22000000" HeadersVisibility="Column" BorderThickness="0" GridLinesVisibility="None" EnableRowVirtualization="True" IsReadOnly="True" SelectionMode="Single" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" SelectionUnit="FullRow" ColumnHeaderStyle="{StaticResource smallHeaderStyle}">
          
            <DataGrid.Resources><ResourceDictionary Source="/styles/vmeta_airesult_scope01_styles.xaml" /></DataGrid.Resources>

            <DataGrid.Columns>

                <!-- Cột Object (ảnh) -->
                <DataGridTemplateColumn Header="Object" Width="50" CanUserResize="False" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Width="50" Margin="1" Height="50" Source="{Binding Value.EncodeObjectImage, Converter={StaticResource Base64ToBitmapConverter}}" Stretch="Fill" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Cột Camera -->
                <DataGridTextColumn Header="Camera" Width="60" IsReadOnly="True" FontSize="11" Binding="{Binding Value.CameraInfo}" />

                <!-- Cột Time -->
                <DataGridTemplateColumn Header="Time" Width="60" CanUserResize="False" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Value.TimeStamp, Converter={StaticResource DateTimeStringFormatConverter}}" Style="{StaticResource customizeTextBlock}" FontSize="11" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Cột In List -->
                <DataGridTemplateColumn Header="In List" Width="45" CanUserResize="False" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid HorizontalAlignment="Center">
                                <CheckBox IsChecked="{Binding Value.IsBlackList}" IsEnabled="False" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource customizeCheckbox}" />
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Cột Info -->
                <DataGridTextColumn Header="Info" Width="150" CanUserResize="False" IsReadOnly="True" Binding="{Binding Value.Caption}" />

            </DataGrid.Columns>
        </DataGrid>
    </Grid>

</Page>
