<UserControl x:Class="V3SClient.UI.Views.LiveTile_v3"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:V3SClient.UI.Views"
             xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Background="{StaticResource VmsSurfaceBrush_v3}">
    <UserControl.Resources>
        <Style x:Key="LiveTileActionButton_v3" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle_v3}">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ActionButtonBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ActionButtonBorder" Property="Opacity" Value="0.86"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="ActionButtonBorder" Property="Opacity" Value="0.45"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LiveTileActionPrimaryButton_v3" TargetType="Button" BasedOn="{StaticResource LiveTileActionButton_v3}">
            <Setter Property="Background" Value="{StaticResource VmsPrimaryBrush_v3}"/>
            <Setter Property="BorderBrush" Value="{StaticResource VmsPrimaryBrush_v3}"/>
            <Setter Property="Foreground" Value="{StaticResource VmsTextInverseBrush_v3}"/>
        </Style>
    </UserControl.Resources>
    <Border x:Name="TileBorder" BorderBrush="{StaticResource VmsBorderBrush_v3}" BorderThickness="1" Background="{StaticResource VmsSurfaceBrush_v3}" Margin="1" ClipToBounds="True" SizeChanged="TileBorder_SizeChanged" MouseEnter="TileBorder_MouseEnter" MouseLeave="TileBorder_MouseLeave" MouseLeftButtonUp="TileBorder_MouseLeftButtonUp">
        <Grid>
            <local:WhepPlayer_v3 x:Name="Player" />
            <!-- The grid/sub pipeline remains alive while this second native
                 host prepares the main stream for fullscreen. -->
            <local:WhepPlayer_v3 x:Name="MainPlayer" Background="Transparent" IsHitTestVisible="False" />
            <!-- WindowsFormsHost owns a native child window, so WPF
                 MouseEnter on TileBorder is only raised near its edge. This
                 transparent surface gives the whole tile a reliable hover
                 hit area while keeping the video visible underneath. -->
            <Border x:Name="HoverSurface" Background="Transparent" Panel.ZIndex="10" MouseEnter="HoverSurface_MouseEnter" MouseLeave="HoverSurface_MouseLeave" />
            <local:AiMetadataOverlay_v3 x:Name="MetadataOverlay" IsHitTestVisible="False" />

            <!-- Keep the camera ID inside the tile's WPF visual tree. The
                 previous Popup was a separate HWND and could remain visible
                 over another application after focus changed. -->
            <Border x:Name="CameraBadgeInline" Panel.ZIndex="35" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="7" Padding="7,4" Background="{StaticResource VmsElevatedBrush_v3}" BorderBrush="{StaticResource VmsBorderStrongBrush_v3}" BorderThickness="1" CornerRadius="3" IsHitTestVisible="False" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="StatusDotInline" Width="7" Height="7" Fill="{StaticResource VmsOfflineBrush_v3}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="CameraNameInline" Foreground="{StaticResource VmsTextInverseBrush_v3}" FontWeight="SemiBold" FontSize="11" TextTrimming="CharacterEllipsis" MaxWidth="210"/>
                </StackPanel>
            </Border>

            <Border x:Name="LoadingOverlay" Panel.ZIndex="20" Background="{StaticResource VmsSurfaceBrush_v3}" Visibility="Collapsed" IsHitTestVisible="False">
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
                    <TextBlock Text="↻" FontSize="30" Foreground="{StaticResource VmsPrimaryBrush_v3}" HorizontalAlignment="Center">
                        <TextBlock.RenderTransform><RotateTransform x:Name="LoadingRotation" CenterX="15" CenterY="15"/></TextBlock.RenderTransform>
                    </TextBlock>
                    <ProgressBar Width="110" Height="3" IsIndeterminate="True" Foreground="{StaticResource VmsPrimaryBrush_v3}" Background="{StaticResource VmsBorderBrush_v3}" Margin="0,5,0,0"/>
                    <TextBlock x:Name="LoadingText" Text="Đang kết nối..." Foreground="{StaticResource VmsTextSecondaryBrush_v3}" FontSize="11" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Viewbox Width="30" Height="30" HorizontalAlignment="Center">
                        <Canvas Width="30" Height="30">
                            <Canvas.RenderTransform><RotateTransform x:Name="StreamLoadingRotation" CenterX="15" CenterY="15"/></Canvas.RenderTransform>
                            <Path Data="M 15,2 A 13,13 0 1 1 2,15" Stroke="{StaticResource VmsPrimaryBrush_v3}" StrokeThickness="3.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock x:Name="PendingTitle" Text="Đang kết nối stream..." FontWeight="SemiBold" Foreground="{StaticResource VmsTextPrimaryBrush_v3}" FontSize="13" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    <TextBlock x:Name="PendingStreamText" Foreground="{StaticResource VmsTextSecondaryBrush_v3}" FontSize="11" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="EmptyOverlay" Panel.ZIndex="20" Background="{StaticResource VmsSurfaceBrush_v3}" Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Width="48" Height="48" CornerRadius="24" Background="{StaticResource VmsSurface2Brush_v3}" BorderBrush="{StaticResource VmsBorderBrush_v3}" BorderThickness="1" HorizontalAlignment="Center">
                        <Icon:PackIconMaterial Kind="CameraOffOutline" Width="24" Height="24" Foreground="{StaticResource VmsTextTertiaryBrush_v3}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border x:Name="ErrorOverlay" Panel.ZIndex="30" Background="{StaticResource VmsSurfaceBrush_v3}" Visibility="Collapsed" Padding="12" IsHitTestVisible="True">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="280">
                    <Icon:PackIconMaterial Kind="AlertCircleOutline" Width="32" Height="32" Foreground="{StaticResource VmsErrorBrush_v3}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Lỗi kết nối" FontWeight="SemiBold" Foreground="{StaticResource VmsTextPrimaryBrush_v3}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    <TextBlock x:Name="ErrorText" Text="Kiểm tra mạng hoặc cấu hình camera." TextWrapping="Wrap" TextAlignment="Center" FontSize="11" Foreground="{StaticResource VmsTextSecondaryBrush_v3}" Margin="0,4,0,8"/>
                    <Button Content="Thử lại" Click="Retry_Click" Style="{StaticResource PrimaryButtonStyle_v3}" Padding="12,4"/>
                </StackPanel>
            </Border>

            <Popup x:Name="CameraBadgePopup" Placement="AbsolutePoint" AllowsTransparency="True" IsHitTestVisible="False" IsOpen="False">
            <Border x:Name="CameraBadge" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0" Padding="7,4" Background="{StaticResource VmsElevatedBrush_v3}" BorderBrush="{StaticResource VmsBorderStrongBrush_v3}" BorderThickness="1" CornerRadius="3">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="StatusDot" Width="7" Height="7" Fill="{StaticResource VmsOfflineBrush_v3}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="CameraName" Foreground="{StaticResource VmsTextInverseBrush_v3}" FontWeight="SemiBold" FontSize="11" TextTrimming="CharacterEllipsis" MaxWidth="210"/>
                </StackPanel>
            </Border>
            </Popup>

            <Popup x:Name="ActionPopup" Placement="AbsolutePoint" AllowsTransparency="True" StaysOpen="True" PopupAnimation="Fade">
            <Border x:Name="ActionBar" Panel.ZIndex="30" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0" Padding="0" Background="Transparent" BorderThickness="0" Opacity="1" IsHitTestVisible="True" MouseEnter="ActionBar_MouseEnter" MouseLeave="ActionBar_MouseLeave">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="ConnectButton" Click="Connect_Click" Style="{StaticResource LiveTileActionPrimaryButton_v3}" ToolTip="Kết nối camera"><Icon:PackIconMaterial Kind="Play" Width="13" Height="13"/></Button>
                    <Button x:Name="DisconnectButton" Click="Disconnect_Click" Style="{StaticResource LiveTileActionButton_v3}" ToolTip="Ngắt kết nối"><Icon:PackIconMaterial Kind="PowerPlugOff" Width="13" Height="13"/></Button>
                    <ComboBox x:Name="StreamSelector" Width="105" Height="26" DisplayMemberPath="StreamType" SelectionChanged="StreamSelector_SelectionChanged" Style="{StaticResource VmsComboBoxStyle_v3}" Margin="1" Visibility="Collapsed"/>
                    <Button x:Name="FullscreenButton" Click="Fullscreen_Click" Style="{StaticResource LiveTileActionButton_v3}" ToolTip="Toàn màn hình"><Icon:PackIconMaterial x:Name="FullscreenIcon" Kind="Fullscreen" Width="13" Height="13"/></Button>
                    <Button Click="Remove_Click" Style="{StaticResource LiveTileActionButton_v3}" Foreground="{StaticResource VmsErrorBrush_v3}" ToolTip="Xóa camera"><Icon:PackIconMaterial Kind="DeleteOutline" Width="13" Height="13"/></Button>
                </StackPanel>
            </Border>
            </Popup>
        </Grid>
    </Border>
</UserControl>
