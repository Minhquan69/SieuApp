<UserControl x:Class="V3SClient.UI.Views.LiveTile_v3"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:V3SClient.UI.Views"
             xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Background="{StaticResource VmsSurfaceBrush_v3}">
    <Border x:Name="TileBorder" BorderBrush="{StaticResource VmsBorderBrush_v3}" BorderThickness="1" Background="{StaticResource VmsSurfaceBrush_v3}" Margin="1" ClipToBounds="True" SizeChanged="TileBorder_SizeChanged" MouseEnter="TileBorder_MouseEnter" MouseLeave="TileBorder_MouseLeave" MouseLeftButtonUp="TileBorder_MouseLeftButtonUp">
        <Grid>
            <local:WhepPlayer_v3 x:Name="Player" />
            <!-- WindowsFormsHost owns a native child window, so WPF
                 MouseEnter on TileBorder is only raised near its edge. This
                 transparent surface gives the whole tile a reliable hover
                 hit area while keeping the video visible underneath. -->
            <Border x:Name="HoverSurface" Background="Transparent" Panel.ZIndex="10" MouseEnter="HoverSurface_MouseEnter" MouseLeave="HoverSurface_MouseLeave" />
            <local:AiMetadataOverlay_v3 x:Name="MetadataOverlay" IsHitTestVisible="False" />

            <Border x:Name="LoadingOverlay" Background="#990B1D2A" Visibility="Collapsed" IsHitTestVisible="False">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="↻" FontSize="30" Foreground="{StaticResource VmsPrimaryBrush_v3}" HorizontalAlignment="Center">
                        <TextBlock.RenderTransform><RotateTransform x:Name="LoadingRotation" CenterX="15" CenterY="15"/></TextBlock.RenderTransform>
                    </TextBlock>
                    <ProgressBar Width="110" Height="3" IsIndeterminate="True" Foreground="{StaticResource VmsPrimaryBrush_v3}" Background="{StaticResource VmsBorderBrush_v3}" Margin="0,5,0,0"/>
                    <TextBlock x:Name="LoadingText" Text="Đang kết nối..." Foreground="{StaticResource VmsTextSecondaryBrush_v3}" FontSize="11" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border x:Name="EmptyOverlay" Background="{StaticResource VmsSurfaceBrush_v3}" Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="□" FontSize="25" Foreground="{StaticResource VmsTextTertiaryBrush_v3}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Ô camera trống" FontSize="11" Foreground="{StaticResource VmsTextTertiaryBrush_v3}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <Border x:Name="ErrorOverlay" Background="{StaticResource VmsSurfaceBrush_v3}" Visibility="Collapsed" Padding="12">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="280">
                    <TextBlock Text="!" FontSize="28" FontWeight="Bold" Foreground="{StaticResource VmsErrorBrush_v3}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Lỗi kết nối" FontWeight="SemiBold" Foreground="{StaticResource VmsTextPrimaryBrush_v3}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    <TextBlock x:Name="ErrorText" Text="Kiểm tra mạng hoặc cấu hình camera." TextWrapping="Wrap" TextAlignment="Center" FontSize="11" Foreground="{StaticResource VmsTextSecondaryBrush_v3}" Margin="0,4,0,8"/>
                    <Button Content="Thử lại" Click="Retry_Click" Style="{StaticResource PrimaryButtonStyle_v3}" Padding="12,4"/>
                </StackPanel>
            </Border>

            <Popup x:Name="CameraBadgePopup" Placement="AbsolutePoint" AllowsTransparency="True" IsHitTestVisible="False" IsOpen="False">
            <Border x:Name="CameraBadge" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0" Padding="7,4" Background="{StaticResource VmsElevatedBrush_v3}" BorderBrush="{StaticResource VmsBorderStrongBrush_v3}" BorderThickness="1" CornerRadius="3">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="StatusDot" Width="7" Height="7" Fill="{StaticResource VmsOfflineBrush_v3}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="CameraName" Foreground="{StaticResource VmsTextInverseBrush_v3}" FontWeight="SemiBold" FontSize="11" TextTrimming="CharacterEllipsis" MaxWidth="210"/>
                </StackPanel>
            </Border>
            </Popup>

            <Popup x:Name="ActionPopup" Placement="AbsolutePoint" AllowsTransparency="True" StaysOpen="True" PopupAnimation="Fade">
            <Border x:Name="ActionBar" Panel.ZIndex="30" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0" Padding="3" Background="{StaticResource VmsElevatedBrush_v3}" BorderBrush="{StaticResource VmsPrimaryBorderBrush_v3}" BorderThickness="1" CornerRadius="5" Opacity="1" IsHitTestVisible="True" MouseEnter="ActionBar_MouseEnter" MouseLeave="ActionBar_MouseLeave">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="ConnectButton" Click="Connect_Click" Style="{StaticResource PrimaryButtonStyle_v3}" Padding="5,3" Margin="1" ToolTip="Kết nối camera"><Icon:PackIconMaterial Kind="Play" Width="13" Height="13"/></Button>
                    <Button x:Name="DisconnectButton" Click="Disconnect_Click" Style="{StaticResource SecondaryButtonStyle_v3}" Padding="5,3" Margin="1" ToolTip="Ngắt kết nối"><Icon:PackIconMaterial Kind="PowerPlugOff" Width="13" Height="13"/></Button>
                    <ComboBox x:Name="StreamSelector" Width="105" Height="26" DisplayMemberPath="StreamType" SelectionChanged="StreamSelector_SelectionChanged" Style="{StaticResource VmsComboBoxStyle_v3}" Margin="1" Visibility="Collapsed"/>
                    <Button x:Name="FullscreenButton" Click="Fullscreen_Click" Style="{StaticResource SecondaryButtonStyle_v3}" Width="28" Height="28" Padding="0" Margin="1" ToolTip="Toàn màn hình"><Icon:PackIconMaterial Kind="Fullscreen" Width="13" Height="13"/></Button>
                    <Button Click="Remove_Click" Style="{StaticResource SecondaryButtonStyle_v3}" Width="28" Height="28" Padding="0" Margin="1" Foreground="{StaticResource VmsErrorBrush_v3}" ToolTip="Xóa camera"><Icon:PackIconMaterial Kind="DeleteOutline" Width="13" Height="13"/></Button>
                </StackPanel>
            </Border>
            </Popup>
        </Grid>
    </Border>
</UserControl>
