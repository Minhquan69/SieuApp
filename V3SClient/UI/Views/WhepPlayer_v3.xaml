<UserControl x:Class="V3SClient.UI.Views.WhepPlayer_v3" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration" Background="{StaticResource VmsSurfaceBrush_v3}">
  <Grid>
    <wfi:WindowsFormsHost x:Name="VideoHost" />
    <Border x:Name="StatusPanel" Background="{StaticResource VmsSurfaceBrush_v3}">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock x:Name="StatusText" Foreground="{StaticResource VmsTextSecondaryBrush_v3}" Text="Select a camera to connect." HorizontalAlignment="Center" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
