<Page x:Class="V3SClient.UI.Views.VPlayback"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:V3SClient.UI.Views"
      xmlns:ucs="clr-namespace:V3SClient.ucs"
      mc:Ignorable="d"
      d:DesignHeight="800"
      d:DesignWidth="1200"
      Loaded="Page_Loaded"
      Title="Playback_page">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/styles/customize_button.xaml" />
                <ResourceDictionary Source="/styles/customize_image.xaml" />
                <ResourceDictionary Source="/styles/customize_textblock.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <BooleanToVisibilityConverter x:Key="BoolToVis" />
          
        </ResourceDictionary>
       
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>

        <!-- Left Side-->
        <Border Grid.Column="0">
            <Frame x:Name="frmLeftMenu" />

        </Border>
        <!-- Right Size-->
        <Frame x:Name="frmRightSide"
               Background="#0D0F12"
               Grid.Column="2">
        </Frame>
        
        <!-- Center zone-->
        <Border Grid.Column="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />  <!-- Video Grid -->
                    <RowDefinition Height="35" />  <!-- Bottom Controls -->
                </Grid.RowDefinitions>
                <!-- Vùng hiển thị các video-->
                <Grid x:Name="startPlayback"
                      Background="#0D0F12"
                      Grid.Row="0"   
                      Panel.ZIndex="10"  
                      >
                    <TextBlock Text="Please Select Cameras and Search to Playback "
                               Style="{StaticResource label_TextBlock}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               FontSize="20"
                               Foreground="#AAAAAA"
                               />

                </Grid>
                <Grid x:Name="gridCameraList"
                      Background="#0D0F12"
                      Grid.Row="0">
                </Grid>


                <!-- Vùng hiển thị các nút điều khiển-->
                <Grid Grid.Row="1" Background="#111318">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="350" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                Opacity="0.7"
                                VerticalAlignment="Center"
                                Margin="10,0,0,0"
                                >
                        <Button x:Name="btnDownload"
                                Click="btnDownload_Click"
                                Visibility="Collapsed"
                                VerticalAlignment="Center"
                                Margin="0,0,10,0"
                                Style="{StaticResource Transparent_Button}"
                                ToolTip="Download Selection">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/images/downloads/download.png"
                                       Width="20" Height="20"
                                       Style="{StaticResource Transparent_Image}" />
                                <TextBlock Text="Download"
                                           Style="{StaticResource label_TextBlock}"
                                           VerticalAlignment="Center"
                                           Margin="5,0,0,0" />
                            </StackPanel>
                        </Button>

                        <TextBlock Style="{StaticResource label_TextBlock}"
                                   Text="Cam: 0"
                                   VerticalAlignment="Center"
                                   x:Name="txtTotalCam" 
                                   />

                    </StackPanel>
                    <!-- center control buttons-->
                    <UniformGrid Grid.Column="1"
                                 Opacity="0.7"
                                 Columns="5"
                                 Rows="1"
                                 VerticalAlignment="Center">
                        <Button x:Name="btnPrevious"
                                Click="PlaybackControl"
                                Style="{StaticResource Transparent_Button}">
                            <Image Source="/images/videocontrols/previous15.png"
                                   Style="{StaticResource Transparent_Image}" ToolTip="- Giảm tốc độ phát"/>
                        </Button>
                        <Button x:Name="btnSeekBack"
                                Click="PlaybackControl"
                                Style="{StaticResource Transparent_Button}" ToolTip=" Dịch chuyển -">
                            <Image Source="/images/videocontrols/previous.png"
                                   Style="{StaticResource Transparent_Image}" />
                        </Button>
                        <Button x:Name="btnPlay"
                                Click="PlaybackControl"
                                Style="{StaticResource Transparent_Button}" ToolTip="Phát/Dừng video">
                            <Image x:Name="playImage"
                                   Source="/images/videocontrols/play.png"
                                   Style="{StaticResource Transparent_Image}" />
                        </Button>
                        <Button x:Name="btnSeekForward"
                                Click="PlaybackControl"
                                Style="{StaticResource Transparent_Button}" ToolTip=" Dịch chuyển +">
                            <Image Style="{StaticResource Transparent_Image}"
                                   Source="/images/videocontrols/forward.png" />
                        </Button>
                        <Button x:Name="btnForward"
                                Click="PlaybackControl"
                                Style="{StaticResource Transparent_Button}" ToolTip="+ Tăng tốc độ phát">
                            <Image Style="{StaticResource Transparent_Image}"
                                   Source="/images/videocontrols/forward15.png" />
                        </Button>

                    </UniformGrid>

                    <StackPanel Grid.Column="2"
                                Margin="0,0,10,0"
                                VerticalAlignment="Bottom"
                                HorizontalAlignment="Right"
                                Opacity="0.7"
                                >
                        <StackPanel Orientation="Horizontal">
                        </StackPanel>

                        <TextBlock Style="{StaticResource label_TextBlock}"
                                   VerticalAlignment="Center"
                                   x:Name="txtCurrentRate" 
                                   />
                    </StackPanel>
                </Grid>
            
            </Grid>
        </Border>
    </Grid>
</Page>
