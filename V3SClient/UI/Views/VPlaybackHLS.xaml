<Page x:Class="V3SClient.UI.Views.VPlaybackHLS"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:V3SClient.UI.Views"
      xmlns:ucs="clr-namespace:V3SClient.ucs"
      mc:Ignorable="d"
      d:DesignHeight="800"
      d:DesignWidth="1200"
      Loaded="Page_Loaded"
      Title="Playback_HLS_page">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/styles/customize_button.xaml" />
                <ResourceDictionary Source="/styles/customize_image.xaml" />
                <ResourceDictionary Source="/styles/customize_textblock.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <BooleanToVisibilityConverter x:Key="BoolToVis" />

            <Style x:Key="PlaybackDownloadContextMenuStyle"
                   TargetType="{x:Type ContextMenu}">
                <Setter Property="Background"
                        Value="#1B2029" />
                <Setter Property="BorderBrush"
                        Value="#3A4656" />
                <Setter Property="BorderThickness"
                        Value="1" />
                <Setter Property="Padding"
                        Value="4" />
                <Setter Property="MinWidth"
                        Value="230" />
                <Setter Property="SnapsToDevicePixels"
                        Value="True" />
                <Setter Property="OverridesDefaultStyle"
                        Value="True" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ContextMenu}">
                            <Border Background="#1B2029"
                                    BorderBrush="#3A4656"
                                    BorderThickness="1"
                                    SnapsToDevicePixels="True">
                                <StackPanel Margin="4"
                                            IsItemsHost="True"
                                            KeyboardNavigation.DirectionalNavigation="Cycle" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="PlaybackDownloadMenuItemStyle"
                   TargetType="{x:Type MenuItem}">
                <Setter Property="Foreground"
                        Value="#E8ECF1" />
                <Setter Property="Background"
                        Value="Transparent" />
                <Setter Property="Padding"
                        Value="8,6" />
                <Setter Property="FontSize"
                        Value="12" />
                <Setter Property="MinHeight"
                        Value="30" />
                <Setter Property="HorizontalContentAlignment"
                        Value="Stretch" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type MenuItem}">
                            <Border x:Name="MenuItemBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted"
                                         Value="True">
                                    <Setter TargetName="MenuItemBorder"
                                            Property="Background"
                                            Value="#293241" />
                                </Trigger>
                                <Trigger Property="IsEnabled"
                                         Value="False">
                                    <Setter Property="Opacity"
                                            Value="0.45" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="PlaybackDownloadSeparatorStyle"
                   TargetType="{x:Type Separator}">
                <Setter Property="Margin"
                        Value="6,4" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Separator}">
                            <Border Height="1"
                                    Background="#334050" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
          
        </ResourceDictionary>
       
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>

        <!-- Left Side-->
        <Border Grid.Column="0">
            <Frame x:Name="frmLeftMenu" />

        </Border>
        <!-- Right Size-->
        <Frame x:Name="frmRightSide"
               Background="#0D0F12"
               Grid.Column="2">
        </Frame>
        
        <!-- Center zone-->
        <Border Grid.Column="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />  <!-- Video Grid -->
                    <RowDefinition x:Name="AggregateTimelineRowDefinition"
                                   Height="70" />  <!-- Aggregate Timeline -->
                </Grid.RowDefinitions>
                <!-- VÃ¹ng hiá»ƒn thá»‹ cÃ¡c video-->
                <Grid x:Name="startPlayback"
                      Background="#0D0F12"
                      Grid.Row="0"   
                      Panel.ZIndex="10"  
                      >
                    <TextBlock Text="Please Select Cameras and Search to Playback "
                               Style="{StaticResource label_TextBlock}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               FontSize="20"
                               Foreground="#AAAAAA"
                               />

                </Grid>
                <Grid x:Name="gridCameraList"
                      Background="#0D0F12"
                      Grid.Row="0">
                </Grid>


                <!-- VÃ¹ng hiá»ƒn thá»‹ cÃ¡c nÃºt Ä‘iá»u khiá»ƒn-->
                <Grid Grid.Row="1" Background="#111318">
                    <Canvas x:Name="aggregateTimelineCanvas"
                            Margin="0,1,8,1"
                            Background="#111318"
                            ClipToBounds="True"
                            SizeChanged="AggregateTimelineCanvas_SizeChanged"
                            MouseLeftButtonDown="AggregateTimelineCanvas_MouseLeftButtonDown"
                            MouseMove="AggregateTimelineCanvas_MouseMove"
                            MouseLeftButtonUp="AggregateTimelineCanvas_MouseLeftButtonUp"
                            MouseRightButtonUp="AggregateTimelineCanvas_MouseRightButtonUp" />

                    <Grid Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="350" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                Opacity="0.7"
                                VerticalAlignment="Center"
                                Margin="10,0,0,0"
                                >
                        <Button x:Name="btnDownload"
                                Click="btnDownload_Click"
                                Visibility="Collapsed"
                                VerticalAlignment="Center"
                                Margin="0,0,10,0"
                                Style="{StaticResource Transparent_Button}"
                                ToolTip="Download Selection">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/images/downloads/download.png"
                                       Width="20" Height="20"
                                       Style="{StaticResource Transparent_Image}" />
                                <TextBlock Text="Download"
                                           Style="{StaticResource label_TextBlock}"
                                           VerticalAlignment="Center"
                                           Margin="5,0,0,0" />
                            </StackPanel>
                        </Button>

                        <TextBlock Style="{StaticResource label_TextBlock}"
                                   Text="Cam: 0"
                                   VerticalAlignment="Center"
                                   x:Name="txtTotalCam" 
                                   />

                    </StackPanel>
                    <!-- center control buttons-->
                    <UniformGrid Grid.Column="1"
                                 Opacity="0.7"
                                 Columns="5"
                                 Rows="1"
                                 VerticalAlignment="Center">
                        <Button x:Name="btnPrevious"
                                Click="PlaybackControl"
                                Style="{StaticResource Transparent_Button}">
                            <Image Source="/images/videocontrols/previous15.png"
                                   Style="{StaticResource Transparent_Image}" ToolTip="- Giáº£m tá»‘c Ä‘á»™ phÃ¡t"/>
                        </Button>
                        <Button x:Name="btnSeekBack"
                                Click="PlaybackControl"
                                Style="{StaticResource Transparent_Button}" ToolTip=" Dá»‹ch chuyá»ƒn -">
                            <Image Source="/images/videocontrols/previous.png"
                                   Style="{StaticResource Transparent_Image}" />
                        </Button>
                        <Button x:Name="btnPlay"
                                Click="PlaybackControl"
                                Style="{StaticResource Transparent_Button}" ToolTip="PhÃ¡t/Dá»«ng video">
                            <Image x:Name="playImage"
                                   Source="/images/videocontrols/play.png"
                                   Style="{StaticResource Transparent_Image}" />
                        </Button>
                        <Button x:Name="btnSeekForward"
                                Click="PlaybackControl"
                                Style="{StaticResource Transparent_Button}" ToolTip=" Dá»‹ch chuyá»ƒn +">
                            <Image Style="{StaticResource Transparent_Image}"
                                   Source="/images/videocontrols/forward.png" />
                        </Button>
                        <Button x:Name="btnForward"
                                Click="PlaybackControl"
                                Style="{StaticResource Transparent_Button}" ToolTip="+ TÄƒng tá»‘c Ä‘á»™ phÃ¡t">
                            <Image Style="{StaticResource Transparent_Image}"
                                   Source="/images/videocontrols/forward15.png" />
                        </Button>

                    </UniformGrid>

                    <StackPanel Grid.Column="2"
                                Margin="0,0,10,0"
                                VerticalAlignment="Bottom"
                                HorizontalAlignment="Right"
                                Opacity="0.7"
                                >
                        <StackPanel Orientation="Horizontal">
                        </StackPanel>

                        <TextBlock Style="{StaticResource label_TextBlock}"
                                   VerticalAlignment="Center"
                                   x:Name="txtCurrentRate" 
                                   />
                    </StackPanel>
                </Grid>
            
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
