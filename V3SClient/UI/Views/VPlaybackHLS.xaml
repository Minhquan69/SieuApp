<Page x:Class="V3SClient.UI.Views.VPlaybackHLS"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
      xmlns:local="clr-namespace:V3SClient.UI.Views"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="800"
      d:DesignWidth="1200"
      Loaded="Page_Loaded"
      Title="Playback_HLS_page"
      Background="{StaticResource VmsBackgroundBrush_v3}">
    <Page.Resources>
        <Style x:Key="PlaybackToolbarButton_v3" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle_v3}">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="MinHeight" Value="28"/>
        </Style>
        <Style x:Key="PlaybackFieldLabel_v3" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource VmsTextTertiaryBrush_v3}"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="PlaybackDownloadContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="{StaticResource VmsSurfaceBrush_v3}"/>
            <Setter Property="BorderBrush" Value="{StaticResource VmsBorderBrush_v3}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="PlaybackDownloadMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource VmsTextPrimaryBrush_v3}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="9,6"/>
        </Style>
        <Style x:Key="PlaybackDownloadSeparatorStyle" TargetType="Separator">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="{StaticResource VmsBorderBrush_v3}"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- The toolbar mirrors the web hierarchy. Search selection/time is
             still hosted by the existing LeftMenu/ViewSearch control on the
             right, so no playback API or event contract is changed. -->
        <Border x:Name="PlaybackControlHeader" Grid.Row="0" Background="{StaticResource VmsHeaderBrush_v3}" BorderBrush="{StaticResource VmsBorderBrush_v3}" BorderThickness="0,0,0,1" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="28" Height="28" CornerRadius="6" Background="{StaticResource VmsPrimarySoftBrush_v3}" BorderBrush="{StaticResource VmsPrimaryBorderBrush_v3}" BorderThickness="1" Margin="0,0,8,0">
                        <Icon:PackIconMaterial Kind="PlayCircleOutline" Width="17" Height="17" Foreground="{StaticResource VmsPrimaryBrush_v3}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="PHÁT LẠI" Style="{StaticResource PlaybackFieldLabel_v3}"/>
                        <TextBlock x:Name="txtTotalCam" Text="Chưa chọn camera" Foreground="{StaticResource VmsTextPrimaryBrush_v3}" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>

                <Frame x:Name="frmSearchToolbar" Grid.Column="1" NavigationUIVisibility="Hidden" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="PlaybackSidebarOpenButton" Width="34" Height="34" Visibility="Collapsed" Click="TogglePlaybackSidebar_Click" ToolTip="Open camera list" Style="{StaticResource PlaybackToolbarButton_v3}">
                        <Icon:PackIconMaterial Kind="ChevronLeft" Width="20" Height="20"/>
                    </Button>
                    <Button x:Name="btnDownload" Click="btnDownload_Click" Visibility="Collapsed" Style="{StaticResource PlaybackToolbarButton_v3}" ToolTip="Tải video đã chọn">
                        <StackPanel Orientation="Horizontal"><Icon:PackIconMaterial Kind="DownloadOutline" Width="15" Height="15"/><TextBlock Text="Tải xuống" Margin="5,0,0,0"/></StackPanel>
                    </Button>
                    <TextBlock x:Name="txtCurrentRate" Foreground="{StaticResource VmsTextSecondaryBrush_v3}" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="PlaybackSidebarColumn" Width="280" MinWidth="0" MaxWidth="340"/>
                <ColumnDefinition Width="0"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition x:Name="AggregateTimelineRowDefinition" Height="108"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="Black" BorderBrush="{StaticResource VmsBorderBrush_v3}" BorderThickness="1" CornerRadius="6" ClipToBounds="True">
                    <Grid>
                        <Grid x:Name="gridCameraList" Background="Black"/>
                        <Grid x:Name="startPlayback" Background="{StaticResource VmsSurfaceBrush_v3}" Panel.ZIndex="10">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Border Width="42" Height="42" CornerRadius="21" Background="{StaticResource VmsSurface2Brush_v3}" BorderBrush="{StaticResource VmsBorderBrush_v3}" BorderThickness="1" HorizontalAlignment="Center">
                                    <Icon:PackIconMaterial Kind="PlayCircleOutline" Width="25" Height="25" Foreground="{StaticResource VmsTextSecondaryBrush_v3}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Chọn camera và tìm kiếm để xem phát lại" Foreground="{StaticResource VmsTextSecondaryBrush_v3}" FontSize="13" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Overlay only: this does not reserve a grid row or resize cameras. -->
                <!-- Legacy WPF toolbar is retained only as disabled markup while
                     the native overlay is used for GStreamer HWND airspace. -->
                <!--
                <Border x:Name="GlobalPlaybackToolbar" Grid.Row="0" Panel.ZIndex="50" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,12" Background="{StaticResource VmsSurfaceBrush_v3}" BorderBrush="{StaticResource VmsBorderBrush_v3}" BorderThickness="1" CornerRadius="5" Padding="4"
                        MouseEnter="GlobalPlaybackToolbar_MouseEnter" MouseLeave="GlobalPlaybackToolbar_MouseLeave">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="btnPrevious" Click="PlaybackControl" Style="{StaticResource PlaybackToolbarButton_v3}" ToolTip="Giảm tốc độ"><Icon:PackIconMaterial Kind="Rewind10" Width="15" Height="15"/></Button>
                        <Button x:Name="btnSeekBack" Click="PlaybackControl" Style="{StaticResource PlaybackToolbarButton_v3}" ToolTip="Lùi"><Icon:PackIconMaterial Kind="SkipPrevious" Width="15" Height="15"/></Button>
                        <Button x:Name="btnPlay" Click="PlaybackControl" Style="{StaticResource PlaybackToolbarButton_v3}" ToolTip="Phát/Dừng"><Image x:Name="playImage" Source="/images/videocontrols/play.png" Width="15" Height="15"/></Button>
                        <Button x:Name="btnSeekForward" Click="PlaybackControl" Style="{StaticResource PlaybackToolbarButton_v3}" ToolTip="Tiến"><Icon:PackIconMaterial Kind="SkipNext" Width="15" Height="15"/></Button>
                        <Button x:Name="btnForward" Click="PlaybackControl" Style="{StaticResource PlaybackToolbarButton_v3}" ToolTip="Tăng tốc độ"><Icon:PackIconMaterial Kind="FastForward10" Width="15" Height="15"/></Button>
                        <Separator Width="1" Margin="5,2" Background="{StaticResource VmsBorderBrush_v3}"/>
                        <Button Click="GlobalPlaybackAction_Click" Tag="AiAll" Style="{StaticResource PlaybackToolbarButton_v3}" ToolTip="Bật/tắt AI tất cả camera"><TextBlock Text="AI" FontSize="10" FontWeight="Bold" Foreground="{StaticResource VmsPrimaryBrush_v3}"/></Button>
                        <Button Click="GlobalPlaybackAction_Click" Tag="SnapshotAll" Style="{StaticResource PlaybackToolbarButton_v3}" ToolTip="Chụp ảnh tất cả camera"><Icon:PackIconMaterial Kind="CameraOutline" Width="15" Height="15"/></Button>
                        <Button Click="GlobalPlaybackAction_Click" Tag="DownloadAll" Style="{StaticResource PlaybackToolbarButton_v3}" ToolTip="Tải video tất cả camera"><Icon:PackIconMaterial Kind="DownloadOutline" Width="15" Height="15"/></Button>
                    </StackPanel>
                </Border>
                -->

                <!-- The native toolbar host is added here after Page.Loaded.  It is a
                     sibling of the GStreamer hosts, so it overlays video without
                     changing the size of the grid. -->
                <Grid x:Name="NativePlaybackToolbarLayer" Grid.Row="0" Panel.ZIndex="60" IsHitTestVisible="True"/>

                <Border Grid.Row="1" Margin="0,6,0,0" Background="{StaticResource VmsSurfaceBrush_v3}" BorderBrush="{StaticResource VmsBorderBrush_v3}" BorderThickness="1" CornerRadius="6" Padding="8">
                    <Grid>
                        <Canvas x:Name="aggregateTimelineCanvas"
                                Background="{StaticResource VmsSurfaceBrush_v3}"
                                ClipToBounds="True"
                                SizeChanged="AggregateTimelineCanvas_SizeChanged"
                                MouseLeftButtonDown="AggregateTimelineCanvas_MouseLeftButtonDown"
                                MouseMove="AggregateTimelineCanvas_MouseMove"
                                MouseLeave="AggregateTimelineCanvas_MouseLeave"
                                MouseLeftButtonUp="AggregateTimelineCanvas_MouseLeftButtonUp"
                                MouseRightButtonUp="AggregateTimelineCanvas_MouseRightButtonUp"/>
                    </Grid>
                </Border>
            </Grid>

            <Border x:Name="PlaybackSidebar" Grid.Column="1" Background="{StaticResource VmsSidebarBrush_v3}" BorderBrush="{StaticResource VmsBorderBrush_v3}" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Border Background="{StaticResource VmsHeaderBrush_v3}" BorderBrush="{StaticResource VmsBorderBrush_v3}" BorderThickness="0,0,0,1" Padding="11,10">
                        <Grid>
                            <StackPanel Orientation="Horizontal"><Icon:PackIconMaterial Kind="VideoOutline" Width="16" Height="16" Foreground="{StaticResource VmsPrimaryBrush_v3}" Margin="0,0,7,0"/><TextBlock Text="Danh sách camera" Foreground="{StaticResource VmsTextPrimaryBrush_v3}" FontWeight="SemiBold" FontSize="13"/></StackPanel>
                            <Button HorizontalAlignment="Right" Width="27" Height="27" Padding="0" Click="TogglePlaybackSidebar_Click" ToolTip="Đóng danh sách camera" Style="{StaticResource PlaybackToolbarButton_v3}"><Icon:PackIconMaterial Kind="ChevronRight" Width="18" Height="18"/></Button>
                        </Grid>
                    </Border>
                    <local:PlaybackCameraList_v3 x:Name="PlaybackCameraList" Grid.Row="1"/>
                </Grid>
            </Border>

            <!-- Retained for the current playback/AI-log workflow. It stays
                 loaded by code-behind but is not part of the web playback UI. -->
            <Frame x:Name="frmRightSide" Grid.Column="2" Visibility="Collapsed" NavigationUIVisibility="Hidden"/>
        </Grid>

        <Border x:Name="PlaybackToast" Grid.Row="0" Grid.RowSpan="2" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,18,18,0" Width="350" Visibility="Collapsed" Panel.ZIndex="100" Background="{StaticResource VmsSurfaceBrush_v3}" BorderBrush="{StaticResource VmsBorderStrongBrush_v3}" BorderThickness="1" CornerRadius="9" Padding="0">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="5"/><ColumnDefinition Width="44"/><ColumnDefinition Width="*"/><ColumnDefinition Width="32"/></Grid.ColumnDefinitions>
                <Border x:Name="PlaybackToastAccent" Grid.Column="0" Background="{StaticResource VmsInfoBrush_v3}" CornerRadius="9,0,0,9"/>
                <Border Grid.Column="1" Width="30" Height="30" CornerRadius="15" Background="{StaticResource VmsPrimarySoftBrush_v3}" HorizontalAlignment="Center" VerticalAlignment="Center"><Icon:PackIconMaterial x:Name="PlaybackToastIcon" Kind="InformationOutline" Width="19" Height="19" Foreground="{StaticResource VmsInfoBrush_v3}" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                <StackPanel Grid.Column="2" Margin="0,13,4,13" VerticalAlignment="Center"><TextBlock x:Name="PlaybackToastTitle" Foreground="{StaticResource VmsTextPrimaryBrush_v3}" FontWeight="SemiBold" FontSize="13"/><TextBlock x:Name="PlaybackToastMessage" Foreground="{StaticResource VmsTextSecondaryBrush_v3}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/></StackPanel>
                <Button Grid.Column="3" Click="ClosePlaybackToast_Click" Width="28" Height="28" Padding="0" Margin="0,7,6,0" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Foreground="{StaticResource VmsTextSecondaryBrush_v3}" ToolTip="Đóng thông báo"><Icon:PackIconMaterial Kind="Close" Width="16" Height="16"/></Button>
            </Grid>
        </Border>
    </Grid>
</Page>
