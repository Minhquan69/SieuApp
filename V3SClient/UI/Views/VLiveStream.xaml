<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="clr-namespace:V3SClient.UI.Views"
      xmlns:ucs="clr-namespace:V3SClient.ucs"
      x:Class="V3SClient.UI.Views.VLiveStream"
      mc:Ignorable="d"
      d:DesignHeight="640"
      d:DesignWidth="800">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/styles/border_reseted.xaml" />
                <ResourceDictionary Source="/styles/customize_combobox_mini.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>


    <Grid Background="#111318">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="2" x:Name="colRightSplitter"/>
            <ColumnDefinition Width="auto" x:Name="colRightMenu"/>
        </Grid.ColumnDefinitions>

        <Frame x:Name="frameLeftMenu"
               Grid.Column="0"
               Background="Transparent">

        </Frame>
        
        <GridSplitter Grid.Column="2" Width="2" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="#252830" Margin="0,0,0,0" ShowsPreview="True" Cursor="SizeWE"/>
        
        <Frame x:Name="frmRightSide"
               Background="#0D0F12"
               Grid.Column="3">
        </Frame>


        <!-- Định vùng hiển thị Cam-->
        <Border Grid.Column="1"
                Style="{StaticResource Border_Reseted}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="30" />
                </Grid.RowDefinitions>
                <!--Camera list-->
                <Grid Grid.Row="0" Background="#0D0F12"
                      x:Name="gridCameraList"
                      Panel.ZIndex="1">
                    
                    
                </Grid>
                
                
                <!--Bottom Bar-->

                <Border Grid.Row="1"
                        Style="{StaticResource Border_Reseted}"
                        Padding="2,2,2,2"
                        Background="Transparent"
                        BorderThickness="0,2,0,0"
                        BorderBrush="#252830">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="TalkStatusBorder" Grid.Column="0"
                                Visibility="Collapsed"
                                BorderThickness="1"
                                BorderBrush="#666666"
                                CornerRadius="3">
                            <Border.Background>
                                <SolidColorBrush Color="#1E2230"
                                                 Opacity="0.9" />
                            </Border.Background>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Left">
                                <Image Source="/images/mic_on.png" Stretch="Uniform" />
                                <TextBlock Text="Talk:  "
                                           Style="{StaticResource General_TextBlock}"
                                           Foreground="#DDDDDD"
                                           />
                                <TextBlock x:Name="txtTalk2Group"
                                           Text=""
                                           Style="{StaticResource General_TextBlock}"
                                           FontWeight="Medium" />
                            </StackPanel>

                        </Border>
                        
                        <!-- Góc bên Phải màn hình-->

                        <Border Grid.Column="2"
                                BorderThickness="0"
                                BorderBrush="#666666"
                                CornerRadius="3"
                                HorizontalAlignment="Right"
                                
                                >
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Image x:Name="imgActionIcon" Source="/images/mouse_action.png" Width="20" Height="20" Margin="0,0,15,0" Cursor="Hand" ToolTip="Hành động" MouseLeftButtonUp="ActionIcon_MouseLeftButtonUp">
                                    <Image.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Kết nối tất cả" Click="MenuAction_ConnectAll_Click">
                                                <MenuItem.Icon>
                                                    <Image Source="/images/cam_online.png" Width="16" Height="16"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Ngắt kết nối tất cả" Click="MenuAction_DisconnectAll_Click">
                                                <MenuItem.Icon>
                                                    <Image Source="/images/cam_offline.png" Width="16" Height="16"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Xóa tất cả" Click="MenuAction_ClearAll_Click">
                                                <MenuItem.Icon>
                                                    <Image Source="/images/close.png" Width="16" Height="16"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </Image.ContextMenu>
                                </Image>
                                <!-- Icon hiển thị layout hiện tại -->
                                <Image x:Name="imgLayoutIcon" Source="/images/layout/layout_1.png" Width="24" Height="24" Cursor="Hand" ToolTip="Tùy chỉnh layout hiển thị">
                                    <Image.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Layout 1x1"  Tag="{x:Static local:LayoutPreset.layout_1x1}" Click="MenuLayout_Click" >
                                                <MenuItem.Icon>
                                                    <Image Source="/images/layout/layout_1.png" Width="16" Height="16"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Layout 2x2"  Tag="{x:Static local:LayoutPreset.layout_2x2}" Click="MenuLayout_Click">
                                                <MenuItem.Icon>
                                                    <Image Source="/images/layout/layout_2x2.png" Width="16" Height="16"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Layout 5+1" Tag="{x:Static local:LayoutPreset.layout_6_1big}" Click="MenuLayout_Click">
                                                <MenuItem.Icon>
                                                    <Image Source="/images/layout/layout_6_1big.png" Width="16" Height="16"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Layout 3x3" Tag="{x:Static local:LayoutPreset.layout_3x3}" Click="MenuLayout_Click">
                                                <MenuItem.Icon>
                                                    <Image Source="/images/layout/layout_3x3.png" Width="16" Height="16"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Layout 15 +1" Tag="{x:Static local:LayoutPreset.layout_15_1big}" Click="MenuLayout_Click">
                                                <MenuItem.Icon>
                                                    <Image Source="/images/layout/layout_13_1big.png" Width="16" Height="16"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Layout 6x6" Tag="{x:Static local:LayoutPreset.layout_6x6}" Click="MenuLayout_Click">
                                                <MenuItem.Icon>
                                                    <Image Source="/images/layout/layout_4x4.png" Width="16" Height="16"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Layout tuỳ chỉnh" Tag="{x:Static local:LayoutPreset.layout_custom}" Click="MenuLayout_Click">
                                                <MenuItem.Icon>
                                                    <Image Source="/images/layout/layout_custom.png" Width="16" Height="16"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </Image.ContextMenu>
                                </Image>
                            </StackPanel>

                        </Border>
                        
                        
                    </Grid>

                </Border>
            </Grid>
        </Border>



    </Grid>
</Page>
