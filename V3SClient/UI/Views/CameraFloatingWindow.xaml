<Window x:Class="V3SClient.UI.Views.CameraFloatingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Camera Live" 
        Width="380" Height="300"
        WindowStyle="None" 
        Background="#1A1A1A"
        ShowInTaskbar="False" Topmost="False"
        ResizeMode="CanResizeWithGrip">
    
    <Border x:Name="mainBorder" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="4">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="270" Opacity="0.5" ShadowDepth="3"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Background="#111111" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <!-- Accent bar bên trái -->
                    <Border Background="#E87E04" Width="3" HorizontalAlignment="Left"/>
                    
                    <TextBlock x:Name="txtCamName" Foreground="#CCC" FontWeight="SemiBold" FontSize="12"
                               Margin="12,0,120,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,3,0">
                        <!-- Opacity Slider -->
                        <TextBlock Text="●" Foreground="#666" VerticalAlignment="Center" Margin="0,0,2,0" FontSize="11" ToolTip="Độ trong suốt"/>
                        <Slider x:Name="opacitySlider" Width="50" Minimum="0.3" Maximum="1.0" Value="1.0" 
                                VerticalAlignment="Center" Margin="0,0,4,0" ToolTip="Độ trong suốt"
                                ValueChanged="OpacitySlider_ValueChanged"/>
                        <!-- Minimize/Collapse -->
                        <Button x:Name="btnMinimize" Content="▬" Width="22" Height="22" 
                                Background="Transparent" Foreground="#888" FontSize="8"
                                BorderThickness="0" Click="BtnMinimize_Click" Cursor="Hand" ToolTip="Thu gọn / Mở rộng"/>
                        <!-- Close -->
                        <Button Content="✕" Width="22" Height="22" 
                                Background="Transparent" Foreground="#E87E04" FontSize="10"
                                BorderThickness="0" Click="BtnClose_Click" Cursor="Hand" ToolTip="Đóng"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Camera View -->
            <Grid x:Name="gridCameraView" Grid.Row="1" Background="Black" Margin="1,0,1,1"/>
        </Grid>
    </Border>
</Window>
