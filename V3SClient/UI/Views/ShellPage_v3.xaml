<UserControl x:Class="V3SClient.UI.Views.ShellPage_v3"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ucs="clr-namespace:V3SClient.ucs"
             xmlns:converters="clr-namespace:V3SClient.UI.Converters"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             Background="{StaticResource VmsBackgroundBrush_v3}">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility_v3" />
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="ShellSidebarColumn" Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <ucs:SidebarControl_v3 x:Name="ShellSidebar"/>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="ShellHeaderRow" Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <ucs:HeaderControl_v3 x:Name="ShellHeader"/>
            <ContentControl x:Name="ContentFrame" Grid.Row="1"/>
        </Grid>

        <!-- A Popup creates its own HWND, so native GStreamer/WinForms video cannot cover this persistent progress. -->
        <Border x:Name="GlobalDownloadProgressAnchor_v3"
                Grid.ColumnSpan="2"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,20,20"
                Width="0" Height="0"
                IsHitTestVisible="False" />
        <primitives:Popup x:Name="GlobalDownloadProgressPopup_v3"
                          PlacementTarget="{Binding ElementName=GlobalDownloadProgressAnchor_v3}"
                          Placement="Top"
                          StaysOpen="True"
                          AllowsTransparency="False"
                          IsOpen="{Binding HasActiveDownloads, Mode=OneWay}">
            <Border x:Name="GlobalDownloadProgressPanel_v3"
                Width="340"
                Padding="16"
                Background="{StaticResource VmsElevatedBrush_v3}"
                BorderBrush="{StaticResource VmsBorderStrongBrush_v3}"
                BorderThickness="1"
                CornerRadius="8"
                Opacity="0.94">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Đang tải video" Foreground="{StaticResource VmsTextPrimaryBrush_v3}" FontWeight="SemiBold" FontSize="14"/>
                <Button Grid.Column="1" Content="Hủy" Click="CancelGlobalDownload_Click"
                        Padding="10,4" Margin="12,0,0,0"
                        Background="{StaticResource VmsErrorBrush_v3}" Foreground="{StaticResource VmsTextInverseBrush_v3}"
                        BorderThickness="0"/>
                <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Margin="0,9,0,0"
                           Text="{Binding ActiveDownload.CameraNames}"
                           Foreground="{StaticResource VmsTextPrimaryBrush_v3}" TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Margin="0,4,0,6"
                           Text="{Binding ActiveDownload.StatusText}"
                           Foreground="{StaticResource VmsTextSecondaryBrush_v3}" TextTrimming="CharacterEllipsis"/>
                <ProgressBar Grid.Row="3" Grid.ColumnSpan="2" Height="6" Minimum="0" Maximum="100"
                             Value="{Binding ActiveDownload.Progress}" Foreground="{StaticResource VmsPrimaryBrush_v3}"
                             Background="{StaticResource VmsSurface3Brush_v3}"/>
            </Grid>
            </Border>
        </primitives:Popup>
    </Grid>
</UserControl>
