<Page x:Class="V3SClient.UI.Views.LoginPage_v3"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignWidth="780"
      d:DesignHeight="460"
      Background="{StaticResource VmsBackgroundBrush_v3}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.15*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource VmsSidebarBrush_v3}" Padding="42">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="iVista VMS" Foreground="{StaticResource VmsTextPrimaryBrush_v3}" FontSize="30" FontWeight="SemiBold" />
                <TextBlock Text="Professional video monitoring" Foreground="{StaticResource VmsPrimaryBrush_v3}" FontSize="16" Margin="0,10,0,0" />
                <TextBlock Text="Secure access to cameras, system status, and centralized monitoring."
                           Foreground="{StaticResource VmsTextSecondaryBrush_v3}"
                           FontSize="14"
                           TextWrapping="Wrap"
                           LineHeight="22"
                           Margin="0,24,0,0" />
                <Border Style="{StaticResource VmsCardBorderStyle_v3}" Margin="0,34,0,0" Background="{StaticResource VmsSurfaceBrush_v3}">
                    <StackPanel>
                        <TextBlock Text="Secure" Foreground="{StaticResource VmsTextPrimaryBrush_v3}" FontWeight="SemiBold" />
                        <TextBlock Text="Reliable authenticated access" Foreground="{StaticResource VmsTextSecondaryBrush_v3}" Margin="0,5,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Background="{StaticResource VmsBackgroundBrush_v3}" Margin="34">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Welcome back" Foreground="{StaticResource VmsTextPrimaryBrush_v3}" FontSize="25" FontWeight="SemiBold" />
                <TextBlock Text="Sign in to continue" Foreground="{StaticResource VmsTextSecondaryBrush_v3}" Margin="0,6,0,22" />

                <Border Background="{StaticResource VmsErrorSoftBrush_v3}" BorderBrush="{StaticResource VmsErrorBrush_v3}" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,14">
                    <Border.Style>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers><DataTrigger Binding="{Binding HasError}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource VmsTextPrimaryBrush_v3}" TextWrapping="Wrap" />
                </Border>

                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="{x:Type StackPanel}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers><DataTrigger Binding="{Binding IsProfileSelectionVisible}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Profile" Foreground="{StaticResource VmsTextSecondaryBrush_v3}" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <ComboBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}" DisplayMemberPath="Name" Style="{StaticResource VmsComboBoxStyle_v3}" ItemContainerStyle="{StaticResource VmsComboBoxItemStyle_v3}" />
                    <TextBlock Text="{Binding SelectedProfile.Code}" Foreground="{StaticResource VmsTextTertiaryBrush_v3}" Margin="0,6,0,18" />
                    <Button Content="Enter system" Command="{Binding ContinueCommand}" Style="{StaticResource PrimaryButtonStyle_v3}" />
                </StackPanel>

                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="{x:Type StackPanel}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers><DataTrigger Binding="{Binding IsProfileSelectionVisible}" Value="True"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger></Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Username" Foreground="{StaticResource VmsTextSecondaryBrush_v3}" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource VmsTextBoxStyle_v3}" Margin="0,0,0,15" />
                    <TextBlock Text="Password" Foreground="{StaticResource VmsTextSecondaryBrush_v3}" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <PasswordBox x:Name="PasswordInput" MinHeight="32" Padding="9,5" Background="{StaticResource VmsSurface2Brush_v3}" BorderBrush="{StaticResource VmsBorderBrush_v3}" BorderThickness="1" Foreground="{StaticResource VmsTextPrimaryBrush_v3}" PasswordChanged="PasswordInput_OnPasswordChanged" Margin="0,0,0,20" />
                    <Button Content="Sign in" Command="{Binding LoginCommand}" Style="{StaticResource PrimaryButtonStyle_v3}" />
                </StackPanel>

                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource VmsTextSecondaryBrush_v3}" Margin="0,14,0,0" HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
