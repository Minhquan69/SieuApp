<Page x:Class="V3SClient.UI.Views.DOC_SCAN"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:models="clr-namespace:V3SClient.models"
      xmlns:converters="clr-namespace:V3SClient.UI.Converters"
      mc:Ignorable="d"
      d:DesignHeight="700"
      d:DesignWidth="1200"
      Title="Quản lý quét tài liệu">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/styles/border_reseted.xaml" />
                <ResourceDictionary Source="/styles/customize_button_v2.xaml" />
                <ResourceDictionary Source="/styles/customize_scrollviewer.xaml" />
                <ResourceDictionary Source="/styles/customize_listbox.xaml" />
                <ResourceDictionary Source="/styles/ql_bsx_dk_styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis" />
            <converters:NewFolderBadgeVisibilityConverter x:Key="NewFolderBadgeVisibility" />

            <Style x:Key="JobHeaderCenterStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource QlBsxJobColumnHeaderStyle}">
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>
            <Style x:Key="JobHeaderLeftStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource QlBsxJobColumnHeaderStyle}">
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>
            <Style x:Key="JobCellTextCenterStyle" TargetType="TextBlock">
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="TextAlignment" Value="Center" />
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="#0D0F12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#111318" BorderBrush="#222630" BorderThickness="0,0,0,1" Padding="8,7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Width="275" Margin="5,0,10,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding DashboardTitle}" Foreground="#E8ECF1" FontSize="32" FontWeight="Bold" />
                    <TextBlock Text="{Binding DashboardSubtitle}" Foreground="#6B7280" FontSize="14" Margin="0,5,0,0" TextWrapping="Wrap" />
                </StackPanel>

                <UniformGrid Grid.Column="1" Rows="1">
                    <Border Style="{StaticResource QlBsxDkOverviewCardStyle}" Background="#161920">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" CornerRadius="18" Background="#1E2230" Margin="0,0,10,0" VerticalAlignment="Center">
                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" Foreground="#EAB308" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Tổng file" Foreground="#C0C8D4" FontSize="12" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding TotalProcessed}" Foreground="#E8ECF1" FontSize="23" FontWeight="Bold" Margin="0,1,0,0" />
                                <TextBlock Text="Hôm nay" Foreground="#6B7280" FontSize="11" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource QlBsxDkOverviewCardStyle}" Background="#161920">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" CornerRadius="18" Background="#1A2540" Margin="0,0,10,0" VerticalAlignment="Center">
                                <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" Foreground="#7BA3C9" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Đang xử lý" Foreground="#C0C8D4" FontSize="12" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding ProcessingCount}" Foreground="#E8ECF1" FontSize="23" FontWeight="Bold" Margin="0,1,0,0" />
                                <TextBlock Text="Hiện tại" Foreground="#6B7280" FontSize="11" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource QlBsxDkOverviewCardStyle}" Background="#161920">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" CornerRadius="18" Background="#152520" Margin="0,0,10,0" VerticalAlignment="Center">
                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="#4CAF50" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Thành công" Foreground="#C0C8D4" FontSize="12" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SuccessCount}" Foreground="#E8ECF1" FontSize="23" FontWeight="Bold" Margin="0,1,0,0" />
                                <TextBlock Text="{Binding SuccessRate, StringFormat='Tỷ lệ {0:F1}%'}" Foreground="#6B7280" FontSize="11" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource QlBsxDkOverviewCardStyle}" Background="#161920">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" CornerRadius="18" Background="#2A1520" Margin="0,0,10,0" VerticalAlignment="Center">
                                <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" Foreground="#E57373" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Thất bại" Foreground="#C0C8D4" FontSize="12" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding ErrorCount}" Foreground="#E57373" FontSize="23" FontWeight="Bold" Margin="0,1,0,0" />
                                <TextBlock Text="Không nhận diện" Foreground="#6B7280" FontSize="11" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource QlBsxDkOverviewCardStyle}" Background="#161920">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="TRẠNG THÁI HỆ THỐNG" Foreground="#8B95A5" FontSize="10" FontWeight="SemiBold" />
                                <StackPanel Orientation="Horizontal" Margin="0,7,0,0">
                                    <Ellipse Width="7" Height="7" Margin="0,0,6,0" VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#E57373" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsServiceRunning}" Value="True">
                                                        <Setter Property="Fill" Value="#4CAF50" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock FontSize="11" FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#E57373" />
                                                <Setter Property="Text" Value="AI DỪNG" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsServiceRunning}" Value="True">
                                                        <Setter Property="Foreground" Value="#4CAF50" />
                                                        <Setter Property="Text" Value="AI HOẠT ĐỘNG" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                                <Button Command="{Binding ToggleServiceCommand}" Width="31" Height="31" MinWidth="31" Padding="0" Margin="0,0,5,0"
                                        Style="{StaticResource QlBsxDkServiceActionStyle}" ToolTip="Khởi động/dừng AI">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="13" Style="{StaticResource QlBsxDkTextBlock03Style}" />
                                </Button>
                                <Button Command="{Binding OpenConfigCommand}" Width="31" Height="31" MinWidth="31" Padding="0" Margin="0"
                                        Style="{StaticResource QlBsxDkServiceActionStyle}" ToolTip="Cấu hình AI">
                                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#95A0B0" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </UniformGrid>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" MinWidth="520" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="1*" MinWidth="430" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Background="#161920" BorderBrush="#252830" BorderThickness="1" CornerRadius="8" Padding="12,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="28" Height="28" CornerRadius="6" Background="#16263A" Margin="0,0,9,0">
                                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" Foreground="#5BA3F5" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel>
                                    <TextBlock Text="THƯ MỤC ĐẦU VÀO" Foreground="#DEE3ED" FontSize="12" FontWeight="SemiBold" />
                                    <TextBlock Text="Nguồn ảnh giấy tờ xe cần kiểm tra" Foreground="#6B7280" FontSize="10" Margin="0,2,0,0" />
                                </StackPanel>
                            </StackPanel>
                            <Button Grid.Column="1" Command="{Binding BrowseInputDirectoryCommand}" HorizontalAlignment="Right" Padding="9,5" Background="#1A1F2B" BorderBrush="#303744" BorderThickness="1" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="5">
                                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8DA;" FontFamily="Segoe MDL2 Assets" Foreground="#5BA3F5" FontSize="11" Margin="0,0,5,0" />
                                    <TextBlock Text="Đổi thư mục" Foreground="#C7D1E0" FontSize="11" FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                        </Grid>
                        <Border Grid.Row="1" Background="#10141D" BorderBrush="#232A36" BorderThickness="1" CornerRadius="5" Padding="8,6" Margin="0,10,0,8">
                            <TextBlock Text="{Binding InputDirectory}" FontFamily="Consolas" Foreground="#C0C8D4" FontSize="11" TextTrimming="CharacterEllipsis" ToolTip="{Binding InputDirectory}" />
                        </Border>
                        <Grid Grid.Row="2" Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Dung lượng" Foreground="#6B7280" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <ProgressBar Grid.Column="1" Value="{Binding InputStorageUsagePercent, Mode=OneWay}" Maximum="100" Height="4" Foreground="#2F7BEF" Background="#1E2230" BorderThickness="0" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{Binding InputStorageUsageText}" Foreground="#8994A6" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0" />
                        </Grid>
                        <Grid Grid.Row="3">
                            <TextBlock Text="{Binding ProcessingJobs.Count, StringFormat='{}{0} job đầu vào'}" Foreground="#6B7280" FontSize="10" />
                            <TextBlock Text="{Binding TotalProcessed, StringFormat='Đã ghi nhận {0} file'}" Foreground="#6B7280" FontSize="10" HorizontalAlignment="Right" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Background="#161920" BorderBrush="#252830" BorderThickness="1" CornerRadius="8" Padding="12,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="28" Height="28" CornerRadius="6" Background="#13281E" Margin="0,0,9,0">
                                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" Foreground="#4CAF50" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel>
                                    <TextBlock Text="THƯ MỤC ĐẦU RA" Foreground="#DEE3ED" FontSize="12" FontWeight="SemiBold" />
                                    <TextBlock Text="Kết quả phân loại theo từng thư mục" Foreground="#6B7280" FontSize="10" Margin="0,2,0,0" />
                                </StackPanel>
                            </StackPanel>
                            <Button Grid.Column="1" Command="{Binding BrowseOutputDirectoryCommand}" HorizontalAlignment="Right" Padding="9,5" Background="#1A1F2B" BorderBrush="#303744" BorderThickness="1" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="5">
                                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8DA;" FontFamily="Segoe MDL2 Assets" Foreground="#5BA3F5" FontSize="11" Margin="0,0,5,0" />
                                    <TextBlock Text="Đổi thư mục" Foreground="#C7D1E0" FontSize="11" FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                        </Grid>
                        <Border Grid.Row="1" Background="#10141D" BorderBrush="#232A36" BorderThickness="1" CornerRadius="5" Padding="8,6" Margin="0,10,0,8">
                            <TextBlock Text="{Binding OutputDirectory}" FontFamily="Consolas" Foreground="#C0C8D4" FontSize="11" TextTrimming="CharacterEllipsis" ToolTip="{Binding OutputDirectory}" />
                        </Border>
                        <Grid Grid.Row="2" Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Dung lượng" Foreground="#6B7280" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <ProgressBar Grid.Column="1" Value="{Binding StorageUsagePercent, Mode=OneWay}" Maximum="100" Height="4" Foreground="#4CAF50" Background="#1E2230" BorderThickness="0" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{Binding StorageUsageText}" Foreground="#8994A6" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0" />
                        </Grid>
                        <Grid Grid.Row="3">
                            <TextBlock Text="{Binding OutputFolders.Count, StringFormat='{}{0} thư mục kết quả'}" Foreground="#6B7280" FontSize="10" />
                            <TextBlock Text="{Binding TotalProcessed, StringFormat='Đã xử lý {0} file'}" Foreground="#6B7280" FontSize="10" HorizontalAlignment="Right" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="1" Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" MinWidth="185" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="2.15*" MinWidth="360" />
                </Grid.ColumnDefinitions>

            <Border Grid.Column="2" Background="#161920" BorderBrush="#252830" BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Padding="11,9" BorderBrush="#1E2230" BorderThickness="0,0,0,1">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" Foreground="#5BA3F5" FontSize="13" Margin="0,0,7,0" VerticalAlignment="Center" />
                                <TextBlock Text="DANH SÁCH XỬ LÝ ĐẦU VÀO" Foreground="#C0C8D4" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="{Binding ProcessingJobs.Count, StringFormat={}{0} mục}" Foreground="#4CAF50" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="9,7">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="150" />
                        </Grid.ColumnDefinitions>
                        <Border Background="#0B0D12" BorderBrush="#303540" BorderThickness="1" CornerRadius="4" Height="32" Padding="8,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" Foreground="#6B7280" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Text="{Binding InputSearchText, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" Foreground="#E0E5ED" CaretBrush="#4A9EFF" VerticalContentAlignment="Center" ToolTip="Tìm theo tên file hoặc thư mục" />
                            </Grid>
                        </Border>
                        <ComboBox Grid.Column="2" SelectedValue="{Binding SelectedInputStatus}" SelectedValuePath="Tag" Style="{StaticResource CustomComboBoxStyle}" ItemContainerStyle="{StaticResource CustomComboBoxItemStyle}" Height="32">
                            <ComboBoxItem Content="Tất cả trạng thái" Tag="Táº¥t cáº£ tráº¡ng thÃ¡i" />
                            <ComboBoxItem Content="Thành công" Tag="ThÃ nh cÃ´ng" />
                            <ComboBoxItem Content="Đang xử lý" Tag="Äang xá»­ lÃ½" />
                            <ComboBoxItem Content="Lỗi" Tag="Lá»—i" />
                        </ComboBox>
                    </Grid>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding ProcessingJobs}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              CanUserResizeColumns="False"
                              CanUserReorderColumns="False"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              Style="{StaticResource QlBsxJobGridStyle}">
                        <DataGrid.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource QlBsxDkSlimScrollBarStyle}" />
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="THỜI GIAN" Binding="{Binding UpdatedAt, StringFormat={}{0:dd/MM HH:mm}}" Width="105" HeaderStyle="{StaticResource JobHeaderCenterStyle}" ElementStyle="{StaticResource JobCellTextCenterStyle}" />
                            <DataGridTemplateColumn Header="LOẠI JOB" Width="90" HeaderStyle="{StaticResource JobHeaderCenterStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SourceType}" Foreground="#8B95A5" TextTrimming="CharacterEllipsis" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="TÊN FILE" Width="*" MinWidth="170" HeaderStyle="{StaticResource JobHeaderLeftStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid VerticalAlignment="Center" ToolTip="{Binding FileName}" ToolTipService.ShowDuration="30000">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" Foreground="#8095B0" Margin="0,0,6,0" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding FileName}" Foreground="#DEE3ED" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding SizeText}" Foreground="#5A6370" FontSize="10" Margin="0,1,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="TRẠNG THÁI" Width="92" HeaderStyle="{StaticResource JobHeaderCenterStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StatusText}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#8B95A5" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                            <Setter Property="Foreground" Value="#4CAF50" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                            <Setter Property="Foreground" Value="#A9445B" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Rejected">
                                                            <Setter Property="Foreground" Value="#A9445B" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="THAO TÁC" Width="112" HeaderStyle="{StaticResource JobHeaderCenterStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Button Command="{Binding DataContext.ViewProcessingJobCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Style="{StaticResource QlBsxJobActionButtonStyle}" ToolTip="Xem ảnh">
                                                <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                                            </Button>
                                            <Button Command="{Binding DataContext.OpenProcessingJobFolderCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Style="{StaticResource QlBsxJobActionButtonStyle}" ToolTip="Mở thư mục">
                                                <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                                            </Button>
                                            <Button Command="{Binding DataContext.ShowProcessingErrorCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Style="{StaticResource QlBsxJobActionButtonStyle}" Visibility="{Binding IsError, Converter={StaticResource BoolToVis}}" ToolTip="Xem lỗi">
                                                <TextBlock Text="!" FontSize="13" FontWeight="Bold" Foreground="#A9445B" />
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="3" BorderBrush="#1E2230" BorderThickness="0,1,0,0" Padding="8,6">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Command="{Binding PreviousInputPageCommand}" Content="&#xE76B;" FontFamily="Segoe MDL2 Assets" Style="{StaticResource QlBsxDkPaginationButtonStyle}" Margin="0,0,4,0" ToolTip="Trang trước" />
                            <ItemsControl ItemsSource="{Binding InputPageButtons}" VerticalAlignment="Center">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding Text}" Command="{Binding DataContext.GoToInputPageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding PageNumber}" IsEnabled="{Binding CanNavigate}" Style="{StaticResource QlBsxDkPaginationNumberButtonStyle}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Command="{Binding NextInputPageCommand}" Content="&#xE76C;" FontFamily="Segoe MDL2 Assets" Style="{StaticResource QlBsxDkPaginationButtonStyle}" Margin="4,0,8,0" ToolTip="Trang sau" />
                            <ComboBox ItemsSource="{Binding InputPageSizeOptions}" SelectedItem="{Binding InputPageSize}" Style="{StaticResource CustomComboBoxStyle}" ItemContainerStyle="{StaticResource CustomComboBoxItemStyle}" Width="92" Height="28">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StringFormat={}{0} / trang}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

                <GridSplitter Grid.Column="1" Width="2" HorizontalAlignment="Center" VerticalAlignment="Stretch" ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" ShowsPreview="True" Background="#222630" Opacity="0.45" Cursor="SizeWE" />

                <Border Grid.Column="0" Background="#161920" BorderBrush="#252830" BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="240" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Padding="10,9" BorderBrush="#1E2230" BorderThickness="0,0,0,1">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" Foreground="#5BA3F5" FontSize="13" Margin="0,0,7,0" VerticalAlignment="Center" />
                                    <StackPanel>
                                        <TextBlock Text="ẢNH MỚI" Foreground="#C0C8D4" FontSize="12" FontWeight="SemiBold" />
                                        <TextBlock Text="Từ thư mục đầu vào" Foreground="#5A6370" FontSize="10" Margin="0,2,0,0" />
                                    </StackPanel>
                                </StackPanel>
                                <Border HorizontalAlignment="Right" VerticalAlignment="Center" Background="#182434" BorderBrush="#2C3A4C" BorderThickness="1" CornerRadius="9" Padding="6,2">
                                    <TextBlock Text="{Binding RecentCaptures.Count}" Foreground="#7BA3C9" FontSize="10" FontWeight="SemiBold" />
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Margin="8,8,8,6" Background="#0B0D12" BorderBrush="#252830" BorderThickness="1" CornerRadius="6" ClipToBounds="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Image Source="{Binding LatestDocumentCameraFrame}" Stretch="Uniform" />
                                    <TextBlock Text="Chưa có tín hiệu camera" Foreground="#667085" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding LatestDocumentCameraFrame}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <Button Command="{Binding TakeDocumentPictureCommand}" Width="48" Height="48" BorderThickness="2" BorderBrush="#F8FAFC" Background="#2B5FBF" Foreground="White" Cursor="Hand" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,12" ToolTip="Chụp ảnh vào thư mục input">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="24">
                                                    <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#3678E8" />
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter Property="Background" Value="#475467" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>

                                <Border Grid.Row="1" Background="#121722" BorderBrush="#252830" BorderThickness="0,1,0,0" Padding="8,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding DocumentCameraStatus}" Foreground="#8B95A5" FontSize="10" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding DocumentCameraNotification}" Foreground="#7BA3C9" FontSize="10" TextTrimming="CharacterEllipsis" Visibility="{Binding IsDocumentCameraNotificationVisible, Converter={StaticResource BoolToVis}}" />
                                        </StackPanel>
                                        <Button Grid.Column="1" Command="{Binding OpenDocumentCameraWindowCommand}" Width="28" Height="28" Padding="0" Background="Transparent" BorderThickness="0" Foreground="#AAB4C0" FontFamily="Segoe MDL2 Assets" Content="&#xE8A7;" ToolTip="Xem camera man hinh lon" Cursor="Hand" />
                                        <Button Grid.Column="2" Command="{Binding RestartDocumentCameraCommand}" Width="28" Height="28" Padding="0" Background="Transparent" BorderThickness="0" Foreground="#AAB4C0" FontFamily="Segoe MDL2 Assets" Content="&#xE72C;" ToolTip="Ket noi lai camera" Cursor="Hand" />
                                        <Button Grid.Column="3" Command="{Binding ToggleDocumentCameraSettingsCommand}" Width="28" Height="28" Padding="0" Background="Transparent" BorderThickness="0" Foreground="#AAB4C0" FontFamily="Segoe MDL2 Assets" Content="&#xE713;" ToolTip="Cau hinh camera" Cursor="Hand" />
                                    </Grid>
                                </Border>

                                <Border Grid.RowSpan="2" Background="#E60D0F12" Padding="10" Visibility="{Binding IsDocumentCameraSettingsVisible, Converter={StaticResource BoolToVis}}">
                                    <Grid VerticalAlignment="Center">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Link camera chụp ảnh" Foreground="#DEE3ED" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6" />
                                        <Grid Grid.Row="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="6" />
                                                <ColumnDefinition Width="64" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding DocumentRtspUrl, UpdateSourceTrigger=PropertyChanged}" Background="#10141D" BorderBrush="#303540" BorderThickness="1" Foreground="#E0E5ED" CaretBrush="#4A9EFF" Padding="7,5" Height="30" />
                                            <Button Grid.Column="2" Command="{Binding SaveDocumentRtspCommand}" Content="Lưu" Background="#2B5FBF" Foreground="White" BorderThickness="0" Height="30" Cursor="Hand" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <ListBox Grid.Row="2"
                                 ItemsSource="{Binding RecentCaptures}"
                                 Background="#0B0D12"
                                 BorderThickness="0"
                                 Padding="6"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ItemContainerStyle="{StaticResource QlBsxDkListBoxItemStyle}">
                            <ListBox.Resources>
                                <Style TargetType="ScrollBar" BasedOn="{StaticResource QlBsxDkSlimScrollBarStyle}" />
                            </ListBox.Resources>
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,7" Background="#111318" BorderBrush="#303845" BorderThickness="1" CornerRadius="5" ToolTip="{Binding FilePath}" ToolTipService.ShowDuration="30000">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="124" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Border Background="#0B0D12" CornerRadius="5,5,0,0" ClipToBounds="True">
                                                <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" Margin="2" />
                                            </Border>

                                            <Border Grid.Row="1" Background="#D9101520" Padding="7,5">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Text="{Binding FileName}" Foreground="#E0E5ED" FontSize="10" TextTrimming="CharacterEllipsis" />
                                                    <Grid Grid.Row="1" Margin="0,3,0,0">
                                                        <TextBlock Text="{Binding SizeText}" Foreground="#697487" FontSize="9" />
                                                        <TextBlock Text="{Binding CaptureTime, StringFormat='{}{0:HH:mm:ss}'}" Foreground="#7C8595" FontSize="9" HorizontalAlignment="Right" />
                                                    </Grid>
                                                </Grid>
                                            </Border>

                                            <Border Background="#2B5FBF" CornerRadius="3" Padding="4,2" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="6">
                                                <TextBlock Text="MỚI" Foreground="White" FontSize="8" FontWeight="Bold" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>

            <GridSplitter Grid.Row="1" Grid.Column="1" Width="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" ShowsPreview="True" Background="#222630" Opacity="0.5" Cursor="SizeWE" />

            <Border Grid.Row="1" Grid.Column="2" Background="#161920" BorderBrush="#252830" BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Margin="10,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" Foreground="#5BA3F5" FontSize="13" Margin="0,0,7,0" />
                            <TextBlock Text="THƯ MỤC KẾT QUẢ" Foreground="#C0C8D4" FontSize="12" FontWeight="SemiBold" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding OutputFolders.Count, StringFormat={}{0} nhom}" Foreground="#4CAF50" FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <Button Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Command="{Binding OpenSelectedFileCommand}" Padding="0" Width="30" Height="30" Background="Transparent" Foreground="#AAB4C0" BorderThickness="0" FontSize="15" Cursor="Hand" ToolTip="Mở thư mục hoặc file đang chọn" />
                    </Grid>

                    <Grid Grid.Row="1" Margin="10,0,10,9">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Height="34" Background="#181B24" BorderBrush="#354050" BorderThickness="1" CornerRadius="6" Padding="9,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" Foreground="#8095B0" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                <Grid Grid.Column="1">
                                    <TextBlock Text="Tìm theo thư mục..." Foreground="#5A6370" VerticalAlignment="Center" IsHitTestVisible="False" Style="{StaticResource QlBsxDkTextBlock04Style}" />
                                    <TextBox x:Name="FolderSearchBox" Text="{Binding FolderSearchText, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" Foreground="#E8ECF1" BorderThickness="0" CaretBrush="#4A9EFF" Padding="2,6" VerticalContentAlignment="Center" />
                                </Grid>
                            </Grid>
                        </Border>
                        <Grid Grid.Column="1" Margin="6,0,0,0">
                            <ToggleButton x:Name="FolderSortButton" Width="30" Height="30" Background="Transparent" Foreground="#AAB4C0" BorderThickness="0" Cursor="Hand" ToolTip="Sắp xếp thư mục" Content="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="15" />
                            <Popup x:Name="FolderSortPopup" PlacementTarget="{Binding ElementName=FolderSortButton}" Placement="Bottom" VerticalOffset="4" StaysOpen="False" AllowsTransparency="True" IsOpen="{Binding IsChecked, ElementName=FolderSortButton, Mode=TwoWay}">
                                <Border Background="#181B24" BorderBrush="#404858" BorderThickness="1" CornerRadius="7" Padding="5" MinWidth="155">
                                    <ListBox ItemsSource="{Binding OutputFolderSortOptions}" SelectedItem="{Binding SelectedOutputFolderSort}" ItemContainerStyle="{StaticResource QlBsxDkListBoxItemStyle}" Background="Transparent" BorderThickness="0" Foreground="#E8ECF1" SelectionChanged="FolderSortList_SelectionChanged" />
                                </Border>
                            </Popup>
                        </Grid>
                    </Grid>

                    <TreeView x:Name="OutputFileTree"
                              Grid.Row="2"
                              ItemsSource="{Binding OutputFolders}"
                              Background="#0B0D12"
                              Foreground="#E4E9F0"
                              BorderBrush="#222630"
                              BorderThickness="1"
                              Padding="6"
                              TextElement.Foreground="#E4E9F0"
                              SelectedItemChanged="OutputFileTree_SelectedItemChanged"
                              ItemContainerStyle="{StaticResource QlBsxDkTreeViewItem06Style}"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              HorizontalContentAlignment="Stretch"
                              ClipToBounds="True">
                        <TreeView.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource QlBsxDkSlimScrollBarStyle}" />
                            <Style TargetType="TreeViewItem" BasedOn="{StaticResource QlBsxDkTreeViewItem06Style}" />
                            <DataTemplate DataType="{x:Type models:PlateFolderItem}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontSize="10" Margin="0,0,7,0" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="&#x25B6;" />
                                                    <Setter Property="Foreground" Value="#5BA3F5" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TreeViewItem}}" Value="True">
                                                            <Setter Property="Text" Value="&#x25BC;" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FolderName}" FontWeight="SemiBold" Foreground="#ECF0F5" FontSize="12" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,0,0">
                                            <TextBlock Text="{Binding LastUpdatedAt, StringFormat='{}{0:HH:mm:ss}'}" Foreground="#5A6370" FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0" />
                                            <TextBlock Text="{Binding FileCount, StringFormat='({0})'}" Foreground="#95A0B0" FontSize="11" VerticalAlignment="Center" />
                                            <Border Background="#2456A8" BorderBrush="#5599DD" BorderThickness="1" CornerRadius="7" Padding="6,1" Margin="6,0,0,0" VerticalAlignment="Center">
                                                <Border.Visibility>
                                                    <MultiBinding Converter="{StaticResource NewFolderBadgeVisibility}">
                                                        <Binding Path="FolderPath" />
                                                        <Binding Path="DataContext.NewestOutputFolderPath" RelativeSource="{RelativeSource AncestorType=TreeView}" />
                                                        <Binding Path="DataContext.NewFolderBadgeExpiresAt" RelativeSource="{RelativeSource AncestorType=TreeView}" />
                                                    </MultiBinding>
                                                </Border.Visibility>
                                                <TextBlock Text="NEW" Foreground="White" FontSize="8" FontWeight="Bold" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>

                                    <Border Grid.Row="1" Height="132" Margin="0,7,0,2" Background="#0D0F12" BorderBrush="#252D38" BorderThickness="1" CornerRadius="5" Padding="6">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TreeViewItem}}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" PanningMode="HorizontalOnly">
                                            <ItemsControl ItemsSource="{Binding OutputFiles}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Width="132" Height="108" Margin="3" Background="#111318" BorderBrush="#303845" BorderThickness="1" CornerRadius="5" ToolTipService.InitialShowDelay="250">
                                                            <Border.ToolTip>
                                                                <ToolTip Background="#0D0F12" BorderBrush="#354050" BorderThickness="1" Padding="4">
                                                                    <StackPanel>
                                                                        <Image Source="{Binding Thumbnail}" Width="260" Height="160" Stretch="Uniform" />
                                                                        <TextBlock Text="{Binding FileName}" Foreground="#EEEEEE" Margin="2,4,2,0" />
                                                                    </StackPanel>
                                                                </ToolTip>
                                                            </Border.ToolTip>
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="*" />
                                                                    <RowDefinition Height="Auto" />
                                                                </Grid.RowDefinitions>
                                                                <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" Margin="2" />
                                                                <Border Grid.Row="1" Background="#D9101520" Padding="5,3">
                                                                    <Grid>
                                                                        <TextBlock Text="{Binding FileName}" Foreground="#E0E5ED" FontSize="10" TextTrimming="CharacterEllipsis" Margin="0,0,35,0" />
                                                                        <TextBlock Text="{Binding SizeText}" Foreground="#7C8595" FontSize="9" HorizontalAlignment="Right" />
                                                                    </Grid>
                                                                </Border>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </TreeView.Resources>
                    </TreeView>

                    <Border Grid.Row="3" BorderBrush="#252830" BorderThickness="0,1,0,0" Padding="7,5" Background="#111318">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Command="{Binding PreviousOutputPageCommand}" Content="&#xE76B;" FontFamily="Segoe MDL2 Assets" Style="{StaticResource QlBsxDkPaginationButtonStyle}" Margin="0,0,4,0" ToolTip="Trang trước" />
                            <ItemsControl ItemsSource="{Binding OutputPageButtons}" VerticalAlignment="Center">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding Text}" Command="{Binding DataContext.GoToOutputPageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding PageNumber}" IsEnabled="{Binding CanNavigate}" Style="{StaticResource QlBsxDkPaginationNumberButtonStyle}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Command="{Binding NextOutputPageCommand}" Content="&#xE76C;" FontFamily="Segoe MDL2 Assets" Style="{StaticResource QlBsxDkPaginationButtonStyle}" Margin="4,0,8,0" ToolTip="Trang sau" />
                            <ComboBox ItemsSource="{Binding OutputPageSizeOptions}" SelectedItem="{Binding OutputPageSize}" Style="{StaticResource CustomComboBoxStyle}" ItemContainerStyle="{StaticResource CustomComboBoxItemStyle}" Width="86" Height="28">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StringFormat={}{0} / trang}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#111318" BorderBrush="#252830" BorderThickness="0,1,0,0" Padding="15,6">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#E57373" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsServiceRunning}" Value="True">
                                    <Setter Property="Fill" Value="#4CAF50" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="AI Engine: " Foreground="#6B7280" FontSize="11" />
                <TextBlock FontSize="11" FontWeight="SemiBold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#E57373" />
                            <Setter Property="Text" Value="Dừng" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsServiceRunning}" Value="True">
                                    <Setter Property="Foreground" Value="#4CAF50" />
                                    <Setter Property="Text" Value="Hoạt động" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="  |  Mô hình: Document OCR v1.0  |  Job: " Foreground="#6B7280" FontSize="11" Margin="22,0,0,0" />
                <TextBlock Text="{Binding JobDisplayName}" Foreground="#C0C8D4" FontSize="11" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
