<Page x:Class="V3SClient.UI.Views.VLivePosition"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:V3SClient.UI.Views"
      xmlns:ucs="clr-namespace:V3SClient.ucs"
      mc:Ignorable="d" 
      xmlns:converters="clr-namespace:V3SClient.UI.Converters"
      d:DesignHeight="320" d:DesignWidth="480"
      xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      Title="Vị trí trực tuyến" Background ="#1A1A1A"  >
    <Page.Resources>
        <ResourceDictionary>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        </ResourceDictionary>
    </Page.Resources>
    
    <Grid x:Name="gridMap">
        <wv2:WebView2 x:Name="mapWebView" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
    </Grid>
</Page>



















