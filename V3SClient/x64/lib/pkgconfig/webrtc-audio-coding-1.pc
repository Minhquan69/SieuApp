prefix=${pcfiledir}/../..
includedir=${prefix}/include
libdir=${prefix}/lib

Name: webrtc-audio-coding-1
Description: WebRTC Audio Coding library
Version: 1.3
Libs: -L${libdir} -lwebrtc-audio-coding-1 -lwinmm
Cflags: -I${includedir}/webrtc-audio-processing-1 -DWEBRTC_LIBRARY_IMPL -DWEBRTC_WIN -D_WIN32 -D__STDC_FORMAT_MACROS=1 -DNOMINMAX -D_USE_MATH_DEFINES

