prefix=${pcfiledir}/../..
includedir=${prefix}/include
libdir=${prefix}/lib

Name: avformat
Description: Multimedia formats
Version: 60.3.100
Requires.private: libavcodec, libavutil, libswresample
Libs: -L${libdir} -lavformat
Libs.private: -lws2_32 -luser32 -lbcrypt -lz -lbz2
Cflags: -I${includedir}

