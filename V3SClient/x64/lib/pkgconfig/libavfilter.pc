prefix=${pcfiledir}/../..
includedir=${prefix}/include
libdir=${prefix}/lib

Name: avfilter
Description: Audio/video filtering library
Version: 9.3.100
Requires.private: libavutil, libavformat, libavcodec, libswresample, libpostproc, libswscale
Libs: -L${libdir} -lavfilter
Libs.private: -lws2_32 -luser32 -lbcrypt -lz -lbz2
Cflags: -I${includedir}

