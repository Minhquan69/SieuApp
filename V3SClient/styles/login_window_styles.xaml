<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local="clr-namespace:V3SClient.window">
  <ResourceDictionary.MergedDictionaries>
    <ResourceDictionary Source="/styles/customize_textbox.xaml" />
  </ResourceDictionary.MergedDictionaries>
  <Style x:Key="LoginInputTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource CustomTextBoxStyle}">
    <Setter Property="FontFamily" Value="Segoe UI" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Background" Value="#161920" />
    <Setter Property="Foreground" Value="#E8ECF1" />
    <Setter Property="BorderBrush" Value="#303540" />
    <Setter Property="Padding" Value="8,3" />
  </Style>
  <Style x:Key="LoginInputPasswordBoxStyle" TargetType="PasswordBox">
    <Setter Property="FontFamily" Value="Segoe UI" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Background" Value="#161920" />
    <Setter Property="Foreground" Value="#E8ECF1" />
    <Setter Property="BorderBrush" Value="#303540" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="8,3" />
    <Setter Property="CaretBrush" Value="White" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style TargetType="Button" x:Key="LoginWindowRoundedButtonStyle">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="5">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Setter Property="Background" Value="#007ACC" />
    <Setter Property="Foreground" Value="White" />
  </Style>
</ResourceDictionary>
