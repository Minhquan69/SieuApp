<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:V3SClient.UI.Pages" xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit">
  <ResourceDictionary.MergedDictionaries>
    <ResourceDictionary Source="/styles/customize_textblock.xaml" />
    <ResourceDictionary Source="/styles/customize_combobox.xaml" />
    <ResourceDictionary Source="/styles/customize_button.xaml" />
    <ResourceDictionary Source="/styles/customize_image.xaml" />
    <ResourceDictionary Source="/styles/GradientBorder.xaml" />
    <ResourceDictionary Source="/styles/search_base.xaml" />
  </ResourceDictionary.MergedDictionaries>
  <Style x:Key="ViewVaiSearchSearchToggleButtonStyle" TargetType="ToggleButton">
    <Setter Property="Height" Value="28" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="#AAAAAA" />
    <Setter Property="BorderBrush" Value="#252830" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ToggleButton">
          <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="IsChecked" Value="True">
        <Setter Property="Background" Value="#161920" />
        <Setter Property="Foreground" Value="#4A9EFF" />
        <Setter Property="FontWeight" Value="Bold" />
      </Trigger>
    </Style.Triggers>
  </Style>
</ResourceDictionary>