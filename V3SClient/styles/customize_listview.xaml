<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Style for ListView -->
  <Style TargetType="ListView">
    <Setter Property="Background" Value="White" />
    <Setter Property="BorderBrush" Value="Gray" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="FontSize" Value="12" />
  </Style>
  <!-- Style for ListView Column Headers -->
  <Style TargetType="GridViewColumnHeader">
    <Setter Property="Background" Value="#161920" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="Padding" Value="10" />
    <Setter Property="BorderBrush" Value="#252830" />
    <Setter Property="BorderThickness" Value="0 0 1 1" />
  </Style>
  <!-- Style for ListView Items (Rows) -->
  <Style TargetType="ListViewItem">
    <Setter Property="Foreground" Value="Black" />
    <Setter Property="Padding" Value="8" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="BorderBrush">
      <Setter.Value>
        <SolidColorBrush Color="Gray" Opacity="0.1" />
      </Setter.Value>
    </Setter>
    <Setter Property="BorderThickness" Value="0.5" />
    <Setter Property="Background" Value="White" />
    <!-- Added Background for ListViewItem -->
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Background" Value="#B0BEC5" />
      </Trigger>
      <Trigger Property="IsSelected" Value="True">
        <Setter Property="Background" Value="#607D8B" />
        <Setter Property="Foreground" Value="White" />
      </Trigger>
    </Style.Triggers>
  </Style>
  <!-- Style for GridViewRowPresenter (No Background here) -->
  <Style TargetType="GridViewRowPresenter">
    <Setter Property="Height" Value="40" />
  </Style>
</ResourceDictionary>