<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:webview2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf" xmlns:ucs="clr-namespace:V3SClient.ucs">
  <ResourceDictionary.MergedDictionaries>
    <ResourceDictionary Source="/styles/customize_textblock.xaml" />
    <ResourceDictionary Source="/styles/customize_combobox.xaml" />
    <ResourceDictionary Source="/styles/customize_button.xaml" />
    <ResourceDictionary Source="/styles/border_reseted.xaml" />
    <ResourceDictionary Source="/styles/gradientBorder.xaml" />
    <ResourceDictionary Source="/styles/customize_scrollviewer.xaml" />
    <ResourceDictionary Source="/styles/search_base.xaml" />
  </ResourceDictionary.MergedDictionaries>
  <Style x:Key="VaiSearchPageTimelineItemStyle" TargetType="ListBoxItem">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ListBoxItem">
          <Border x:Name="ItemBorder" Background="Transparent" Padding="0">
            <ContentPresenter />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="ItemBorder" Property="Background" Value="#1A2C3E" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="ItemBorder" Property="Background" Value="#161920" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>