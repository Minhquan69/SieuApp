<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks">
  <ResourceDictionary.MergedDictionaries>
    <ResourceDictionary Source="/styles/customize_combobox.xaml" />
    <ResourceDictionary Source="/styles/customize_textbox.xaml" />
    <ResourceDictionary Source="/styles/customize_scrollviewer.xaml" />
    <ResourceDictionary Source="/styles/customize_button.xaml" />
  </ResourceDictionary.MergedDictionaries>
  <Style x:Key="RoiConfigWindowHeaderStyle" TargetType="TextBlock">
    <Setter Property="Foreground" Value="#4A9EFF" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Margin" Value="0,10,0,8" />
  </Style>
  <Style x:Key="RoiConfigWindowLabelStyle" TargetType="TextBlock">
    <Setter Property="Foreground" Value="#8B95A5" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Margin" Value="0,8,0,4" />
  </Style>
  <Style x:Key="RoiConfigWindowInputStyle" TargetType="TextBox" BasedOn="{StaticResource CustomTextBoxStyle}">
    <Setter Property="FontSize" Value="13" />
  </Style>
  <Style x:Key="RoiConfigWindowComboStyle" TargetType="ComboBox" BasedOn="{StaticResource CustomComboBoxStyle}">
    <Setter Property="Height" Value="32" />
    <Setter Property="ItemContainerStyle" Value="{StaticResource CustomComboBoxItemStyle}" />
  </Style>
</ResourceDictionary>