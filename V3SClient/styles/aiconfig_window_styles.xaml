<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local="clr-namespace:V3SClient.window" xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks">
  <ResourceDictionary.MergedDictionaries>
    <ResourceDictionary Source="/styles/customize_button.xaml" />
    <ResourceDictionary Source="/styles/customize_button_v2.xaml" />
    <ResourceDictionary Source="/styles/customize_textblock.xaml" />
    <ResourceDictionary Source="/styles/customize_checkbox.xaml" />
    <ResourceDictionary Source="/styles/customize_combobox.xaml" />
  </ResourceDictionary.MergedDictionaries>
  <Style x:Key="AiConfigWindowSwitchStyle" TargetType="CheckBox">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="CheckBox">
          <Grid x:Name="Root" Background="Transparent">
            <Border x:Name="Background" Width="36" Height="20" CornerRadius="10" Background="#354050" BorderThickness="0" />
            <Ellipse x:Name="Thumb" Width="14" Height="14" Fill="White" HorizontalAlignment="Left" Margin="3,0,0,0">
              <Ellipse.RenderTransform>
                <TranslateTransform X="0" />
              </Ellipse.RenderTransform>
            </Ellipse>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="Background" Property="Background" Value="#4A9EFF" />
              <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
              <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style TargetType="Ellipse" x:Key="AiconfigWindowEllipse01Style">
    <Setter Property="Fill" Value="#454545" />
    <Style.Triggers>
      <DataTrigger Binding="{Binding IsEnabled}" Value="True">
        <Setter Property="Fill" Value="#4CAF50" />
      </DataTrigger>
    </Style.Triggers>
  </Style>
</ResourceDictionary>