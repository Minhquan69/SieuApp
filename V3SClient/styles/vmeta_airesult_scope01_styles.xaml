<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:V3SClient.UI.Views" xmlns:libs="clr-namespace:V3SClient.libs">
  <Style TargetType="ScrollBar">
    <Style.Triggers>
      <!--ScrollBar dọc-->
      <Trigger Property="Orientation" Value="Vertical">
        <Setter Property="Width" Value="4" />
        <Setter Property="Background" Value="#111318" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="ScrollBar">
              <Grid Background="#111318">
                <Track Name="PART_Track" IsDirectionReversed="true">
                  <Track.DecreaseRepeatButton>
                    <RepeatButton Height="0" IsEnabled="False" Template="{DynamicResource ScrollBarRepeatButtonTemplate}" />
                  </Track.DecreaseRepeatButton>
                  <Track.Thumb>
                    <Thumb>
                      <Thumb.Template>
                        <ControlTemplate TargetType="Thumb">
                          <Border Background="#AAAAAA" CornerRadius="2" Width="3" Margin="0" HorizontalAlignment="Center" />
                        </ControlTemplate>
                      </Thumb.Template>
                    </Thumb>
                  </Track.Thumb>
                  <Track.IncreaseRepeatButton>
                    <RepeatButton Height="0" IsEnabled="False" Template="{DynamicResource ScrollBarRepeatButtonTemplate}" />
                  </Track.IncreaseRepeatButton>
                </Track>
              </Grid>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Trigger>
      <!--ScrollBar ngang-->
      <Trigger Property="Orientation" Value="Horizontal">
        <Setter Property="Height" Value="4" />
        <Setter Property="Background" Value="#111318" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="ScrollBar">
              <Grid Background="#111318">
                <Track Name="PART_Track">
                  <Track.DecreaseRepeatButton>
                    <RepeatButton Style="{x:Null}" Background="#111318" BorderThickness="0" />
                  </Track.DecreaseRepeatButton>
                  <Track.Thumb>
                    <Thumb>
                      <Thumb.Template>
                        <ControlTemplate TargetType="Thumb">
                          <Border Background="#AAAAAA" CornerRadius="2" Height="3" Margin="0" />
                        </ControlTemplate>
                      </Thumb.Template>
                    </Thumb>
                  </Track.Thumb>
                  <Track.IncreaseRepeatButton>
                    <RepeatButton Style="{x:Null}" Background="#111318" BorderThickness="0" />
                  </Track.IncreaseRepeatButton>
                </Track>
              </Grid>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Trigger>
    </Style.Triggers>
  </Style>
</ResourceDictionary>