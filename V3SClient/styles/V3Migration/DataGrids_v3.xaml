<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="VmsDataGridStyle_v3" TargetType="{x:Type DataGrid}">
        <Setter Property="Background" Value="{StaticResource VmsSurfaceBrush_v3}" />
        <Setter Property="Foreground" Value="{StaticResource VmsTextPrimaryBrush_v3}" />
        <Setter Property="BorderBrush" Value="{StaticResource VmsBorderBrush_v3}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource VmsBorderSubtleBrush_v3}" />
        <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
        <Setter Property="RowHeaderWidth" Value="0" />
        <Setter Property="CanUserAddRows" Value="False" />
        <Setter Property="CanUserResizeRows" Value="False" />
        <Setter Property="EnableRowVirtualization" Value="True" />
        <Setter Property="EnableColumnVirtualization" Value="True" />
    </Style>
    <Style x:Key="VmsDataGridRowStyle_v3" TargetType="{x:Type DataGridRow}">
        <Setter Property="Background" Value="{StaticResource VmsSurfaceBrush_v3}" />
        <Setter Property="Foreground" Value="{StaticResource VmsTextPrimaryBrush_v3}" />
        <Setter Property="BorderBrush" Value="{StaticResource VmsBorderSubtleBrush_v3}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="MinHeight" Value="34" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{StaticResource VmsSurface2Brush_v3}" /></Trigger>
            <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="{StaticResource VmsPrimarySoftBrush_v3}" /></Trigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="VmsDataGridColumnHeaderStyle_v3" TargetType="{x:Type DataGridColumnHeader}">
        <Setter Property="Background" Value="{StaticResource VmsSurface2Brush_v3}" />
        <Setter Property="Foreground" Value="{StaticResource VmsTextSecondaryBrush_v3}" />
        <Setter Property="BorderBrush" Value="{StaticResource VmsBorderSubtleBrush_v3}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style x:Key="VmsCardBorderStyle_v3" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{StaticResource VmsSurfaceBrush_v3}" />
        <Setter Property="BorderBrush" Value="{StaticResource VmsBorderBrush_v3}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="16" />
    </Style>
</ResourceDictionary>
