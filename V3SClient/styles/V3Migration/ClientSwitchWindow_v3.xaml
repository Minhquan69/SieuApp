<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="ClientSwitchButton_v3" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource VmsTextPrimaryBrush_v3}"/><Setter Property="Background" Value="{StaticResource VmsSurface2Brush_v3}"/><Setter Property="BorderBrush" Value="{StaticResource VmsBorderBrush_v3}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="14,8"/><Setter Property="FontSize" Value="12"/><Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="9" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{StaticResource VmsElevatedBrush_v3}"/><Setter Property="BorderBrush" Value="{StaticResource VmsPrimaryBorderBrush_v3}"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter Property="Background" Value="{StaticResource VmsPrimaryPressedBrush_v3}"/></Trigger><Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.45"/><Setter Property="Cursor" Value="Arrow"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
    </Style>
    <Style x:Key="ClientSwitchPrimaryButton_v3" TargetType="Button" BasedOn="{StaticResource ClientSwitchButton_v3}"><Setter Property="Background" Value="{StaticResource VmsPrimaryBrush_v3}"/><Setter Property="BorderBrush" Value="{StaticResource VmsPrimaryBrush_v3}"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Padding" Value="18,10"/></Style>
    <Style x:Key="ClientSwitchListBoxItem_v3" TargetType="ListBoxItem"><Setter Property="Padding" Value="0"/><Setter Property="Margin" Value="0,0,0,10"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ListBoxItem"><Border x:Name="Card" Background="{StaticResource VmsBackgroundBrush_v3}" BorderBrush="{StaticResource VmsBorderBrush_v3}" BorderThickness="1" CornerRadius="12" Padding="16"><ContentPresenter/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Card" Property="Background" Value="{StaticResource VmsSurface2Brush_v3}"/><Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource VmsPrimaryBorderBrush_v3}"/></Trigger><Trigger Property="IsSelected" Value="True"><Setter TargetName="Card" Property="Background" Value="{StaticResource VmsPrimarySoftBrush_v3}"/><Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource VmsPrimaryBrush_v3}"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
    <Style TargetType="ScrollBar" x:Key="ClientSwitchScrollBar_v3"><Setter Property="Width" Value="8"/><Setter Property="Background" Value="{StaticResource VmsSurfaceBrush_v3}"/><Setter Property="Foreground" Value="{StaticResource VmsBorderStrongBrush_v3}"/></Style>
</ResourceDictionary>
