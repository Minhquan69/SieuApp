<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="VmsComboBoxStyle_v3" TargetType="{x:Type ComboBox}">
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Background" Value="{StaticResource VmsSurface2Brush_v3}" />
        <Setter Property="BorderBrush" Value="{StaticResource VmsBorderBrush_v3}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource VmsTextPrimaryBrush_v3}" />
    </Style>
    <Style x:Key="VmsComboBoxItemStyle_v3" TargetType="{x:Type ComboBoxItem}">
        <Setter Property="Background" Value="{StaticResource VmsSurfaceBrush_v3}" />
        <Setter Property="Foreground" Value="{StaticResource VmsTextPrimaryBrush_v3}" />
        <Setter Property="Padding" Value="8,5" />
    </Style>
</ResourceDictionary>
