<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:V3SClient.ucs.Settings.views" xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks" xmlns:converters="clr-namespace:V3SClient.UI.Converters" xmlns:i="http://schemas.microsoft.com/xaml/behaviors">
  <ResourceDictionary.MergedDictionaries>
    <ResourceDictionary Source="/styles/customize_button.xaml" />
    <ResourceDictionary Source="/styles/customize_button_v2.xaml" />
    <ResourceDictionary Source="/styles/customize_image.xaml" />
    <ResourceDictionary Source="/styles/customize_textblock.xaml" />
    <ResourceDictionary Source="/styles/customize_datagrid.xaml" />
    <ResourceDictionary Source="/styles/border_reseted.xaml" />
    <ResourceDictionary Source="/styles/customize_combobox.xaml" />
    <ResourceDictionary Source="/styles/customize_textbox.xaml" />
    <ResourceDictionary Source="/styles/customize_checkbox_v2.xaml" />
    <ResourceDictionary Source="/styles/customize_scrollviewer.xaml" />
  </ResourceDictionary.MergedDictionaries>
  <Style TargetType="Border" x:Key="CamInfoViewBorder01Style">
    <Style.Triggers>
      <DataTrigger Binding="{Binding IsActive}" Value="True">
        <Setter Property="Background" Value="#2E7D32" />
      </DataTrigger>
      <DataTrigger Binding="{Binding IsActive}" Value="False">
        <Setter Property="Background" Value="#C62828" />
      </DataTrigger>
    </Style.Triggers>
  </Style>
  <Style TargetType="TextBlock" x:Key="CamInfoViewTextBlock02Style">
    <Style.Triggers>
      <DataTrigger Binding="{Binding IsActive}" Value="True">
        <Setter Property="Text" Value="Hoạt động" />
      </DataTrigger>
      <DataTrigger Binding="{Binding IsActive}" Value="False">
        <Setter Property="Text" Value="Ngừng" />
      </DataTrigger>
    </Style.Triggers>
  </Style>
</ResourceDictionary>