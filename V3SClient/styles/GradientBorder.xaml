<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit">
  <Style x:Key="GrayBorder" TargetType="Border">
    <Setter Property="Background">
      <Setter.Value>
        <LinearGradientBrush EndPoint="1,0.5" StartPoint="0,0.5">
          <GradientStop Color="#1d1d1d" Offset="0.0" />
          <GradientStop Color="#2c3e50" Offset="0.5" />
          <GradientStop Color="#1d1d1d" Offset="1.0" />
        </LinearGradientBrush>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <!-- Khi IsMouseOver = True (chu?t n?m trên Border) -->
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Background" Value="#2c3e50" />
      </Trigger>
    </Style.Triggers>
  </Style>
  <Style TargetType="RepeatButton" x:Key="CustomizeRepeateButton">
    <Setter Property="Background" Value="#222222" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="FontSize" Value="15" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Width" Value="17" />
    <Setter Property="Height" Value="17" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Margin" Value="1" />
  </Style>
  <Style TargetType="xctk:DateTimePicker" x:Key="CustomizeDateTimePicker">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="FontFamily" Value="kanit" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="BorderBrush" Value="#252830" />
    <Setter Property="Format" Value="Custom" />
    <Setter Property="FormatString" Value="g" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="TextAlignment" Value="Left" />
    <Setter Property="Opacity" Value="0.9" />
    <Setter Property="Padding" Value="10,0,0,0" />
    <Setter Property="CalendarWidth" Value="280" />
  </Style>
</ResourceDictionary>