<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:models="clr-namespace:V3SClient.models">
  <ResourceDictionary.MergedDictionaries></ResourceDictionary.MergedDictionaries>
  <Style TargetType="StackPanel" x:Key="VehicleCaptureSlotControlStackPanel01Style">
