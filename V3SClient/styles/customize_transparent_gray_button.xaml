<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style x:Key="TransparentGrayButton" TargetType="Button">
    <!--<Setter Property="Background" Value="#1AFFFFFF"/>-->
    <Setter Property="Background">
      <Setter.Value>
        <SolidColorBrush Color="DimGray" Opacity="0.1" />
        <!-- Ð? trong su?t 10% -->
      </Setter.Value>
    </Setter>
    <Setter Property="Foreground" Value="White" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Padding" Value="2" />
    <Setter Property="BorderThickness" Value="0" />
    <!--<Setter Property="BorderBrush" Value="#60FFFFFF"/>-->
    <Setter Property="Width" Value="Auto" />
    <Setter Property="Height" Value="24" />
    <Setter Property="MinWidth" Value="56" />
    <Setter Property="MinHeight" Value="24" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" CornerRadius="0 10 0 0">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Background" Value="#30FFFFFF" />
        <Setter Property="Foreground" Value="Yellow" />
      </Trigger>
      <Trigger Property="IsPressed" Value="True">
        <Setter Property="Background" Value="#10FFFFFF" />
        <Setter Property="Foreground" Value="Gray" />
      </Trigger>
    </Style.Triggers>
  </Style>
</ResourceDictionary>