<Window x:Class="V3SClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:V3SClient"
        xmlns:usc="clr-namespace:V3SClient.ucs"
        xmlns:converters="clr-namespace:V3SClient.UI.Converters"
        xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
        mc:Ignorable="d"
        WindowState="Maximized"
        Loaded="Window_Loaded"
        WindowStyle="None"
        Title="MainWindow"
        AllowsTransparency="False"
        Background="#111318"
        Height="1000"
        Width="1500" Closing="Window_Closing">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/styles/border_reseted.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:PermissionVisibilityConverter x:Key="PermissionVisConverter"/>
        </ResourceDictionary>
    </Window.Resources>



    <!-- Border xung quanh nội dung của cửa sổ -->
    <Border BorderBrush="#111318"
            BorderThickness="2"
            CornerRadius="5" >
        <Border.Background>
            <SolidColorBrush Color="#0D0F12" Opacity="1"/>
        </Border.Background>

        <Grid Background="Transparent" >


            <Grid.RowDefinitions>
                <RowDefinition Height="60" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            
            <!--Topbar-->
            <Border Style="{StaticResource Border_Reseted}"
                    Grid.Row="0"
                    BorderBrush="#0D0F12"
                    BorderThickness="1,2,1,0"
                    Padding="12,12,12,12">
                <Border.Background>
                    <SolidColorBrush Color="#0D0F12"
                                     Opacity="0.9" />
                </Border.Background>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="326" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="300" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Opacity="1"
                            >
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="/images/logo/ivista_logo.png"
                                   Style="{StaticResource ImageFull}"
                                   Stretch="Uniform"
                                   />
                            <TextBlock Style="{StaticResource General_TextBlock}"
                                       Text=""
                                       FontSize="18"
                                       Opacity="0.8" 
                                       Margin="10,20,0,0"/>

                        </StackPanel>
                       

                    </Border>
                    <!-- Button cho các page -->
                    <Border Grid.Column="1"
                            Style="{StaticResource Border_Reseted}"
                            Padding="0"
                            Opacity="1"
                            >
                        <StackPanel x:Name="stackPanelPages"
                                    Orientation="Horizontal"
                                    Background="Transparent">

                            <Border Style="{StaticResource Border_Button}"                                    
                                                                    
                                    >
                                <Button x:Name="btnLive"
                                        Style="{StaticResource No_HandOver_Button}"
                                        Background="Transparent"
                                        Click="Selected_Page_Click"
                                        >
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/images/cam.png"
                                               Stretch="Fill" />
                                        <TextBlock Text="Live"
                                                   Style="{StaticResource General_TextBlock}"
                                                   Margin="10,0,0,0"
                                                   />

                                    </StackPanel>
                                </Button>
                            </Border>
                            <Border Style="{StaticResource Border_Button}">
                                <Button x:Name="btnEMap"
                                        Style="{StaticResource No_HandOver_Button}"
                                        Background="Transparent"
                                        Click="btnEMap_Click"
                                        >

                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/images/location.png"
                                               Stretch="Fill" />
                                        <TextBlock Text="E-Map"
                                                   Style="{StaticResource General_TextBlock}"
                                                   Margin="10,0,0,0" />

                                    </StackPanel>
                                </Button>

                            </Border>

                            <!--<Border 
                                    Style="{StaticResource Border_Button}">
                                
                                <Button x:Name="btnPlayback"
                                        Style="{StaticResource No_HandOver_Button}"
                                        Background="Transparent"
                                        Click="Selected_Page_Click"
                                        >
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/images/playback.png"
                                               Stretch="Fill" />
                                        <TextBlock Text="Playback"
                                                   Style="{StaticResource General_TextBlock}"
                                                   Margin="10,0,0,0"
                                                    />

                                    </StackPanel>
                                </Button>

                            </Border>-->
                   
                            <Border Background="Transparent" Style="{StaticResource Border_Button}">
                                <Button x:Name="btnPlaybackHLS"
                                        Style="{StaticResource No_HandOver_Button}"
                                        Background="Transparent"
                                        Click="Selected_Page_Click"
                                        >
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/images/playback.png"
                                               Stretch="Fill" />
                                        <TextBlock Text="Playback"
                                                   Style="{StaticResource General_TextBlock}"
                                                   Margin="10,0,0,0"
                                                    />

                                    </StackPanel>
                                </Button>
                            </Border>
                            <Border x:Name="menuRegDK" Style="{StaticResource Border_Button}">
                                <Button x:Name="btnRegDK" Style="{StaticResource No_HandOver_Button}" Background="Transparent" Click="Selected_Page_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/images/vehicle_manager.png" Stretch="Fill" ToolTip="Quản lý đăng ký xe"/>
                                        <TextBlock Text="V-Reg" Style="{StaticResource General_TextBlock}" Margin="10,0,0,0" />
                                    </StackPanel>
                                </Button>
                            </Border>

                            <Border x:Name="menuQLBSXDK" Style="{StaticResource Border_Button}">
                                <Button x:Name="btnQLBSXDK" Style="{StaticResource No_HandOver_Button}" Background="Transparent" Click="Selected_Page_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/images/vehicle_manager.png" Stretch="Fill" ToolTip="Quản lý BSX đăng ký"/>
                                        <TextBlock Text="QL_BSX_DK" Style="{StaticResource General_TextBlock}" Margin="10,0,0,0" />
                                    </StackPanel>
                                </Button>
                            </Border>

                            <Border x:Name="menuDocScan" Style="{StaticResource Border_Button}">
                                <Button x:Name="btnDocScan" Style="{StaticResource No_HandOver_Button}" Background="Transparent" Click="Selected_Page_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" Foreground="#E8ECF1"
                                                   FontSize="20" Width="24" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   ToolTip="Quét và xử lý tài liệu" />
                                        <TextBlock Text="DOC SCAN" Style="{StaticResource General_TextBlock}" Margin="10,0,0,0" />
                                    </StackPanel>
                                </Button>
                            </Border>

                           



                            <!-- Nút Menu mở rộng (category) chứa Downloads + Settings -->
                            <Border Style="{StaticResource Border_Button}">
                                <Grid>
                                    <Button x:Name="btnCategoryMenu"
                                            Style="{StaticResource No_HandOver_Button}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Click="btnCategoryMenu_Click"
                                            ToolTip="Thêm chức năng">
                                        <Image Source="/images/category.png"
                                               Style="{StaticResource ImageFull}"
                                               Stretch="UniformToFill" />
                                    </Button>

                                    <Popup x:Name="CategoryPopup" 
                                           PlacementTarget="{Binding ElementName=btnCategoryMenu}" 
                                           Placement="Bottom" 
                                           StaysOpen="False" 
                                           AllowsTransparency="True" 
                                           PopupAnimation="Fade">
                                        <Border Background="#181C24" BorderBrush="#303540" BorderThickness="1" CornerRadius="6" Padding="5" MinWidth="180" Margin="0,5,0,0">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.5" Color="Black"/>
                                            </Border.Effect>
                                            <StackPanel>

                                                <Button x:Name="btnAIAnalysisLog" Background="Transparent" BorderThickness="0" Cursor="Hand" HorizontalContentAlignment="Left" Padding="10,8" Click="Selected_Page_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Source="/images/log.png" Width="18" Height="18" Stretch="Uniform" Margin="0,0,10,0"/>
                                                        <TextBlock Text="AI logs" Foreground="#E8ECF1" FontSize="13" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>

                                                <!-- Downloads -->
                                                <Button x:Name="btnDownloads" Background="Transparent" BorderThickness="0" 
                                                        Cursor="Hand" HorizontalContentAlignment="Left" Padding="10,8"
                                                        Click="btnDownloads_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Source="/images/download.png" Width="18" Height="18" Stretch="Uniform" Margin="0,0,10,0"/>
                                                        <TextBlock Text="Downloads" Foreground="#E8ECF1" FontSize="13" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>

                                                <Separator Background="#303540" Margin="5,2" Height="0.5"/>

                                                <!-- Config (có phân quyền) -->
                                                <Button x:Name="btnConfig" Background="Transparent" BorderThickness="0"
                                                        Cursor="Hand" HorizontalContentAlignment="Left" Padding="10,8"
                                                        Visibility="{Binding Converter={StaticResource PermissionVisConverter}, ConverterParameter='camera:view|roi:view|camera_group:view|ai_assignment:view|client_profile:view|config:view'}"
                                                        Click="Selected_Page_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Source="/images/config.png" Width="18" Height="18" Stretch="Uniform" Margin="0,0,10,0"/>
                                                        <TextBlock Text="Cấu hình" Foreground="#E8ECF1" FontSize="13" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>

                                                <!-- AI Config (mặc định ẩn) -->
                                                <Button x:Name="btnAIConfig" Background="Transparent" BorderThickness="0"
                                                        Cursor="Hand" HorizontalContentAlignment="Left" Padding="10,8"
                                                        Visibility="Collapsed"
                                                        Click="Selected_Page_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Source="/images/AI.png" Width="18" Height="18" Stretch="Uniform" Margin="0,0,10,0"/>
                                                        <TextBlock Text="AI Config" Foreground="#E8ECF1" FontSize="13" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </Border>
                  
                   
                    

                    <!-- Các nút chức năng của chương trình-->

                    <Border Grid.Column="2"
                            Padding="0,0,0,0"
                            Opacity="1"
                            >
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="10" />                                
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>



                            <!--<Button Grid.Column="0"
                                    Style="{StaticResource No_HandOver_Button}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                     Click="btn_User_Click"
                                    >
                                <StackPanel Orientation="Horizontal"
                                            Background="Transparent">
                                    <Image Source="/images/user.png"
                                           Stretch="Fill" />
                                    <TextBlock Style="{StaticResource General_TextBlock}"
                                               Margin="5,0,0,0"
                                               Text="Admin" />
                                </StackPanel>

                            </Button>-->
                            <Grid>
                                <Button x:Name="UserButton" Grid.Column="0" Style="{StaticResource No_HandOver_Button}" Background="Transparent" BorderThickness="0" Click="btn_User_Click" ToolTip="Thông tin tài khoản đăng nhập">
                                    <StackPanel Orientation="Horizontal" Background="Transparent">
                                        <Image Source="/images/user.png" Stretch="Fill" Width="24" Height="24"/>
                                        <TextBlock Style="{StaticResource General_TextBlock}" Margin="5,0,0,0" x:Name="UsernameDisplay" Text="Admin"/>
                                    </StackPanel>
                                </Button>

                                <!-- Popup Dropdown Hiện đại -->
                                <Popup x:Name="UserPopup"  PlacementTarget="{Binding ElementName=UserButton}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                    <Border Background="#181C24"  BorderBrush="#303540" BorderThickness="1" CornerRadius="8" Padding="15" Width="220">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.5" Color="Black"/>
                                        </Border.Effect>
                                        <StackPanel>
                                            <!-- Section: Thông tin người dùng -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                <Icon:PackIconMaterial Kind="AccountCircle" Foreground="#4A9EFF" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                <StackPanel>
                                                    <TextBlock Text="Người dùng" FontSize="10" Foreground="#6B7280" FontWeight="Light"/>
                                                    <TextBlock x:Name="UsernameDisplayPopUp" Text="userlogin" FontWeight="Bold" Foreground="#E8ECF1" FontSize="13"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <Separator Background="#303540" Margin="0,0,0,12" Height="0.5"/>

                                            <!-- Section: Chi tiết đăng nhập -->
                                            <Grid Margin="0,0,0,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="28"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Icon:PackIconMaterial Kind="ClockTimeFourOutline" Foreground="#5A6370" Width="14" Height="14" VerticalAlignment="Center" Grid.Row="0"/>
                                                <TextBlock x:Name="LoginTimeDisplay" Text="--:--" Foreground="#C0C8D4" FontSize="11" VerticalAlignment="Center" Grid.Column="1" Grid.Row="0" Margin="0,0,0,8"/>

                                                <Icon:PackIconMaterial Kind="Monitor" Foreground="#5A6370" Width="14" Height="14" VerticalAlignment="Center" Grid.Row="1"/>
                                                <Grid Grid.Column="1" Grid.Row="1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <ComboBox x:Name="cboActiveClient" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0" DisplayMemberPath="Name" SelectedValuePath="Id" />
                                                    <Button x:Name="btnSwitchProfile" Content="Áp dụng" Grid.Column="1" FontSize="10" Padding="5,2" Background="#4A9EFF" Foreground="White" BorderThickness="0" Click="btnSwitchProfile_Click" Cursor="Hand" ToolTip="Áp dụng Profile mới" />
                                                </Grid>
                                                <TextBlock x:Name="txtActiveClient" Visibility="Collapsed" />
                                            </Grid>

                                            <Separator Background="#303540" Margin="0,12,0,12" Height="0.5"/>

                                            <!-- Section: Hành động -->
                                            <Button x:Name="btnNativeConfig" Click="btnNativeConfig_Click" Background="Transparent" BorderThickness="0" Margin="0,0,0,10" HorizontalAlignment="Left" Cursor="Hand">
                                                <StackPanel Orientation="Horizontal">
                                                    <Icon:PackIconMaterial Kind="Cog" Width="16" Height="16" Foreground="#4A9EFF" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Cấu hình" Foreground="#E8ECF1" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Button>

                                            <Button Click="Logout_Click" Background="Transparent" BorderThickness="0" HorizontalAlignment="Left" Cursor="Hand">
                                                <StackPanel Orientation="Horizontal">
                                                    <Icon:PackIconMaterial Kind="Logout" Width="16" Height="16" Foreground="#E57373" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Đăng xuất" Foreground="#E57373" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Button>

                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>
                            <TextBlock Grid.Column="1"
                                       Text="|"
                                       Style="{StaticResource General_TextBlock}"
                                       FontSize="20"
                                       FontWeight="Light"
                                       Opacity="0.3" />
                            
                            <Button Grid.Column="2"
                                    Padding="3"
                                    Style="{StaticResource No_HandOver_Button}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    x:Name="btn_MaximizeWindow"
                                    Click="btn_MaximizeWindow_Click" ToolTip="Thu nhỏ màn hình">
                                <Image Source="/images/maximize-window.png"
                                       Style="{StaticResource ImageFull}"
                                       Stretch="Uniform" />
                            </Button>
                            <Button Grid.Column="3"
                                    Padding="3"
                                    Style="{StaticResource No_HandOver_Button}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    x:Name="btn_MinimizeWindow"
                                    Click="btn_MinimizeWindow_Click" ToolTip="Ẩn xuống thanh công cụ">
                                <Image Source="/Images/minimize-window.png"
                                       Style="{StaticResource ImageFull}"
                                       Stretch="Uniform" />
                            </Button>
                            <Button Grid.Column="4"
                                    Padding="3"
                                    Style="{StaticResource No_HandOver_Button}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    x:Name="btn_Exit"
                                    Click="btn_Exit_Click" ToolTip="Thoát chương trình">
                                <Image Source="/images/close_app.png"
                                       Style="{StaticResource ImageFull}"
                                       Stretch="Uniform" />
                            </Button>
                        </Grid>

                    </Border>
                </Grid>
            </Border>

            <Frame x:Name="Frm_Content"
                   NavigationUIVisibility="Hidden"
                   Grid.Row="1"
                   Background="Transparent" />



            <!-- Thêm các phần tử UI của bạn ở đây -->

        </Grid>
    </Border>
</Window>
